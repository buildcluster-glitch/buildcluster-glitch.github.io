// PDFテンプレを1度ロード&キャッシュ
const _suidoPdfCache = {};
async function renderSuidoPdfBackground(templateKey) {
  if (!window.pdfjsLib) { showToast('pdf.js未読込', true); return false; }
  const tmpl = window.SUIDO_PDF_TEMPLATES?.[templateKey];
  if (!tmpl) { showToast(`テンプレ「${templateKey}」が読込めません`, true); return false; }
  const canvas = document.getElementById('suido-pdf-canvas');
  if (!canvas) return false;
  // 縦横の切替
  const wrap = document.getElementById('suido-canvas-wrap');
  const isLandscape = SUIDO_FIELD_MAPS[templateKey]?.orientation === 'landscape';
  if (wrap) wrap.classList.toggle('landscape', isLandscape);
  try {
    let pdf = _suidoPdfCache[templateKey];
    if (!pdf) {
      const bytes = _base64ToUint8Array(tmpl.pdfBase64);
      try {
        pdf = await pdfjsLib.getDocument({ data: bytes }).promise;
      } catch (e1) {
        pdf = await pdfjsLib.getDocument({ data: bytes, disableWorker: true }).promise;
      }
      _suidoPdfCache[templateKey] = pdf;
    }
    const page = await pdf.getPage(1);
    const viewport = page.getViewport({ scale: 2.5 });
    canvas.width = viewport.width;
    canvas.height = viewport.height;
    const ctx = canvas.getContext('2d');
    await page.render({ canvasContext: ctx, viewport }).promise;
    return true;
  } catch (e) {
    console.error('[suido] PDF render failed:', e);
    showToast('PDF描画失敗: ' + (e.message||e), true);
    return false;
  }
}

