// 住所から市町村を判定
function detectSuidoCity(address) {
  const s = address || '';
  if (/仙台市/.test(s)) return 'sendai';
  if (/富谷市/.test(s)) return 'tomiya';
  if (/大和町/.test(s)) return 'taiwa';
  return 'other';
}
const SUIDO_CITY_LABELS = {
  sendai: '仙台市水道局',
  tomiya: '富谷市水道事業',
  taiwa:  '大和町水道事業',
  other:  '(自動判定できず)',
};
// 発注書工期から使用開始日・廃止日を算出(最早開始日, 最遅終了日)
function getSuidoPeriodDates() {
  const lines = state.estimate?.lines || [];
  const mds = [];
  lines.forEach(l => {
    if (l.hatchuPeriodStart) mds.push({ type:'start', md: l.hatchuPeriodStart });
    if (l.hatchuPeriodEnd) mds.push({ type:'end', md: l.hatchuPeriodEnd });
  });
  // "M/D" を数値化(月×100+日)でソート比較
  const key = (md) => {
    const p = parseMonthDay(md);
    if (!p.m || !p.d) return null;
    return Number(p.m) * 100 + Number(p.d);
  };
  const starts = mds.filter(x => x.type === 'start').map(x => x.md).filter(md => key(md) != null);
  const ends = mds.filter(x => x.type === 'end').map(x => x.md).filter(md => key(md) != null);
  // 最早開始, 最遅終了
  starts.sort((a,b) => key(a) - key(b));
  ends.sort((a,b) => key(b) - key(a));
  return { startMD: starts[0] || '', endMD: ends[0] || '' };
}
// 和暦化(今年基準、M/D → 令和N年M月D日)
function formatJpFromMD(md) {
  if (!md) return '';
  const p = parseMonthDay(md);
  if (!p.m || !p.d) return '';
  const today = new Date();
  const y = today.getFullYear();
  // 今日の月より前なら来年扱い(過去日付防止)
  let year = y;
  const curMonthKey = (today.getMonth()+1) * 100 + today.getDate();
  const mdKey = Number(p.m) * 100 + Number(p.d);
  if (mdKey < curMonthKey - 30) year = y + 1; // 30日以上前なら来年
  const reiwaYear = year - 2018;
  return `令和${reiwaYear}年${Number(p.m)}月${Number(p.d)}日`;
}

