  showToast(`${SUIDO_FIELD_MAPS[templateKey]?.label || templateKey} を読込中…`);
  const ok = await renderSuidoPdfBackground(templateKey);
  if (!ok) return;
  renderSuidoOverlays(templateKey, getSuidoFormData());
  const prevTitle = document.title;
  const meta = state.estimate?.meta || {};
  document.title = sanitizeFilename(`[${meta.bukken||'(無題)'}${meta.roomNo?' '+meta.roomNo:''}] 水道申込_${templateKey}_${formatToday()}`);
  // 向き(landscape/portrait)の @page を動的注入
  const isLandscape = SUIDO_FIELD_MAPS[templateKey]?.orientation === 'landscape';
  let pageStyle = null;
  if (isLandscape) {
    pageStyle = document.createElement('style');
    pageStyle.id = '__suido-page-style';
    pageStyle.textContent = '@page { size: A4 landscape; margin: 0; }';
    document.head.appendChild(pageStyle);
    document.body.classList.add('suido-landscape');
  }
  document.body.classList.add('print-suido-mode');
  setTimeout(() => {
    window.print();
    setTimeout(() => {
      document.body.classList.remove('print-suido-mode');
      document.body.classList.remove('suido-landscape');
      if (pageStyle) pageStyle.remove();
      document.title = prevTitle;
    }, 300);
  }, 250);
}

