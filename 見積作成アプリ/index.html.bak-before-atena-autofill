  // モードに応じて優先グループを先頭に
  const groupOrder = mode === 'order'
    ? ['hatchu','material','moto','sanko']
    : ['moto','sanko','hatchu','material'];
  groupOrder.forEach(key => {
    const g = COL_GROUPS[key];
    const cols = g.cols.filter(c => visible.has(c));
    if (!cols.length) return;
    const og = document.createElement('optgroup');
    og.label = g.label;
    cols.forEach(c => {
      const opt = document.createElement('option');
      opt.value = c; opt.textContent = c;
      og.appendChild(opt);
    });
    priceColSelect.appendChild(og);
  });
  priceColSelect.value = currentPriceCol();
  priceColLabel.textContent = mode === 'order' ? '発注先(発注書単価列)' : '元請け(見積書単価列)';
  docTitle.textContent = mode === 'order' ? '御発注書' : '御見積書';
}

// 見積単価列の変更時のみ、既存行の unitPrice を新列で更新するか確認
function updateEstimateUnitPriceFromCol(targetCol) {
  if (!state.estimate.lines.length) return;
  if (!confirm(`既存明細の見積単価を「${targetCol}」の単価で更新しますか?\n(発注単価には影響しません)`)) return;
  state.estimate.lines.forEach(l => {
    if (l.itemRef) {
      const m = state.master.find(x => String(x.項目番号) === String(l.itemRef));
      if (m && m[targetCol] != null) {
        l.unitPrice = m[targetCol];
        l.amountOverride = null;
      }
    }
  });
  saveEstimate();
}

