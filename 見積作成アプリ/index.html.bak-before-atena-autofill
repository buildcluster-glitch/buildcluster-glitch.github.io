function copyCheckedRows() {
  const idxs = getCheckedRowIndexes();
  if (!idxs.length) { alert('コピーする行にチェックを入れてください'); return; }
  rowClipboard = idxs.map(i => JSON.parse(JSON.stringify(state.estimate.lines[i])));
  alert(`${rowClipboard.length}行をコピーしました。貼付ボタンで挿入できます。`);
}
function pasteRows() {
  if (!rowClipboard.length) { alert('コピーされた行がありません'); return; }
  // 挿入位置: 選択行があればその最後の次、なければ末尾
  const idxs = getCheckedRowIndexes();
  const insertAt = idxs.length ? Math.max(...idxs) + 1 : state.estimate.lines.length;
  const clone = rowClipboard.map(l => JSON.parse(JSON.stringify(l)));
  state.estimate.lines.splice(insertAt, 0, ...clone);
  saveEstimate(); renderEstimate();
}
function deleteCheckedRows() {
  const idxs = getCheckedRowIndexes();
  if (!idxs.length) { alert('削除する行にチェックを入れてください'); return; }
  if (!confirm(`${idxs.length}行を削除しますか?`)) return;
  // 後ろから削除してインデックスずれ防止
  idxs.sort((a,b)=>b-a).forEach(i => state.estimate.lines.splice(i, 1));
  saveEstimate(); renderEstimate();
}
