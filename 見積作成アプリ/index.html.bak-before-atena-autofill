// 工事お知らせ(入居者向け)
// =========================
// 音が出るカテゴリ(フローリング工事/大工工事)
const NOISY_CATEGORIES = new Set(['フローリング工事', '大工工事']);

// 管理会社の正規化(元請け列名 → 入居者向け正式社名)
function normalizeKanriCompany(raw) {
  if (!raw) return '';
  if (/山一/.test(raw))       return '株式会社山一地所';
  if (/みどり不動産/.test(raw)) return '有限会社みどり不動産';
  if (/JSB|ジェイ.?エス.?ビー/i.test(raw)) return '株式会社ジェイ・エス・ビー・ネットワーク';
  return raw;
}

function getOshirase() {
  if (!state.estimate) return null;
  if (!state.estimate.meta.oshirase) state.estimate.meta.oshirase = emptyOshirase();
  return state.estimate.meta.oshirase;
}

// カテゴリ別工期を 発注書lineから抽出
// {category: {start: 'M/D', end: 'M/D'}}
function getCategoryPeriods() {
  const lines = (state.estimate?.lines || []).filter(l => l.item && !l.reduced);
  const byCat = {};
  const dateKey = (md) => {
    const p = parseMonthDay(md);
    if (!p.m || !p.d) return null;
    return Number(p.m) * 100 + Number(p.d);
  };
  lines.forEach(l => {
    const cat = l.category;
    if (!cat) return;
    if (!byCat[cat]) byCat[cat] = { starts: [], ends: [] };
    if (l.hatchuPeriodStart) byCat[cat].starts.push(l.hatchuPeriodStart);
    if (l.hatchuPeriodEnd) byCat[cat].ends.push(l.hatchuPeriodEnd);
  });
  const result = {};
  Object.entries(byCat).forEach(([cat, data]) => {
    const valid = (arr) => arr.filter(md => dateKey(md) != null);
    const sortedStart = valid(data.starts).sort((a,b) => dateKey(a) - dateKey(b));
    const sortedEnd = valid(data.ends).sort((a,b) => dateKey(b) - dateKey(a));
    const s = sortedStart[0] || '';
    const e = sortedEnd[0] || '';
    if (s || e) result[cat] = { start: s, end: e };
  });
  return result;
}

// 全体工期を取得(最早開始, 最遅終了)
function getOverallPeriod() {
  const { startMD, endMD } = getSuidoPeriodDates();
  return { start: startMD, end: endMD };
}

// 自動データを oshirase フィールドに埋める(空欄のみ)
function autoFillOshirase() {
  const o = getOshirase();
  if (!o) return;
  const est = state.estimate;
  const meta = est.meta || {};
  const t = meta.taikyo || {};
  const issuer = currentIssuer();
  if (!o.issueDate) {
    const d = new Date();
    const reiwaY = d.getFullYear() - 2018;
    o.issueDate = `令和${reiwaY}年${d.getMonth()+1}月吉日`;
  }
  if (!o.issueMonth) {
    const d = new Date();
    o.issueMonth = `${d.getFullYear()}/${d.getMonth()+1}/${d.getDate()}`;
  }
  if (!o.bukkenName) o.bukkenName = meta.bukken || t.apartmentName || '';
  if (!o.roomNo) o.roomNo = meta.roomNo || '';
  const { start, end } = getOverallPeriod();
  if (!o.workStart && start) o.workStart = start;
  if (!o.workEnd && end) o.workEnd = end;
  {
    const raw = state.settings.priceCol || meta.motouke || '';
    // 空欄 or 内部列名(山一Dクレ等 非正式表記)が入ってる場合は正規化して上書き
    const isRawColName = DEFAULT_MOTO_COLS.includes(o.kanriCompany) ||
                         (state.settings.customMotouke||[]).includes(o.kanriCompany) ||
                         !o.kanriCompany;
    if (isRawColName) {
      o.kanriCompany = normalizeKanriCompany(raw);
    }
  }
  if (!o.shikouCompany) o.shikouCompany = '(株)ビルドクラスタ';
  if (!o.tantouName) o.tantouName = t.tachiaiPerson || issuer.tantou || '';
  if (!o.tantouTel) o.tantouTel = t.tachiaiPersonTel || issuer.tantouTel || '';
  if (!o.workHours) o.workHours = '9:00〜17:30';
  // 工事内容(大分類)
  const periods = getCategoryPeriods();
  const cats = Object.keys(periods);
  if (!o.workCategories) o.workCategories = cats.join('・');
  saveEstimate();
}

/* =========================
   ISP用タブ(元請けシステム転記用)
   ========================= */
function renderIsp() {
  const est = state.estimate;
  const thead = document.getElementById('isp-thead');
  const tbody = document.getElementById('isp-tbody');
  const tfoot = document.getElementById('isp-tfoot');
  const sumEl = document.getElementById('isp-summary');
  if (!thead || !tbody) return;
  if (!est) {
    thead.innerHTML = '';
    tbody.innerHTML = '<tr><td style="padding:12px; color:var(--muted);">見積データがありません。</td></tr>';
    if (tfoot) tfoot.innerHTML = '';
    if (sumEl) sumEl.innerHTML = '';
    return;
  }

  // 列定義: ラベル / 値関数 / コピー時の整形
  const rule = getMotoukeRule();
  // 小計(amount)を返すヘルパー
  const yanushiSubtotal = l => {
    return effectiveBurdenType(l) === '家主' ? effectiveYanushiAmt(l, rule) : 0;
  };
  const tenantSubtotal = l => {
    return effectiveBurdenType(l) === '入居者' ? effectiveTenantAmt(l) : 0;
  };
  // 単価 = 小計 / 数量(数量0の時は0)
  const perUnit = (subtotal, qty) => {
    const q = Number(qty) || 0;
    if (q === 0) return 0;
    return Math.round(subtotal / q);
  };
  // ハウスクリーニング / エアコンクリーニング 判定(過失諸経費 5% の対象外)
  const isHcEc = l => /ハウスクリーニング|エアコンクリーニング/.test(l.item || '');
  // 過失負担対象判定(明示true/falseがあれば優先、なければ 入居者負担 かつ HC/EC でない場合に true)
  const isKashitsu = l => {
    if (l.kashitsu === true || l.kashitsu === false) return l.kashitsu;
    return (effectiveBurdenType(l) === '入居者') && !isHcEc(l);
  };
  // グループ別 色定義
  // info=灰 / jisha=青 / yanushi=オレンジ / tenant=緑
  const GROUP_STYLE = {
    info:    { headBg:'#f3f4f6', headFg:'#374151', cellBg:'',         subBg:'',         border:'var(--line)' },
    jisha:   { headBg:'#dbeafe', headFg:'#1e3a8a', cellBg:'#f0f7ff',  subBg:'#dbeafe',  border:'#93c5fd' },
    yanushi: { headBg:'#fed7aa', headFg:'#7c2d12', cellBg:'#fff7ed',  subBg:'#fed7aa',  border:'#fdba74' },
    tenant:  { headBg:'#bbf7d0', headFg:'#166534', cellBg:'#f0fdf4',  subBg:'#bbf7d0',  border:'#86efac' }
  };
  const COLS = [
    { key: 'kashitsu',      group:'info',    label: '過失',       get: l => isKashitsu(l) ? '✓' : '',                          align: 'center', width: '4%',  special:'checkbox', skipCopy: true },
    {
      key: 'name', group:'info',
      label: '工事名称＋室名＋仕様・摘要',
      get: l => [l.item, l.room, l.specs].filter(Boolean).join(' ').replace(/\s+/g,' ').trim(),
      align: 'left',
      width: '22%'
    },
    { key: 'qty',           group:'info',    label: '数量',       get: l => (Number(l.qty) || 0),                              align: 'right', width: '5%',  num: true },
    { key: 'unit',          group:'info',    label: '単位',       get: l => l.unit || '',                                      align: 'center', width: '5%' },
    { key: 'burden',        group:'info',    label: '負担区分',   get: l => effectiveBurdenType(l),                            align: 'center', width: '8%',  special:'burden', skipCopy: true },
    { key: 'unitPrice',     group:'jisha',   label: '見積単価',   get: l => (Number(l.unitPrice) || 0),                        align: 'right', width: '9%',  num: true },
    { key: 'jishaSub',      group:'jisha',   label: '見積小計',   get: l => lineAmount(l, 'estimate'),                         align: 'right', width: '9%',  num: true, sub: true },
    { key: 'yanushiUnit',   group:'yanushi', label: '家主単価',   get: l => perUnit(yanushiSubtotal(l), l.qty),                align: 'right', width: '9%',  num: true },
    { key: 'yanushi',       group:'yanushi', label: '家主小計',   get: l => yanushiSubtotal(l),                                align: 'right', width: '9%',  num: true, sub: true, editable: 'yanushiAmt' },
    { key: 'tenantUnit',    group:'tenant',  label: '入居者単価', get: l => perUnit(tenantSubtotal(l), l.qty),                 align: 'right', width: '9%',  num: true },
    { key: 'tenant',        group:'tenant',  label: '入居者小計', get: l => tenantSubtotal(l),                                 align: 'right', width: '11%', num: true, sub: true, editable: 'tenantAmt' }
  ];

  // 対象行: item があり、減工事ではない行
  const lines = (est.lines || []).filter(l => l.item && !l.reduced);

  // 末尾に「産廃処分費(見積総額の5%)」を家主負担として追加(ISPタブ専用)
  const subtotal = lines.reduce((s, l) => s + lineAmount(l, 'estimate'), 0);
  const sanpaiAmt = Math.round(subtotal * 0.05);
  if (subtotal > 0) {
    lines.push({
      item: '産廃処分費',
      room: '全室',
      specs: '産業廃棄物運搬処分費',
      qty: 1,
      unit: '式',
      unitPrice: 0,             // 自社見積単価は0円
      burdenType: '家主',
      yanushiAmt: sanpaiAmt,    // 家主単価を直接固定(倍率/マスタを通さない)
      tenantAmt: 0,
      _isp_synthetic: true,
      _isp_formula: `見積総額 ${fmtNum(subtotal)} × 5% = ${fmtNum(sanpaiAmt)}`
    });
  }

  // 末尾に「諸経費(過失分5%)」を入居者負担として追加(ISPタブ専用)
  // 過失負担チェックON かつ 入居者負担 かつ HC/EC でない行の入居者小計の5%
  const kashitsuBase = lines
    .filter(l => !l._isp_synthetic && isKashitsu(l) && !isHcEc(l) && (effectiveBurdenType(l) === '入居者'))
    .reduce((s,l) => s + tenantSubtotal(l), 0);
  const kashitsuShoKeihi = Math.round(kashitsuBase * 0.05);
  if (kashitsuShoKeihi > 0) {
    lines.push({
      item: '諸経費',
      room: '全室',
      specs: '入居者過失分5%(産廃処分費)',
      qty: 1,
      unit: '式',
      unitPrice: 0,
      burdenType: '入居者',
      _isp_formula: `入居者過失小計 ${fmtNum(kashitsuBase)} × 5% = ${fmtNum(kashitsuShoKeihi)}`,
      yanushiAmt: 0,
      tenantAmt: kashitsuShoKeihi,
      _isp_synthetic: true
    });
  }

  // ヘッダ(ラベル + 各列のコピー数)+ グループバンド
  // 1段目: グループ見出し帯(自社見積/家主見積/入居者見積)
  const groupBands = [
    { group:'info',    label:'',       span: 5 },
    { group:'jisha',   label:'🏢 自社見積',   span: 2 },
    { group:'yanushi', label:'👤 家主見積',   span: 2 },
    { group:'tenant',  label:'🏠 入居者見積', span: 2 }
  ];
  thead.innerHTML = `
    <tr>
      ${groupBands.map(b => {
        const s = GROUP_STYLE[b.group];
        return `<th colspan="${b.span}" style="padding:5px 8px; background:${s.headBg}; color:${s.headFg}; border:1px solid ${s.border}; text-align:center; font-size:12px; font-weight:600;">${b.label}</th>`;
      }).join('')}
    </tr>
    <tr>
      ${COLS.map((c,i) => {
        const s = GROUP_STYLE[c.group];
        const headBg = c.sub ? s.subBg : s.headBg;
        const copyBtn = c.skipCopy
          ? ''
          : `<button data-isp-col="${i}" title="この列を全行コピー(改行区切り)" style="font-size:11px; padding:2px 6px;">📋</button>`;
        const tip = c.key === 'kashitsu'
          ? ' title="入居者負担の過失分にチェック → 5%諸経費を末尾に自動追加(HC/ECは対象外)"'
          : '';
        return `
        <th${tip} style="padding:6px 8px; background:${headBg}; color:${s.headFg}; border:1px solid ${s.border}; text-align:${c.align}; width:${c.width}; font-size:12px;">
          <div style="display:flex; align-items:center; justify-content:space-between; gap:6px;">
            <span>${c.label}</span>
            ${copyBtn}
          </div>
        </th>`;
      }).join('')}
    </tr>`;

  // 本体
  if (!lines.length) {
    tbody.innerHTML = `<tr><td colspan="${COLS.length}" style="padding:12px; color:var(--muted);">対象行がありません。</td></tr>`;
    if (tfoot) tfoot.innerHTML = '';
  } else {
    tbody.innerHTML = lines.map((l,rowIdx) => {
      // 元の est.lines 内インデックス(synthetic 行は -1)
      const origIdx = l._isp_synthetic ? -1 : (est.lines || []).indexOf(l);
      const tds = COLS.map(c => {
        const s = GROUP_STYLE[c.group];
        const bg = c.sub ? s.subBg : (s.cellBg || '');
        const fontWeight = c.sub ? '600' : '400';
        // 過失チェックボックス列(特殊)
        if (c.special === 'checkbox') {
          // synthetic 行はチェックボックス非表示
          if (l._isp_synthetic) {
            return `<td style="padding:5px 8px; border:1px solid ${s.border}; text-align:center; background:${bg}; color:#9ca3af;">—</td>`;
          }
          // 入居者負担 かつ HC/EC でない行のみ操作可、それ以外は無効化
          const eligible = (effectiveBurdenType(l) === '入居者') && !isHcEc(l);
          const checked = isKashitsu(l) ? 'checked' : '';
          if (eligible) {
            return `<td style="padding:5px 4px; border:1px solid ${s.border}; text-align:center; background:${bg};"><input type="checkbox" data-kashitsu-orig="${origIdx}" ${checked}></td>`;
          }
          return `<td style="padding:5px 8px; border:1px solid ${s.border}; text-align:center; background:${bg}; color:#9ca3af;" title="過失諸経費の対象外(入居者負担以外 or HC/EC)">—</td>`;
        }
        // 負担区分セレクト(特殊)
        if (c.special === 'burden') {
          if (l._isp_synthetic) {
            const bt = effectiveBurdenType(l);
            return `<td style="padding:5px 6px; border:1px solid ${s.border}; text-align:center; background:${bg}; color:#6b7280; font-size:11px;">${bt}</td>`;
          }
          const bt = effectiveBurdenType(l);
          const opts = ['家主','入居者','自社のみ'].map(o =>
            `<option value="${o}" ${o===bt?'selected':''}>${o==='家主'?'👤家主':o==='入居者'?'🏠入居者':'🏢自社のみ'}</option>`
          ).join('');
          return `<td style="padding:2px 4px; border:1px solid ${s.border}; text-align:center; background:${bg};"><select data-burden-orig="${origIdx}" style="width:100%; font-size:11px; padding:1px;">${opts}</select></td>`;
        }
        // 編集可能な小計セル(yanushi/tenant 上書き)
        if (c.editable && !l._isp_synthetic) {
          const v = c.get(l);
          // 自身の負担区分外なら表示のみ・編集不可
          const targetBt = c.editable === 'yanushiAmt' ? '家主' : '入居者';
          const isActive = effectiveBurdenType(l) === targetBt;
          if (!isActive) {
            return `<td style="padding:5px 8px; border:1px solid ${s.border}; text-align:${c.align}; font-size:12px; background:${bg}; color:#9ca3af;">—</td>`;
          }
          const stored = l[c.editable];
          const hasOverride = stored !== undefined && stored !== null && stored !== '';
          const placeholder = hasOverride ? '' : `${fmtNum(v)} (自動)`;
          const valAttr = hasOverride ? `value="${fmtNum(stored)}"` : '';
          const titleAttr = hasOverride ? '上書き中(空にすると自動計算に戻ります)' : '空欄=自動計算 / 数値で上書き';
          const overStyle = hasOverride ? 'font-weight:700; color:#7c2d12;' : '';
          return `<td style="padding:2px 4px; border:1px solid ${s.border}; text-align:${c.align}; font-size:12px; font-weight:${fontWeight}; background:${bg};">
            <input type="text" inputmode="decimal" data-isp-edit="${c.editable}" data-isp-edit-orig="${origIdx}" ${valAttr} placeholder="${placeholder}" title="${titleAttr}" style="width:100%; text-align:right; background:transparent; border:1px solid transparent; padding:2px; ${overStyle}">
          </td>`;
        }
        const v = c.get(l);
        const disp = c.num ? fmtNum(v) : (v == null ? '' : String(v));
        // synthetic 行の name セルには算出式を小さく追記表示(コピペには含まれない c.get の値だけ)
        if (c.key === 'name' && l._isp_synthetic && l._isp_formula) {
          return `<td style="padding:5px 8px; border:1px solid ${s.border}; text-align:${c.align}; font-size:12px; font-weight:${fontWeight}; background:${bg}; white-space:normal;">
            <div>${escapeHtml(disp)}</div>
            <div style="margin-top:2px; font-size:10px; font-style:italic; color:#6b7280; font-weight:400;">📐 ${escapeHtml(l._isp_formula)}</div>
          </td>`;
        }
        return `<td style="padding:5px 8px; border:1px solid ${s.border}; text-align:${c.align}; font-size:12px; font-weight:${fontWeight}; background:${bg}; white-space:${c.key==='name'?'normal':'nowrap'};">${escapeHtml(disp)}</td>`;
      }).join('');
      const isSyn = l._isp_synthetic ? ' style="font-style:italic;"' : '';
      return `<tr data-isp-row="${rowIdx}"${isSyn}>${tds}</tr>`;
    }).join('');
  }

  // 過失チェックボックスのハンドラ
  tbody.querySelectorAll('input[type="checkbox"][data-kashitsu-orig]').forEach(chk => {
    chk.addEventListener('change', () => {
      const orig = Number(chk.dataset.kashitsuOrig);
      if (orig < 0 || !est.lines || !est.lines[orig]) return;
      est.lines[orig].kashitsu = chk.checked;
      saveEstimate();
      renderIsp();   // 諸経費行を再計算
    });
  });
  // 負担区分セレクトのハンドラ
  tbody.querySelectorAll('select[data-burden-orig]').forEach(sel => {
    sel.addEventListener('change', () => {
      const orig = Number(sel.dataset.burdenOrig);
      if (orig < 0 || !est.lines || !est.lines[orig]) return;
      est.lines[orig].burdenType = sel.value;
      saveEstimate();
      renderIsp();
    });
  });
  // 家主小計 / 入居者小計 上書き入力(yanushiAmt / tenantAmt)
  tbody.querySelectorAll('input[data-isp-edit]').forEach(inp => {
    const commit = () => {
      const orig = Number(inp.dataset.ispEditOrig);
      const field = inp.dataset.ispEdit;
      if (orig < 0 || !est.lines || !est.lines[orig]) return;
      const raw = (inp.value || '').replace(/,/g,'').trim();
      if (raw === '') {
        est.lines[orig][field] = null;  // 空欄 → 自動計算へ戻す
      } else {
        const n = Number(raw);
        if (!Number.isNaN(n)) est.lines[orig][field] = n;
      }
      saveEstimate();
      renderIsp();
    };
    inp.addEventListener('change', commit);
    inp.addEventListener('blur', commit);
  });

  // コピー処理(列単位)
  thead.querySelectorAll('button[data-isp-col]').forEach(btn => {
    btn.addEventListener('click', () => {
      const idx = Number(btn.dataset.ispCol);
      const c = COLS[idx];
      const text = lines.map(l => {
        const v = c.get(l);
        // 数値はカンマ無しの素の数字でコピー(元請けシステム貼り付け前提)
        return c.num ? String(v) : (v == null ? '' : String(v));
      }).join('\n');
      copyToClipboard(text, `${c.label} を ${lines.length} 行コピーしました`);
    });
  });

  // 全列TSVコピー
  const btnAll = document.getElementById('btn-isp-copy-all');
  if (btnAll) {
    btnAll.onclick = () => {
      const header = COLS.map(c => c.label).join('\t');
      const body = lines.map(l => COLS.map(c => {
        const v = c.get(l);
        const s = c.num ? String(v) : (v == null ? '' : String(v));
        // タブ・改行をスペースに正規化(TSV破壊防止)
        return s.replace(/[\t\r\n]+/g, ' ');
      }).join('\t')).join('\n');
      copyToClipboard(header + '\n' + body, `表全体(${lines.length}行)をTSVでコピーしました`);
    };
  }

  /* ----- 合計行 + 見積タブとの一致判定 ----- */
  // ISP集計値(小計列を合算)
  const colJishaSub = COLS.find(c => c.key === 'jishaSub');
  const colYanushi  = COLS.find(c => c.key === 'yanushi');
  const colTenant   = COLS.find(c => c.key === 'tenant');
  const ispJishaTotal   = lines.reduce((s,l) => s + (colJishaSub.get(l) || 0), 0);
  const ispYanushiTotal = lines.reduce((s,l) => s + (colYanushi.get(l)  || 0), 0);
  const ispTenantTotal  = lines.reduce((s,l) => s + (colTenant.get(l)   || 0), 0);

  // 見積タブ側の合計値(同じロジックで再計算)
  const estLines = (est.lines || []).filter(l => l.item && !l.reduced);
  const estJisha = estLines.reduce((s,l) => s + lineAmount(l, 'estimate'), 0);
  const estYanushiBase = estLines
    .filter(l => effectiveBurdenType(l) === '家主')
    .reduce((s,l) => s + effectiveYanushiAmt(l, rule), 0);
  const estShoKeihiRate = (rule.autoShoKeihiRate && rule.autoShoKeihiRate > 0) ? rule.autoShoKeihiRate : 0.05;
  const estShoKeihi = Math.round(estJisha * estShoKeihiRate);
  const estYanushiTotal = estYanushiBase + estShoKeihi;
  const estTenantBase = estLines
    .filter(l => effectiveBurdenType(l) === '入居者')
    .reduce((s,l) => s + effectiveTenantAmt(l), 0);
  // ISPタブで追加される過失諸経費(5%)も比較側に加算 → 一致判定が成立する
  const estTenantTotal = estTenantBase + kashitsuShoKeihi;

  // tfoot 合計行(列順: 名称/数量/単位/見積単価/見積小計/家主単価/家主小計/入居者単価/入居者小計)
  if (tfoot) {
    const sJ = GROUP_STYLE.jisha, sY = GROUP_STYLE.yanushi, sT = GROUP_STYLE.tenant, sI = GROUP_STYLE.info;
    const cell = (s, bg, txt, mute) =>
      `<td style="padding:6px 8px; border:1px solid ${s.border}; text-align:right; font-size:12px; font-weight:700; background:${bg}; color:${mute?'#9ca3af':s.headFg};">${txt}</td>`;
    tfoot.innerHTML = `
      <tr>
        <td colspan="5" style="padding:6px 8px; border:1px solid ${sI.border}; background:#f8fafc; text-align:right; font-size:12px; font-weight:700;">合計 (税抜)</td>
        ${cell(sJ, sJ.cellBg, '—', true)}
        ${cell(sJ, sJ.subBg, fmtNum(ispJishaTotal))}
        ${cell(sY, sY.cellBg, '—', true)}
        ${cell(sY, sY.subBg, fmtNum(ispYanushiTotal))}
        ${cell(sT, sT.cellBg, '—', true)}
        ${cell(sT, sT.subBg, fmtNum(ispTenantTotal))}
      </tr>`;
  }

  // 一致判定
  const checks = [
    { label: '🏢 自社見積',   isp: ispJishaTotal,   est: estJisha },
    { label: '👤 家主見積',   isp: ispYanushiTotal, est: estYanushiTotal },
    { label: '🏠 入居者見積', isp: ispTenantTotal,  est: estTenantTotal }
  ];
  if (sumEl) {
    const rows = checks.map(c => {
      const diff = c.isp - c.est;
      const ok = diff === 0;
      const badge = ok
        ? `<span style="color:#065f46; font-weight:600;">✅ 一致</span>`
        : `<span style="color:#991b1b; font-weight:600;">⚠ 差額 ${diff>0?'+':''}${diff.toLocaleString()}円</span>`;
      return `
        <div style="display:flex; gap:12px; align-items:center; padding:4px 0; border-bottom:1px dashed #cbd5e1;">
          <span style="min-width:110px;">${c.label}</span>
          <span style="min-width:140px;">ISP合計: <b>${fmtNum(c.isp)}</b> 円</span>
          <span style="min-width:140px;">見積タブ: <b>${fmtNum(c.est)}</b> 円</span>
          <span>${badge}</span>
        </div>`;
    }).join('');
    sumEl.innerHTML = `
      <div style="display:flex; gap:10px; align-items:center; margin-bottom:6px;">
        <span style="font-weight:600; color:#1e3a8a;">📊 ISP合計 vs 見積タブ 一致判定</span>
        <span style="font-size:11px; padding:2px 8px; background:#fde68a; color:#92400e; border-radius:10px; font-weight:600;">税抜</span>
      </div>
      ${rows}`;
  }
}

// 印刷時: 見積テーブル内の input/select を値テキストに置換 → 列幅が値の長さに合わせて auto-fit
function applyEstimatePrintTextSwap() {
  const tbody = document.getElementById('estimate-tbody');
  if (!tbody) return;
  // 既存のもの削除(再印刷時の重複防止)
  tbody.querySelectorAll('.print-text').forEach(s => s.remove());
  tbody.querySelectorAll('td.has-print-text').forEach(td => td.classList.remove('has-print-text'));
  tbody.querySelectorAll('tr.empty-line-print-hide').forEach(tr => tr.classList.remove('empty-line-print-hide'));
  // 項目名(item)が空の行は印刷時に非表示
  tbody.querySelectorAll('tr[data-i]').forEach(tr => {
    const idx = Number(tr.dataset.i);
    const l = state.estimate?.lines?.[idx];
    if (!l || !l.item) tr.classList.add('empty-line-print-hide');
  });
  // 印刷時に隠れない可視列の数を実測 → section-row / subtotal-row / shogeihi-row の colspan を再設定
  const sampleTr = Array.from(tbody.querySelectorAll('tr[data-i]')).find(tr => !tr.classList.contains('empty-line-print-hide'));
  let visibleCols = 0;
  if (sampleTr) {
    sampleTr.querySelectorAll('td').forEach(td => {
      if (!td.classList.contains('no-print') && !td.classList.contains('edit-only')) visibleCols++;
    });
  }
  if (visibleCols > 0) {
    tbody.querySelectorAll('tr.section-row, tr.subtotal-row, tr.shogeihi-row').forEach(tr => {
      tr.querySelectorAll('td[colspan]').forEach((td, i) => {
        td.setAttribute('data-orig-colspan', td.getAttribute('colspan'));
        if (tr.classList.contains('section-row')) {
          td.setAttribute('colspan', visibleCols);
        } else {
          // subtotal/shogeihi: 1番目の td=ラベル(visibleCols-1)、2番目の td=金額(colspan=1)
          if (i === 0) td.setAttribute('colspan', Math.max(1, visibleCols - 1));
        }
      });
    });
  }
  // セルごとに代表値を集約して TD に span 1つ挿入(複数 input がある場合は値を空白連結)
  tbody.querySelectorAll('tr[data-i] > td').forEach(td => {
    // .no-print/.edit-only セルは印刷外なのでスキップ
    if (td.classList.contains('no-print') || td.classList.contains('edit-only')) return;
    const inputs = td.querySelectorAll('input[type="text"], select');
    if (!inputs.length) return;
    const values = [];
    inputs.forEach(el => {
      let val = '';
      if (el.tagName === 'SELECT') {
        // value が空(プレースホルダー) → 表示しない
        val = el.value || '';
      } else {
        val = el.value || '';
      }
      if (val) values.push(val);
    });
    const span = document.createElement('span');
    span.className = 'print-text';
    span.textContent = values.join(' ');
    td.appendChild(span);
    td.classList.add('has-print-text');
  });
}
function clearEstimatePrintTextSwap() {
  const tbody = document.getElementById('estimate-tbody');
  if (!tbody) return;
  tbody.querySelectorAll('.print-text').forEach(s => s.remove());
  tbody.querySelectorAll('td.has-print-text').forEach(td => td.classList.remove('has-print-text'));
  tbody.querySelectorAll('tr.empty-line-print-hide').forEach(tr => tr.classList.remove('empty-line-print-hide'));
  // colspan を元に戻す
  tbody.querySelectorAll('td[data-orig-colspan]').forEach(td => {
    td.setAttribute('colspan', td.getAttribute('data-orig-colspan'));
    td.removeAttribute('data-orig-colspan');
  });
}
window.addEventListener('beforeprint', applyEstimatePrintTextSwap);
window.addEventListener('afterprint', clearEstimatePrintTextSwap);

function copyToClipboard(text, okMsg) {
  if (navigator.clipboard && window.isSecureContext) {
    navigator.clipboard.writeText(text).then(() => {
      if (okMsg) alert(okMsg);
    }, () => fallbackCopy(text, okMsg));
  } else {
    fallbackCopy(text, okMsg);
  }
}
function fallbackCopy(text, okMsg) {
  const ta = document.createElement('textarea');
  ta.value = text;
  ta.style.position = 'fixed';
  ta.style.left = '-9999px';
  document.body.appendChild(ta);
  ta.select();
  try { document.execCommand('copy'); if (okMsg) alert(okMsg); }
  catch (e) { alert('コピーに失敗しました'); }
  document.body.removeChild(ta);
}

