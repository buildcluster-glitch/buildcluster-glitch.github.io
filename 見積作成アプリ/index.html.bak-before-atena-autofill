// 物件情報ヘッダーを自動引込(見積・現場情報から、空欄のみ補完)
function autoFillHatchuHeader() {
  const ho = getHatchuOrder();
  if (!state.estimate) return;
  const meta = state.estimate.meta;
  const taikyo = meta.taikyo || {};
  if (!ho.projectTitle) ho.projectTitle = `${meta.bukken||''} ${meta.roomNo||''}号室原状回復工事`.trim();
  if (!ho.apName) ho.apName = meta.bukken || '';
  if (!ho.roomNo) ho.roomNo = meta.roomNo || '';
  if (!ho.address) ho.address = meta.shozaichi || taikyo.address || '';
  if (!ho.madori) ho.madori = taikyo.madori || '';
  // 担当者: 立会・見積担当者(ビルドクラスタ側)優先、無ければ営業担当者(元請け側)
  if (!ho.tantou) ho.tantou = taikyo.tachiaiPerson || taikyo.eigyoTantou || '';
  if (!ho.tantouTel) ho.tantouTel = taikyo.tachiaiPersonTel || taikyo.eigyoTel || '';
  if (!ho.taikyoMonth && taikyo.taikyoDate) {
    const m = taikyo.taikyoDate.match(/^(\d{4})-(\d{2})/);
    if (m) { const y = Number(m[1]) - 2018; ho.taikyoMonth = `令和${y}年${Number(m[2])}月`; }
  }
  // 元請会社: 見積書単価列(state.settings.priceCol)から引く(手編集で上書き可)
  if (!ho.kanriNo) ho.kanriNo = state.settings.priceCol || meta.motouke || '';
  if (!ho.issueDate) ho.issueDate = formatJpDate(formatToday());
  saveEstimate();
}

// 見積行を「業者→室名→項目番号」でソート(見積タブと連動)
function sortLinesForHatchu() {
  const itemOrder = new Map();
  state.master.forEach((m, i) => itemOrder.set(m.項目, Number(m.項目番号) || i));
  state.estimate.lines.sort((a, b) => {
    // 空行は末尾
    const ea = !a.item && !a.supplier;
    const eb = !b.item && !b.supplier;
    if (ea !== eb) return ea ? 1 : -1;
    // 未割当は 割当済みの後に
    const wa = a.supplier || 'zzz';
    const wb = b.supplier || 'zzz';
    if (wa !== wb) return wa.localeCompare(wb, 'ja');
    const ra = a.room || '', rb = b.room || '';
    if (ra !== rb) return ra.localeCompare(rb, 'ja');
    return (itemOrder.get(a.item) || 99999) - (itemOrder.get(b.item) || 99999);
  });
  saveEstimate();
}

