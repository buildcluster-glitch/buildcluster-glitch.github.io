  const p = parseNaisoSpecs(current);
  const partOpts = NAISO_PART_OPTS.map(o => `<option value="${o}"${o===p.part?' selected':''}>${o}</option>`).join('');
  const reasonOpts = NAISO_REASON_OPTS.map(o => `<option value="${o}"${o===p.reason?' selected':''}>${o}</option>`).join('');
  return `<div style="display:grid; grid-template-columns: 90px 115px 1fr; gap:2px; align-items:center;">
    <select data-f="specsPart" title="施工面" style="font-size:11px;">
