// "M/D" → 今年 or 来年のDate
function mdToDate(md) {
  const p = parseMonthDay(md);
  if (!p.m || !p.d) return null;
  const today = new Date();
  let year = today.getFullYear();
  const mdKey = Number(p.m)*100 + Number(p.d);
  const curKey = (today.getMonth()+1)*100 + today.getDate();
  if (mdKey < curKey - 30) year += 1;
  return new Date(year, Number(p.m)-1, Number(p.d));
}

// 自動データ埋込み
function autoFillKoutei() {
  const k = getKoutei();
  if (!k) return;
  const est = state.estimate;
  const meta = est.meta || {};
  const t = meta.taikyo || {};
  const issuer = currentIssuer();
  const { start, end } = getOverallPeriod();
  if (!k.projectTitle) k.projectTitle = meta.roomNo ? `${meta.roomNo}号室` : (meta.bukken || '');
  if (!k.address) k.address = meta.shozaichi || t.address || '';
  if (!k.startDate && start) k.startDate = formatJpFromMD(start);
  if (!k.endDate && end) k.endDate = formatJpFromMD(end);
  if (!k.parking) k.parking = t.parking || '';
  if (!k.keyLocation) {
    // 発注書の「玄関鍵」(hatchuOrder.genkanKagi) を優先、無ければ物件マスタのキーボックス/デジキー
    const ho = meta.hatchuOrder || {};
    if (ho.genkanKagi) {
      k.keyLocation = ho.genkanKagi;
    } else {
      const bukken = state.bukken.find(b => b.name === meta.bukken);
      if (bukken) {
        if (bukken.keyBox) k.keyLocation = `キーボックス: ${bukken.keyBox}`;
        else if (bukken.digiKey && bukken.digiKey !== 'ー') k.keyLocation = `デジキー: ${bukken.digiKey}`;
      }
    }
  }
  {
    const raw = state.settings.priceCol || meta.motouke || '';
    if (!k.shishu || DEFAULT_MOTO_COLS.includes(k.shishu) || (state.settings.customMotouke||[]).includes(k.shishu)) {
      k.shishu = normalizeKanriCompany(raw);
    }
  }
  if (!k.shikou) k.shikou = '(株)ビルドクラスタ';
  if (!k.sekininsha) k.sekininsha = t.tachiaiPerson || issuer.tantou || '';
  if (!k.sekininTel) k.sekininTel = t.tachiaiPersonTel || issuer.tantouTel || '';
  saveEstimate();
}

// ガントチャート生成: カテゴリ別工期を HTML テーブルにする
function buildKouteiGantt() {
  const periods = getCategoryPeriods();
  // カテゴリを開始日順にソート
  const key = (md) => {
    const p = parseMonthDay(md);
    if (!p.m || !p.d) return 9999;
    return Number(p.m)*100 + Number(p.d);
  };
  const cats = Object.entries(periods).sort((a,b) => key(a[1].start) - key(b[1].start));
  if (!cats.length) return { html: '<div style="color:#999; padding:10px;">(発注書工期データなし)</div>', dates: [] };

  // 日付範囲: 最早-2日 〜 最遅+2日
  let minDate = null, maxDate = null;
  cats.forEach(([, p]) => {
    const s = mdToDate(p.start);
    const e = mdToDate(p.end);
    if (s && (!minDate || s < minDate)) minDate = s;
    if (e && (!maxDate || e > maxDate)) maxDate = e;
  });
  if (!minDate || !maxDate) return { html: '<div style="color:#999; padding:10px;">(工期不明)</div>', dates: [] };
  minDate = new Date(minDate); minDate.setDate(minDate.getDate() - 2);
  maxDate = new Date(maxDate); maxDate.setDate(maxDate.getDate() + 2);
  // 最低30日は確保(短い工期でも余裕を見せる)
  const MIN_DAYS = 30;
  const msPerDay = 86400000;
  const curSpan = Math.floor((maxDate - minDate) / msPerDay) + 1;
  if (curSpan < MIN_DAYS) {
    const add = MIN_DAYS - curSpan;
    maxDate = new Date(maxDate);
    maxDate.setDate(maxDate.getDate() + add);
  }

  // 日付リスト生成
  const dates = [];
  const cur = new Date(minDate);
  while (cur <= maxDate) {
    dates.push(new Date(cur));
    cur.setDate(cur.getDate() + 1);
  }
  const DOW = ['日','月','火','水','木','金','土'];

  // 月ヘッダー(月が変わるところで区切る)を col で表示
  const monthHeaders = [];
  let curMonth = -1;
  dates.forEach((d) => {
    if (d.getMonth() !== curMonth) {
      monthHeaders.push({ month: d.getMonth()+1, count: 1 });
      curMonth = d.getMonth();
    } else {
      monthHeaders[monthHeaders.length-1].count++;
    }
  });

  // 休日判定: 土・日・祝日
  const isRest = d => d.getDay() === 0 || d.getDay() === 6 || !!isJpHoliday(d);

  // HTML構築
  const monthHeaderHtml = `<tr><th rowspan="3" class="kt-rowlabel kt-diagonal"><span class="a">日付</span><span class="b">工事種別</span></th>${monthHeaders.map(mh => `<th colspan="${mh.count}">${mh.month}月</th>`).join('')}</tr>`;
  const dayHeaderHtml = `<tr>${dates.map(d => {
    return `<th class="${isRest(d)?'sunday':''}">${d.getDate()}</th>`;
  }).join('')}</tr>`;
  const dowHeaderHtml = `<tr>${dates.map(d => {
    const dow = DOW[d.getDay()];
    return `<th class="${isRest(d)?'sunday':''}">${dow}</th>`;
  }).join('')}</tr>`;
  // カテゴリ行
  const rowsHtml = cats.map(([cat, p]) => {
    const sDate = mdToDate(p.start);
    const eDate = mdToDate(p.end) || sDate;
    const cells = dates.map(d => {
      const inRange = sDate && eDate && d >= sDate && d <= eDate;
      let cls = 'kt-work-cell';
      if (inRange) cls += ' work';
      else if (isRest(d)) cls += ' sunday';
      return `<td class="${cls}">&nbsp;</td>`;
    }).join('');
    return `<tr><th class="kt-rowlabel">${escapeHtml(cat)}</th>${cells}</tr>`;
  }).join('');
  // 空行を数行追加
  const emptyRows = Array.from({length:Math.max(0, 8 - cats.length)}, () =>
    `<tr><th class="kt-rowlabel"></th>${dates.map(d => {
      return `<td class="kt-work-cell ${isRest(d)?'sunday':''}">&nbsp;</td>`;
    }).join('')}</tr>`
  ).join('');

  const html = `
    <table class="koutei-gantt">
      <thead>
        ${monthHeaderHtml}
        ${dayHeaderHtml}
        ${dowHeaderHtml}
      </thead>
      <tbody>
        ${rowsHtml}
        ${emptyRows}
      </tbody>
    </table>`;
  return { html, dates };
}

function renderKoutei() {
  if (!state.estimate) return;
  autoFillKoutei();
  const k = getKoutei();
  document.querySelectorAll('#tab-koutei [data-ktei]').forEach(inp => {
    if (document.activeElement !== inp) inp.value = k[inp.dataset.ktei] || '';
