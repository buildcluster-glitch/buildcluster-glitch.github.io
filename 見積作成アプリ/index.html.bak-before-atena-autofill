// 物件マスタ(state.bukken)から 現場名 にマッチする物件を引いて、宛名(atena)・所在地を自動セット
// force=true なら既存値を上書きしてリフレッシュ
function autoFillFromBukken(bukkenName, force) {
  if (!bukkenName) return false;
  if (!Array.isArray(state.bukken)) return false;
  const meta = state.estimate?.meta;
  if (!meta) return false;
  // 検索順:
  // 1. 完全一致
  // 2. ユーザー入力が マスタ名 を含む (例: "AIハイツ 101" → "AIハイツ" に一致)
  // 3. マスタ名 が ユーザー入力 を含む (例: "AIハイ" → "AIハイツ")
  const trimmed = bukkenName.trim();
  let rec = state.bukken.find(b => b && b.name === trimmed);
  if (!rec) {
    // 入力が マスタ名 を含む(最長一致)
    rec = state.bukken
      .filter(b => b && b.name && trimmed.includes(b.name))
      .sort((a, b) => b.name.length - a.name.length)[0];
  }
  if (!rec) {
    // マスタ名 が 入力 を含む
    rec = state.bukken.find(b => b && b.name && b.name.includes(trimmed));
  }
  if (!rec) return false;
  let touched = 0;
  // 宛名(法人名): atena が空 / 自動引用済 / force のいずれかで上書き
  const fullMotouke = rec.motouke ? normalizeKanriCompany(rec.motouke) : '';
  if (fullMotouke && (force || !meta.atena || meta.atenaAutoFilled)) {
    if (meta.atena !== fullMotouke) {
      meta.atena = fullMotouke;
      const inp = document.getElementById('meta-atena');
      if (inp) inp.value = fullMotouke;
      touched++;
    }
    meta.atenaAutoFilled = true;
  }
  // 所在地: shozaichi が空のみ自動セット
  if (rec.address && (force || !meta.shozaichi)) {
    if (meta.shozaichi !== rec.address) {
      meta.shozaichi = rec.address;
      const inp = document.getElementById('meta-shozaichi');
      if (inp) inp.value = rec.address;
      touched++;
    }
  }
  return touched > 0;
}

