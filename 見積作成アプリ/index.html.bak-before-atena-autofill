function kingenFromPriceCol(col) {
  if (['山一地所','山一Dクレ','山一VIP','JSB','フリューゲル','丸山不動産'].includes(col)) return '山一地所';
  if (col === 'みどり不動産') return 'みどり不動産';
  if (col === 'ワールドレジデンシャル') return 'ワールドアイシティ';
  return '山一地所'; // デフォルト
}

// マスタ行 → 対応テンプレ検索
function findFlooringTemplate(itemName, priceCol) {
  if (!itemName) return null;
  const kingen = kingenFromPriceCol(priceCol || state.settings.priceCol);
  for (const p of FLOORING_TMPL_PATTERNS) {
    if (p.match.test(itemName)) {
      const key = `${kingen}_${p.tmpl}`;
      const tmpl = (window.TEMPLATES || []).find(t => t.key === key);
      if (tmpl) return tmpl;
    }
  }
  return null;
}

// テンプレを指定位置に展開(共通関数)
function expandTemplateAt(tmpl, insertAfter) {
  const newLines = tmpl.rows.map(r => ({
    category: 'フローリング工事',
    item: r.item,
    room: '',
    specs: `【${tmpl.name}】`,
    unit: r.unit,
    qty: r.qty,
    unitPrice: r.unitPrice,
    amountOverride: null,
    burdenType: '家主',
    supplier: 'クマガイハウス工業',
    orderPrice: r.origPrice || 0,
    orderAmountOverride: null,
    note: `元請:${tmpl.元請け}`,
    itemRef: null,
  }));
  let insertAt = (insertAfter != null) ? insertAfter + 1 : state.estimate.lines.length;
  newLines.forEach((nl, i) => {
    const idx = insertAt + i;
    if (idx < state.estimate.lines.length && !state.estimate.lines[idx].item && !state.estimate.lines[idx].unitPrice) {
      state.estimate.lines[idx] = nl;
    } else if (idx >= state.estimate.lines.length) {
      state.estimate.lines.push(nl);
    } else {
      state.estimate.lines.splice(idx, 0, nl);
    }
  });
}

