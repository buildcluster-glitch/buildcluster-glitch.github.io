function refreshTaikyoBukkenDatalist() {
  const dl = document.getElementById('taikyo-bukken-datalist');
  if (!dl) return;
  const motoSel = document.getElementById('taikyo-bukken-moto');
  const wardSel = document.getElementById('taikyo-bukken-ward');
  const moto = motoSel?.value || '';
  const ward = wardSel?.value || '';
  // エリア(区)セレクタの選択肢も最新化(元請け絞込を反映)
  if (wardSel) {
    const baseList = state.bukken.filter(b => !moto || b.motouke === moto);
    const wardSet = sortWards([...new Set(baseList.map(extractWard).filter(Boolean))]);
    const cur = wardSel.value;
    wardSel.innerHTML = '<option value="">(全エリア)</option>'
      + wardSet.map(w => `<option value="${escapeHtml(w)}">${escapeHtml(w)}</option>`).join('')
      + '<option value="__none__">(区なし)</option>';
    wardSel.value = wardSet.includes(cur) || cur === '__none__' || cur === '' ? cur : '';
  }
  const filtered = state.bukken
    .filter(b => !moto || b.motouke === moto)
    .filter(b => {
      if (!ward) return true;
      const w = extractWard(b);
      if (ward === '__none__') return !w;
      return w === ward;
    })
    .slice()
    .sort((a, b) => (a.name || '').localeCompare(b.name || '', 'ja'));
  dl.innerHTML = filtered.map(b => {
    const w = extractWard(b);
    return `<option value="${escapeHtml(b.name)}">${escapeHtml(b.motouke||'')}${w?' / '+escapeHtml(w):''} / ${escapeHtml(b.address||'')}</option>`;
  }).join('');
}

