// 住所から 区 を抽出(例: "仙台市青葉区北山..." → "青葉区"、無ければ空)
// エリア並び順: 仙台市の区を最優先 → その他の区 → 市 → 郡
const SENDAI_KU_ORDER = ['青葉区','宮城野区','若林区','太白区','泉区'];
function wardSortKey(w) {
  if (!w) return 'zzz';
  const i = SENDAI_KU_ORDER.indexOf(w);
  if (i >= 0) return `1_${String(i).padStart(2,'0')}`;
  if (/区$/.test(w)) return `2_${w}`;
  if (/市$/.test(w)) return `3_${w}`;
  if (/郡$/.test(w)) return `4_${w}`;
  return `9_${w}`;
}
function sortWards(arr) {
  return arr.slice().sort((a, b) => {
    const ka = wardSortKey(a), kb = wardSortKey(b);
    if (ka !== kb) return ka.localeCompare(kb);
    return a.localeCompare(b, 'ja');
  });
}

// 住所からエリア(区・市・郡)を抽出
// 優先: 区(仙台市内)→ 市(仙台市以外)→ 郡
function extractWard(b) {
  const addr = (b.address || '') + ' ' + (b.city || '');
  // 1. 区(仙台市青葉区・宮城野区等) が最優先
  const kuMatch = addr.match(/[一-龥々ヵ]+区/);
  if (kuMatch) return kuMatch[0];
  // 2. 市(富谷市・名取市等、仙台市は除外 ※仙台は区で拾う)
  const shiMatches = [...addr.matchAll(/([一-龥々ヵ]+市)/g)].map(m => m[1]).filter(x => x !== '仙台市');
  if (shiMatches.length) return shiMatches[0];
  // 3. 郡(黒川郡等)
  const gunMatch = addr.match(/[一-龥々ヵ]+郡/);
  if (gunMatch) return gunMatch[0];
  return '';
}

