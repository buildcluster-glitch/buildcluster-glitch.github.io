// マスタクリーンアップ
const WASTE_NAMES = new Set(['混合廃棄物','廃プラスチック類','廃プラ','がれき類','金属くず','木くず','紙くず']);
const ROOM_NAMES = new Set(['全室','各室','玄関','台所','洋室','和室','トイレ','洗面所','浴室','ロフト','クローゼット','押入','バルコニー','玄関土間','台所~洋室','台所～洋室','各部屋']);

function cleanupMaster(dryRun) {
  const fixes = [];
  state.master.forEach(r => {
    const issues = [];
    // 1) 室名に産廃品目名
    if (WASTE_NAMES.has(r.室名)) {
      issues.push(`室名="${r.室名}" → 産廃品目に移動`);
      if (!r.産廃品目) r.産廃品目 = r.室名;
      r.室名 = '';
    }
    // 2) 室名が数値
    if (r.室名 != null && r.室名 !== '' && !isNaN(Number(r.室名))) {
      const n = Number(r.室名);
      issues.push(`室名="${r.室名}"(数値) → 空`);
      if (n < 1 && n > 0 && r.産廃数量 == null) r.産廃数量 = n;
      r.室名 = '';
    }
    // 3) 産廃品目が室名
    if (ROOM_NAMES.has(r.産廃品目)) {
      issues.push(`産廃品目="${r.産廃品目}" → 室名に移動`);
      if (!r.室名) r.室名 = r.産廃品目;
      r.産廃品目 = '';
    }
    // 4) 数量が極小
    if (r.数量 != null && r.数量 !== '' && Number(r.数量) > 0 && Number(r.数量) < 0.01) {
      issues.push(`数量=${r.数量} → 産廃数量、数量=1`);
      if (r.産廃数量 == null) r.産廃数量 = Number(r.数量);
      r.数量 = 1;
    }
    // 5) 備考が産廃品目
    if (WASTE_NAMES.has(r.備考)) {
      issues.push(`備考="${r.備考}" → 産廃品目`);
      if (!r.産廃品目) r.産廃品目 = r.備考;
      r.備考 = '';
    }
    if (issues.length) fixes.push({ id:r.項目番号, cat:r.カテゴリー, item:r.項目, issues });
  });

  // ダイアログ表示
  const summary = fixes.length === 0
    ? '異常は見つかりませんでした。'
    : fixes.slice(0, 30).map(f => `[${f.id}] ${f.item}\n  ${f.issues.join(' / ')}`).join('\n') + (fixes.length > 30 ? `\n\n... 他 ${fixes.length - 30}件` : '');
  if (dryRun) {
    alert(`診断結果: ${fixes.length}件\n\n${summary}`);
    return;
  }
  if (fixes.length === 0) { alert('異常は見つかりませんでした。'); return; }
  if (!confirm(`${fixes.length}件の行を補正しました。保存しますか?\n\n${summary.slice(0, 1000)}`)) {
    // キャンセル → マスタを再読込(状態巻き戻し)
    state.master = loadMaster();
    renderMaster();
    return;
  }
  saveMaster();
  renderCategoryOptions(); renderMaster();
  alert(`${fixes.length}件補正し保存しました`);
}
