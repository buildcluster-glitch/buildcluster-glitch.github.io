// 物件情報サマリー(見積タブ上部・印刷外)
function renderBukkenInfoPanel() {
  const panel = document.getElementById('bukken-info-panel');
  if (!panel) return;
  const meta = state.estimate?.meta;
  if (!meta) { panel.style.display = 'none'; return; }
  // 物件マスタから現場名で検索
  const bkName = (meta.bukken || '').trim();
  let rec = null;
  if (bkName && Array.isArray(state.bukken)) {
    rec = state.bukken.find(b => b && b.name === bkName)
       || state.bukken.filter(b => b && b.name && bkName.includes(b.name)).sort((a,b)=>b.name.length-a.name.length)[0]
       || state.bukken.find(b => b && b.name && b.name.includes(bkName));
  }
  // 元請けルールから「注意」を取得(settings.motoukeRules[元請け].notice 等の予定)
  const motouke = meta.motouke || rec?.motouke || '';
  const motoFull = motouke ? normalizeKanriCompany(motouke) : '';
  const rule = state.settings?.motoukeRules?.[motoFull] || state.settings?.motoukeRules?.[motouke] || {};
  // 注意文言の組立: 元請けルール notice → 諸経費設定 → bukken.memo / taikyo.memo
  const noticeParts = [];
  if (rule.notice) noticeParts.push(rule.notice);
  if (rule.autoShoKeihiRate > 0) noticeParts.push(`原状回復見積に諸経費 ${Math.round(rule.autoShoKeihiRate*100)}% 必要`);
  const taikyo = meta.taikyo || {};
  // 表示要素の更新ヘルパー
  const setSpan = (id, val, prefix) => {
    const el = document.getElementById(id);
    if (!el) return;
    if (val) {
      el.style.display = '';
      const inner = el.querySelector('span');
      if (inner) inner.textContent = val;
      else el.textContent = (prefix || '') + val;
    } else el.style.display = 'none';
  };
  // 注意
  const warnEl = document.getElementById('bk-info-warn');
  if (warnEl) {
    if (noticeParts.length) {
      warnEl.style.display = '';
      warnEl.textContent = '【注意】 ' + noticeParts.join(' / ');
    } else warnEl.style.display = 'none';
  }
  setSpan('bk-info-parking', taikyo.parking || rec?.parking || '');
  setSpan('bk-info-keybox', rec?.keyBox || '');
  setSpan('bk-info-madori', taikyo.madori || rec?.madori || '');
  // メモ(bukken.memo or taikyo.memo or bukken.notes)
  const memo = [rec?.memo, rec?.notes, taikyo.memo].filter(Boolean).join(' / ').trim();
  setSpan('bk-info-memo', memo);
  // パネル全体: 何かしら情報があれば表示、無ければ隠す
  const hasAny = noticeParts.length || taikyo.parking || rec?.parking || rec?.keyBox || rec?.madori || taikyo.madori || memo;
  panel.style.display = hasAny ? 'flex' : 'none';
}

