    t.style.cssText = 'position:fixed; bottom:20px; left:50%; transform:translateX(-50%); background:#111; color:#fff; padding:10px 18px; border-radius:6px; font-size:13px; z-index:10000; box-shadow:0 4px 20px rgba(0,0,0,0.3); transition:opacity 0.2s;';
    document.body.appendChild(t);
  }
  t.textContent = msg;
  t.style.background = isError ? '#b91c1c' : '#111';
  t.style.opacity = '1';
  clearTimeout(t._hideTimer);
  t._hideTimer = setTimeout(() => { t.style.opacity = '0'; }, 2500);
}

