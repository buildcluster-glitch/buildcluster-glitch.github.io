// 日付 YYYY-MM-DD or YYYY/MM/DD を Date に
function parseYmd(s) {
  if (!s) return null;
  const m = String(s).match(/^(\d{4})[-\/.](\d{1,2})[-\/.](\d{1,2})$/);
  if (!m) return null;
  const d = new Date(Number(m[1]), Number(m[2])-1, Number(m[3]));
  return isNaN(d) ? null : d;
}
// 差分 年/月
function diffYearsMonths(startStr, endStr) {
  const s = parseYmd(startStr);
  if (!s) return null;
  const e = parseYmd(endStr) || new Date();
  let years = e.getFullYear() - s.getFullYear();
  let months = e.getMonth() - s.getMonth();
  if (e.getDate() < s.getDate()) months--;
  if (months < 0) { years--; months += 12; }
  if (years < 0) return null;
  return { years, months };
}
// 契約期間を契約開始日と退去日から再計算
function recalcContractPeriod() {
  const est = state.estimate;
  if (!est || !est.meta || !est.meta.taikyo) return;
  const t = est.meta.taikyo;
  const d = diffYearsMonths(t.contractStart, t.taikyoDate);
  if (!d) return;
  t.contractYears = d.years;
  t.contractMonths = d.months;
  // UIに反映
  const y = document.querySelector('[data-taikyo="contractYears"]');
  const m = document.querySelector('[data-taikyo="contractMonths"]');
  if (y) y.value = d.years;
  if (m) m.value = d.months;
}

