// 一時的に state.estimate を書き換えて印刷し、終わったら戻す
function printAsPartialEstimate(kind /* 'yanushi' | 'nyukyosha' */) {
  const orig = state.estimate;
  const snapshot = JSON.parse(JSON.stringify(orig));
  const rule = getMotoukeRule();
  const moto = orig.meta?.motouke || '';
  // 元の自社見積総額(諸経費計算用)
  const jishaTotal = orig.lines.reduce((s,l)=>s+lineAmount(l,'estimate'),0);
  // 対象行を抽出
  let targetLines = [];
  let docTitle = '';
  let newAtena = orig.meta.atena || '';
  let newAtenaTantou = orig.meta.atenaTantou || '';
  if (kind === 'yanushi') {
    targetLines = orig.lines
      .filter(l => effectiveBurdenType(l) === '家主')
      .map(l => {
        // 手入力の 家主金額 を最終金額として使用。無ければ 自社×倍率
        const finalAmt = effectiveYanushiAmt(l, rule);
        // 数量×単価=金額 の関係を保つため、単価=金額/数量 で逆算
        const q = Number(l.qty) || 1;
        return {
          ...l,
          estimatePrice: Math.round(finalAmt / q),
          amountOverride: finalAmt,
        };
      });
    // 産廃諸経費(元請けに自動計上設定があれば、自社見積×rate)
    const shoKeihi = Math.round(jishaTotal * (rule.autoShoKeihiRate || 0));
    if (shoKeihi > 0) {
      targetLines.push({
        category:'その他',
        item:'産廃諸経費',
        room:'',
        specs:`自社見積総額×${Math.round(rule.autoShoKeihiRate*100)}% (${moto}ルール)`,
        qty:1, unit:'式',
        estimatePrice: shoKeihi,
        orderPrice: 0,
        supplier: '',
        burdenType: '家主',
      });
    }
    if (targetLines.length === 0) { showToast('家主負担行がありません', true); return; }
    docTitle = sanitizeFilename(`[${orig.meta.bukken||'(無題)'}] 家主御見積書 ${orig.meta.date||formatToday()}`);
    // 宛先: 見積書上は「家主」等へ
    newAtena = '家主';
    newAtenaTantou = '';
  } else {
    targetLines = orig.lines
      .filter(l => effectiveBurdenType(l) === '入居者')
      .map(l => {
        const finalAmt = effectiveTenantAmt(l);
        const q = Number(l.qty) || 1;
        return {
          ...l,
          estimatePrice: Math.round(finalAmt / q),
          amountOverride: finalAmt,
        };
      });
    if (targetLines.length === 0) { showToast('入居者負担行がありません', true); return; }
    docTitle = sanitizeFilename(`[${orig.meta.bukken||'(無題)'}] 入居者御見積書 ${orig.meta.date||formatToday()}`);
    // 宛先: 現場情報 contractorType / daikoCorp から自動判定
    const t = orig.meta.taikyo || {};
    if (t.contractorType === '法人') {
      if (t.daikoCorp) {
        newAtena = t.daikoCorp;
        const parts = [];
        if (t.corpName) parts.push(`契約法人: ${t.corpName}`);
        if (t.contractNumber) parts.push(`契約番号: ${t.contractNumber}`);
        newAtenaTantou = parts.join(' / ');
      } else {
        newAtena = t.corpName || '';
        newAtenaTantou = t.contractNumber ? `契約番号: ${t.contractNumber}` : '';
      }
    } else {
      newAtena = t.contractorName || '入居者';
      newAtenaTantou = '';
    }
  }
  // 一時書換
  const tmpEstimate = {
    ...orig,
    meta: { ...orig.meta, atena: newAtena, atenaTantou: newAtenaTantou },
    lines: targetLines,
  };
  state.estimate = tmpEstimate;
  // docModeを estimate に強制(発注書モード中でも家主/入居者PDFは見積書として出す)
  const prevDocMode = state.settings.docMode;
  state.settings.docMode = 'estimate';
  renderLines();
  renderPrintMeta();
  renderTotals();
  const prevTitle = document.title;
  document.title = docTitle;
  setTimeout(() => {
    window.print();
    // 復元
    setTimeout(() => {
      state.estimate = orig;
      state.settings.docMode = prevDocMode;
      renderLines();
      renderPrintMeta();
      renderTotals();
      document.title = prevTitle;
    }, 500);
  }, 150);
}

