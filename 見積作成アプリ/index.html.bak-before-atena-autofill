function loadMaster() {
  const stored = localStorage.getItem(STORAGE_KEYS.master);
  let m;
  if (stored) {
    try { m = JSON.parse(stored); } catch(e) {}
  }
  if (!m) m = JSON.parse(JSON.stringify(window.INITIAL_DATA || []));
  // カテゴリーリネーム移行: ハウスクリーニング → 清掃工事 / 項目に "ハウスクリーニング " 接頭辞付与
  // また 旧"清掃"カテゴリも 清掃工事 に統合
  let migrated = 0;
  m.forEach(r => {
    if (r['カテゴリー'] === 'ハウスクリーニング') {
      r['カテゴリー'] = '清掃工事';
      if (r['項目'] && !r['項目'].startsWith('ハウスクリーニング')) {
        r['項目'] = 'ハウスクリーニング ' + r['項目'];
      }
      migrated++;
    } else if (r['カテゴリー'] === '清掃') {
      r['カテゴリー'] = '清掃工事';
      migrated++;
    } else if (r['カテゴリー'] === 'エアコン洗浄') {
      r['カテゴリー'] = '清掃工事';
      migrated++;
    }
    // 列名リネーム: 退去者 → 入居者単価 / オーナー金額 → 家主単価
    if ('退去者' in r) { r['入居者単価'] = r['退去者']; delete r['退去者']; migrated++; }
    if ('オーナー金額' in r) { r['家主単価'] = r['オーナー金額']; delete r['オーナー金額']; }
    // アラート用メモへの上書き(2026-04 リリース)
    const it = r['項目'] || '';
    if (it === 'CF貼替' && r['備考'] && /^経年変色\/.*\/全面$/.test(r['備考'])) {
      r['備考'] = '※ソフト巾木交換も合わせて見積を';
      migrated++;
    } else if (it === 'CF重ね張り' && r['備考'] && /開口補強/.test(r['備考'])) {
      r['備考'] = '※下地調整費も合わせて見積を';
      migrated++;
    } else if (/開口補強工事/.test(it) && (!r['備考'] || r['備考'] === '')) {
      r['備考'] = '※下地調整費も合わせて見積を';
      migrated++;
    }
  });
  // 起動時に自動で列ずれ補正
  const fixed = applyMasterAutoFixes(m);
  if ((fixed > 0 || migrated > 0) && stored) {
    localStorage.setItem(STORAGE_KEYS.master, JSON.stringify(m));
    if (migrated > 0) console.log(`マスタ移行: ${migrated}件(ハウスクリーニング → 清掃工事)`);
    if (fixed > 0) console.log(`マスタ起動補正: ${fixed}件(列ずれ)`);
  }
  return m;
}
