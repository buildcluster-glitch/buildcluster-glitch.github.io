          <td class="lbl">所在地</td><td colspan="3">${escapeHtml(k.address)}</td>
          <td class="lbl">駐車場</td><td>${escapeHtml(k.parking)}</td>
          <td class="lbl">鍵設置</td><td>${escapeHtml(k.keyLocation)}</td>
        </tr>
        <tr>
          <td class="lbl">施主</td><td colspan="3">${escapeHtml(k.shishu)}</td>
          <td class="lbl">施工業者</td><td colspan="3">${escapeHtml(k.shikou)}</td>
        </tr>
      </table>
      ${html}
      <div class="kt-notes">
        ※日曜日は基本的には休みになりますが、工期の遅れがある場合には作業を行う場合があります。<br>
        ※作業工程は前後することもあります。<br>
        ※工事用水道の無償貸与願います。
      </div>
    </div>`;
  const prevTitle = document.title;
  document.title = sanitizeFilename(`[${k.projectTitle||'(無題)'}] リフォーム工事工程表`);
  // A4横 印刷用 style 動的注入
  let pageStyle = document.createElement('style');
  pageStyle.id = '__koutei-page-style';
  pageStyle.textContent = '@page { size: A4 landscape; margin: 0; }';
  document.head.appendChild(pageStyle);
  document.body.classList.add('print-koutei-mode');
  setTimeout(() => {
    window.print();
    setTimeout(() => {
      document.body.classList.remove('print-koutei-mode');
      if (pageStyle) pageStyle.remove();
      document.title = prevTitle;
    }, 300);
  }, 200);
}

