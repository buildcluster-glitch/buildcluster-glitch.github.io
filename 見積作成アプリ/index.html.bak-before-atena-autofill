}

// =========================
// 項目カスケードメニュー(2段式: 小分類 → 項目)
// =========================
(function(){
  // メニューDOMを生成
  const menu = document.createElement('div');
  menu.id = 'item-cascade-menu';
  menu.innerHTML = `<div class="cascade-wrap">
    <div class="cascade-col-sub" id="cascade-sub-col"></div>
    <div class="cascade-col-items" id="cascade-items-col"></div>
  </div>`;
  document.body.appendChild(menu);
  const subCol = document.getElementById('cascade-sub-col');
  const itemsCol = document.getElementById('cascade-items-col');

  let currentInput = null; // 開いたときの対象input

  function closeMenu() {
    menu.style.display = 'none';
    currentInput = null;
  }

  function openMenu(btn) {
    const wrap = btn.closest('td') || btn.parentElement;
    const inp = wrap.querySelector('input[data-f="item"]');
    if (!inp) return;
    const category = btn.dataset.category;

    // グループ化ロジック
    const groups = new Map(); // name → items[]
    let usedGroups;
    let isCategoryMode = false; // true: 左カラム=カテゴリ、false: 左カラム=小分類

    if (!category) {
      // カテゴリ未指定 → 左カラムをカテゴリにして全項目表示
      isCategoryMode = true;
      const catOrder = new Map(CATEGORY_GROUPS.flatMap(g => g.minors).map((m, i) => [m, i]));
      const catMap = new Map(); // cat → items
      state.master.forEach(m => {
        const cat = m.カテゴリー || '(未分類)';
        if (!catMap.has(cat)) catMap.set(cat, []);
        catMap.get(cat).push(m);
      });
      // カテゴリ既定順 → アルファベット順 でソート
      const sortedCats = [...catMap.keys()].sort((a, b) => {
        const oa = catOrder.has(a) ? catOrder.get(a) : 999;
        const ob = catOrder.has(b) ? catOrder.get(b) : 999;
        if (oa !== ob) return oa - ob;
        return a.localeCompare(b, 'ja');
      });
      usedGroups = sortedCats.map(cat => {
        const arr = catMap.get(cat).slice().sort((a,b)=>Number(a.項目番号||0)-Number(b.項目番号||0));
        groups.set(cat, arr);  // 右カラム表示用に Map にも登録
        return [cat, arr];
      });
    } else {
      const rules = SUBCAT_RULES[category];
      const items = state.master.filter(m => m.カテゴリー === category);
      if (!items.length) return;
      if (rules) {
        rules.forEach(([order, name]) => groups.set(name, []));
        groups.set('その他', []);
        items.forEach(m => {
          const { name } = inferSubcat(category, m.項目);
          const key = groups.has(name) ? name : 'その他';
          groups.get(key).push(m);
        });
        usedGroups = [...groups.entries()].filter(([, arr]) => arr.length > 0);
      } else {
        const sorted = items.slice().sort((a,b) => Number(a.項目番号||0) - Number(b.項目番号||0));
        groups.set('全項目', sorted);  // 右カラム表示用に Map にも登録
        usedGroups = [['全項目', sorted]];
      }
    }

    // 左カラム(サブ)を構築
    subCol.innerHTML = usedGroups.map(([name, arr]) =>
      `<div class="cascade-sub-item" data-sub="${escapeHtml(name)}"><span>${escapeHtml(name)}</span><span class="count">${arr.length}</span></div>`
    ).join('');

    // 右カラム(項目)の表示関数
    const showItemsForSub = (subName) => {
      subCol.querySelectorAll('.cascade-sub-item').forEach(el => {
        el.classList.toggle('active', el.dataset.sub === subName);
      });
      const arr = groups.get(subName) || [];
      itemsCol.innerHTML = arr.length
        ? arr.sort((a,b)=>Number(a.項目番号||0)-Number(b.項目番号||0)).map(m => {
            const priceCol = state.settings.priceCol || '山一地所';
            const p = m[priceCol];
            const priceTxt = (p != null && p !== '') ? ` <small style="color:#6b7280;">${Number(p).toLocaleString()}円/${m.単位||'式'}</small>` : '';
            return `<div class="cascade-item" data-item="${escapeHtml(m.項目)}" title="${escapeHtml(m.項目)}">${escapeHtml(m.項目)}${priceTxt}</div>`;
          }).join('')
        : '<div class="cascade-empty">項目なし</div>';
      // クリックで選択
      itemsCol.querySelectorAll('.cascade-item').forEach(el => {
        el.addEventListener('click', () => {
          // カテゴリモード時: state.estimate.lines に直接 category をセットしてから input イベントを発火
          if (isCategoryMode) {
            const tr = inp.closest('tr');
            const lineIdx = Number(tr?.dataset.i);
            const line = state.estimate.lines[lineIdx];
            if (line) {
              const activeSub = subCol.querySelector('.cascade-sub-item.active');
              const catName = activeSub?.dataset.sub;
              if (catName && catName !== '(未分類)') {
                line.category = catName;
              }
            }
          }
          inp.value = el.dataset.item;
          // input イベント → handleLineEdit で単価等の自動入力 + renderEstimate
          inp.dispatchEvent(new Event('input', { bubbles:true }));
          closeMenu();
        });
      });
    };

    // サブ項目クリック&ホバーで右カラム更新
    subCol.querySelectorAll('.cascade-sub-item').forEach(el => {
      el.addEventListener('mouseenter', () => showItemsForSub(el.dataset.sub));
      el.addEventListener('click', () => showItemsForSub(el.dataset.sub));
    });
    // 初期: 最初のサブを表示
    if (usedGroups.length) showItemsForSub(usedGroups[0][0]);

    // ボタン位置に合わせて表示
    const rect = btn.getBoundingClientRect();
    menu.style.display = 'block';
    // 一旦 left:0 top:0 で寸法確定してから位置決め
    menu.style.left = '0px';
    menu.style.top = '0px';
    const mw = menu.offsetWidth;
    // 下/上どちらに出せるか判定し、より広い方を使う
    const spaceBelow = window.innerHeight - rect.bottom - 8;
    const spaceAbove = rect.top - 8;
    const useAbove = spaceBelow < 300 && spaceAbove > spaceBelow;
    const availableH = useAbove ? spaceAbove : spaceBelow;
    // 内側スクロール領域の高さを直接制限(これでメニュー内でスクロールできる)
    const menuWrap = menu.querySelector('.cascade-wrap');
    menuWrap.style.maxHeight = availableH + 'px';
    [subCol, itemsCol].forEach(c => { c.style.maxHeight = availableH + 'px'; });
    const mh = menu.offsetHeight;
    let left = rect.left;
    let top = useAbove ? Math.max(8, rect.top - mh - 2) : (rect.bottom + 2);
    if (left + mw > window.innerWidth - 8) left = Math.max(8, window.innerWidth - mw - 8);
    menu.style.left = left + 'px';
    menu.style.top = top + 'px';
    currentInput = inp;
  }

  // 見積tbodyの ▼ ボタンに委譲ハンドラ
  document.addEventListener('click', (e) => {
    const btn = e.target.closest('.item-cascade-btn');
    if (btn) {
      e.preventDefault();
      e.stopPropagation();
      openMenu(btn);
      return;
    }
    // メニュー外クリックで閉じる
    if (menu.style.display === 'block' && !e.target.closest('#item-cascade-menu')) {
      closeMenu();
    }
  });
  // Esc で閉じる
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && menu.style.display === 'block') closeMenu();
  });
  // ページ外スクロールで閉じる(メニュー内部のスクロールでは閉じない)
  window.addEventListener('scroll', (e) => {
    if (menu.style.display !== 'block') return;
    if (e.target && e.target.closest && e.target.closest('#item-cascade-menu')) return;
    closeMenu();
  }, true);
})();

