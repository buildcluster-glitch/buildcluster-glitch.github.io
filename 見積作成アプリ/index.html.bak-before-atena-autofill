      <td class="num no-print edit-only" style="background:#fff7ed;" title="原価小計 = 数量×(材料単価+外注単価)"><b>${fmtNum(lineCost(l))}</b></td>
      <td class="num no-print edit-only gross-cell" data-gross-cell="1">${(() => { const cost = lineCost(l); const g = amt - cost; const r = amt > 0 ? (g/amt*100) : null; return `${fmtNum(g)}${r!=null?`<br><small style="font-weight:normal;">${r.toFixed(1)}%</small>`:''}`; })()}</td>
      <td class="no-print edit-only" style="white-space:nowrap; position:relative;"><button class="btn-reduce" title="${l.reduced?'減工事を解除':'減工事マーク(提出時あり・実施時なし)'}" style="background:${l.reduced?'#fde68a':'transparent'}; border:1px solid ${l.reduced?'#f59e0b':'#ddd'};">${l.reduced?'➕':'➖'}</button><button class="danger btn-del" title="削除">×</button><span class="autofill-handle" title="下にドラッグで行コピー"></span></td>
    </tr>`;
  });

  // カテゴリー境界にセクション見出し行を挟み込み、カテゴリー小計も出す(印刷時見やすく)
  const sectionedHtml = [];
  let prevCat = null, sectionTotal = 0, sectionStart = -1;
  const pushSubtotal = () => {
    if (prevCat && sectionTotal > 0) {
      sectionedHtml.push(`<tr class="subtotal-row"><td colspan="${colspanTotal-1}">【${escapeHtml(prevCat)}】小計</td><td class="num print-edge">${sectionTotal.toLocaleString()}</td></tr>`);
    }
  };
  visibleIdx.forEach((i, n) => {
    const l = state.estimate.lines[i];
    const cat = l.category || '';
    if (cat && cat !== prevCat) {
      pushSubtotal();
      sectionTotal = 0;
      sectionedHtml.push(`<tr class="section-row" draggable="true" data-section-cat="${escapeHtml(cat)}"><td colspan="${colspanTotal}" style="cursor:grab; position:relative;">⇅ 【${escapeHtml(cat)}】 <small class="no-print" style="color:#475569; font-weight:normal;">(見出し行をドラッグでカテゴリ丸ごと入替)</small><button type="button" class="btn-del-section no-print" data-section-cat="${escapeHtml(cat)}" title="このカテゴリの全行を削除" style="position:absolute; right:6px; top:50%; transform:translateY(-50%); background:#f3f4f6; color:#6b7280; border:1px solid #d1d5db; border-radius:4px; padding:2px 8px; font-size:11px; cursor:pointer;">🗑 カテゴリ全行削除</button></td></tr>`);
      prevCat = cat;
    } else if (!cat && prevCat) {
      pushSubtotal();
      sectionTotal = 0;
      prevCat = null;
    }
    sectionTotal += lineAmount(l, mode);
    sectionedHtml.push(rowHtmlArr[n]);
  });
  pushSubtotal();

  // 現場管理諸経費の自動行(設定値があれば末尾に追加 / 見積書モードのみ)
  if (mode === 'estimate') {
    const s = state.settings || {};
    const subTotalAll = state.estimate.lines.reduce((sum,l)=>sum+lineAmount(l,'estimate'),0);
    let shogeihi = 0;
    if ((s.shogeihiPct||0) > 0) shogeihi = Math.round(subTotalAll * s.shogeihiPct / 100);
    else if ((s.shogeihiFixed||0) > 0) shogeihi = s.shogeihiFixed;
    if (shogeihi > 0) {
      sectionedHtml.push(`<tr class="shogeihi-row"><td colspan="${colspanTotal-1}" style="text-align:right;">現場管理諸経費 <small>(${(s.shogeihiPct||0)>0?`${s.shogeihiPct}%`:'固定額'})</small></td><td class="num print-edge">${shogeihi.toLocaleString()}</td></tr>`);
    }
  }

  estTbody.innerHTML = sectionedHtml.join('');
  // 粗利セル: 統一スタイル(背景色・色・タイトル)を適用
  estTbody.querySelectorAll('tr[data-i] td[data-gross-cell="1"]').forEach(td => {
    const idx = Number(td.closest('tr').dataset.i);
    const ll = state.estimate.lines[idx];
    if (!ll) return;
    const ea = lineAmount(ll, 'estimate');
    const cost = lineCost(ll);
    updateGrossCellDisplay(td, ea - cost, ea, cost);
  });

  estTbody.querySelectorAll('input, select').forEach(inp => {
    inp.addEventListener('input', handleLineEdit);
    if (inp.tagName === 'SELECT') inp.addEventListener('change', handleLineEdit);
    // 値が長くて見切れる可能性のあるテキスト系フィールドは title 属性をリアルタイム更新 → ホバーで全文表示
    if (inp.tagName === 'INPUT' && inp.type === 'text' && inp.dataset && inp.dataset.f &&
        !['qty','unitPrice','orderPrice','amount','orderAmount','yanushiAmt','tenantAmt'].includes(inp.dataset.f)) {
      const updateTitle = () => { inp.title = inp.value || ''; };
      updateTitle();
      inp.addEventListener('input', updateTitle);
      inp.addEventListener('change', updateTitle);
    }
    if (inp.dataset && inp.dataset.num === '1') {
      inp.addEventListener('focus', handleNumFocus);
      inp.addEventListener('blur', handleNumBlur);
    }
    // datalist付きinputは、フォーカス時に候補を自動展開(Chrome/Edgeのみ対応)
    // ただし freeform テキスト(specs/note)は現在値を編集したいのでクリアしない
    // room は data-clear-on-focus="1" で「フォーカス時に一時クリア → 全候補表示」
    const FREEFORM_DATALIST_FIELDS = new Set(['specs', 'note', 'specsMaterial']);
    if (inp.tagName === 'INPUT' && inp.hasAttribute('list')) {
      if (inp.dataset.clearOnFocus === '1') {
        // 室名: フォーカスで一時クリア(候補一覧を全部表示) / blur で何も選んでなければ元に戻す
        inp.addEventListener('focus', e => {
          const el = e.target;
          el._origRoom = el.value;
          el._roomChanged = false;
          el.value = '';
          if (typeof el.showPicker === 'function') {
            try { el.showPicker(); } catch(_) {}
          }
        });
        inp.addEventListener('input', e => { e.target._roomChanged = true; });
        inp.addEventListener('blur', e => {
          const el = e.target;
          if (!el._roomChanged && (el.value === '' || el.value == null)) {
            // 何も選ばずに blur → 元の値に戻す
            el.value = el._origRoom || '';
          }
          delete el._origRoom;
          delete el._roomChanged;
        });
      } else if (FREEFORM_DATALIST_FIELDS.has(inp.dataset.f)) {
        // 値は残したままで showPicker だけ呼ぶ(デフォ値を保ちつつ候補も見える)
        inp.addEventListener('focus', e => {
          if (typeof e.target.showPicker === 'function') {
            try { e.target.showPicker(); } catch(_) {}
          }
        });
      } else {
        inp.addEventListener('focus', showDatalistPicker);
        inp.addEventListener('mousedown', showDatalistPickerOnClick);
        inp.addEventListener('blur', handleDatalistBlur);
        // ユーザー入力(タイピング/削除)を追跡。明示的な空削除は復元しない
        inp.addEventListener('input', () => { inp._userInput = true; });
        // 空の状態で Backspace/Delete を押した時は input event が発火しないので keydown でも検知
        inp.addEventListener('keydown', (ev) => {
          if (ev.key === 'Backspace' || ev.key === 'Delete' || ev.key === 'Escape'
              || ev.key.length === 1) {
            inp._userInput = true;
          }
        });
      }
    }
  });
  estTbody.querySelectorAll('.btn-del').forEach(btn => {
    btn.addEventListener('click', e => {
      const idx = Number(e.target.closest('tr').dataset.i);
      state.estimate.lines.splice(idx,1);
      saveEstimate(); renderEstimate();
    });
  });
  // セクション見出しの「🗑 カテゴリ全行削除」ボタン
  estTbody.querySelectorAll('.btn-del-section').forEach(btn => {
    btn.addEventListener('click', e => {
      e.stopPropagation();
      const cat = btn.dataset.sectionCat;
      if (!cat) return;
      // 該当カテゴリの行数を集計
      const targets = state.estimate.lines.filter(l => l.category === cat);
      if (!targets.length) return;
      const filledCount = targets.filter(l => l.item).length;
      if (!confirm(`【${cat}】の全 ${targets.length}行 (うち項目入力済 ${filledCount}行) を削除します。\n\nよろしいですか?`)) return;
      // Undo を即時コミット
      if (typeof pushUndo === 'function') pushUndo(true);
      // 該当カテゴリの行を全削除
      state.estimate.lines = state.estimate.lines.filter(l => l.category !== cat);
      saveEstimate();
      if (typeof pushUndo === 'function') pushUndo(true);
      renderEstimate();
      showToast(`【${cat}】の${targets.length}行を削除しました(Ctrl+Z で取消可)`);
    });
  });
  // 仕様・摘要セル の × クリアボタン
  estTbody.querySelectorAll('.btn-clear-specs').forEach(btn => {
    btn.addEventListener('click', e => {
      e.stopPropagation();
      e.preventDefault();
      const idx = Number(btn.dataset.rowI);
      const line = state.estimate.lines[idx];
      if (!line) return;
      line.specs = '';
      // DOMの input も即時更新
      const tr = btn.closest('tr');
      if (tr) {
        const specsInp = tr.querySelector('input[data-f="specs"]');
        if (specsInp) specsInp.value = '';
      }
      saveEstimate();
    });
  });
  // 「＋」ボタン(行の上端/末尾の下端): data-insert-before の位置に新規空行を挿入
  estTbody.querySelectorAll('.row-insert-above, .row-insert-below').forEach(btn => {
    btn.addEventListener('click', e => {
      e.stopPropagation();
      e.preventDefault();
      const insertAt = Number(btn.dataset.insertBefore);
      if (Number.isNaN(insertAt)) return;
      // 挿入前の状態を Undo に即時コミット(Ctrl+Z で1ステップで戻れる)
      if (typeof pushUndo === 'function') pushUndo(true);
      // 直上の既存行(あれば)からカテゴリーを引き継ぐ
      const newLine = emptyLine();
      const prev = state.estimate.lines[insertAt - 1];
      if (prev && prev.category) newLine.category = prev.category;
      state.estimate.lines.splice(insertAt, 0, newLine);
      saveEstimate();
      // 挿入後の状態も即時コミット → 後の編集と独立した1ステップに
      if (typeof pushUndo === 'function') pushUndo(true);
      renderEstimate();
      // 挿入直後にカテゴリ列にフォーカス
      setTimeout(() => {
        const inserted = estTbody.querySelector(`tr[data-i="${insertAt}"]`);
        if (inserted) {
          const sel = inserted.querySelector('select[data-f="category"], input[data-f="category"]');
          if (sel) sel.focus();
          else inserted.scrollIntoView({ block:'nearest', behavior:'smooth' });
        }
      }, 30);
    });
  });
  // 減工事トグル(ワンクリックで切替、理由入力無し)
  estTbody.querySelectorAll('.btn-reduce').forEach(btn => {
    btn.addEventListener('click', e => {
      e.stopPropagation();
      const idx = Number(e.target.closest('tr').dataset.i);
      const line = state.estimate.lines[idx];
      if (!line) return;
      line.reduced = !line.reduced;
      autoUpdateEstimateStatus();
      saveEstimate(); renderEstimate();
    });
  });
  // ↑↓ボタンは廃止(ドラッグ&ドロップで行入替可能なため)
  // Excel風オートフィル: 工事名称セル右下のハンドルを下にドラッグして工事名称を連続コピー
  estTbody.querySelectorAll('.item-fill-handle').forEach(handle => {
    handle.addEventListener('mousedown', e => {
      e.preventDefault(); e.stopPropagation();
      const tr = e.target.closest('tr');
      const srcIdx = Number(tr.dataset.i);
      const srcLine = state.estimate.lines[srcIdx];
      if (!srcLine || !srcLine.item) return;
      let hoveredTargetIdx = srcIdx;
      const allRows = [...estTbody.querySelectorAll('tr[data-i]')];
      const onMove = (ev) => {
        const y = ev.clientY;
        let targetTr = null;
        for (const r of allRows) {
          const rect = r.getBoundingClientRect();
          if (rect.top <= y && rect.bottom >= y) { targetTr = r; break; }
        }
        allRows.forEach(r => r.classList.remove('item-fill-target'));
        if (!targetTr) return;
        const targetIdx = Number(targetTr.dataset.i);
        if (targetIdx > srcIdx) {
          hoveredTargetIdx = targetIdx;
          allRows.forEach(r => {
            const i = Number(r.dataset.i);
            if (i > srcIdx && i <= targetIdx) r.classList.add('item-fill-target');
          });
        } else {
          hoveredTargetIdx = srcIdx;
        }
      };
      const onUp = () => {
        document.removeEventListener('mousemove', onMove);
        document.removeEventListener('mouseup', onUp);
        allRows.forEach(r => r.classList.remove('item-fill-target'));
        if (hoveredTargetIdx <= srcIdx) return;
        // src+1 〜 hoveredTargetIdx の行に工事名称+マスタ派生値をコピー
        let filled = 0;
        // マスタから元ソースの情報を取得
        const masterRow = state.master.find(m =>
          m.カテゴリー === (srcLine.category||'') && m.項目 === srcLine.item
        );
        for (let i = srcIdx + 1; i <= hoveredTargetIdx; i++) {
          const tgt = state.estimate.lines[i];
          if (!tgt) continue;
          tgt.item = srcLine.item;
          // カテゴリ未設定ならsrcのカテゴリも継承
          if (!tgt.category) tgt.category = srcLine.category || '';
          // マスタがあれば単価等も自動入力(既存のqty/room/noteは尊重)
          if (masterRow && tgt.category === srcLine.category) {
            applyItemFromMaster(tgt, masterRow);
          }
          filled++;
        }
        if (filled > 0) {
          saveEstimate();
          renderEstimate();
          showToast(`「${srcLine.item}」を${filled}行にコピーしました`);
        }
      };
      document.addEventListener('mousemove', onMove);
      document.addEventListener('mouseup', onUp);
    });
  });

  // Excel風オートフィル: カテゴリセル右下のハンドルを下にドラッグしてカテゴリを連続コピー
  estTbody.querySelectorAll('.cat-fill-handle').forEach(handle => {
    handle.addEventListener('mousedown', e => {
      e.preventDefault(); e.stopPropagation();
      const tr = e.target.closest('tr');
      const srcIdx = Number(tr.dataset.i);
      const srcLine = state.estimate.lines[srcIdx];
      if (!srcLine || !srcLine.category) return;
      let hoveredTargetIdx = srcIdx;
      const allRows = [...estTbody.querySelectorAll('tr[data-i]')];
      const onMove = (ev) => {
        const y = ev.clientY;
        let targetTr = null;
        for (const r of allRows) {
          const rect = r.getBoundingClientRect();
          if (rect.top <= y && rect.bottom >= y) { targetTr = r; break; }
        }
        allRows.forEach(r => r.classList.remove('cat-fill-target'));
        if (!targetTr) return;
        const targetIdx = Number(targetTr.dataset.i);
        if (targetIdx > srcIdx) {
          hoveredTargetIdx = targetIdx;
          allRows.forEach(r => {
            const i = Number(r.dataset.i);
            if (i > srcIdx && i <= targetIdx) r.classList.add('cat-fill-target');
          });
        } else {
          hoveredTargetIdx = srcIdx;
        }
      };
      const onUp = () => {
        document.removeEventListener('mousemove', onMove);
        document.removeEventListener('mouseup', onUp);
        allRows.forEach(r => r.classList.remove('cat-fill-target'));
        if (hoveredTargetIdx <= srcIdx) return;
        // src+1 〜 hoveredTargetIdx の行に「行全体」をコピー(ディープクローン)
        let filled = 0;
        for (let i = srcIdx + 1; i <= hoveredTargetIdx; i++) {
          if (i >= state.estimate.lines.length) break;
          const clone = JSON.parse(JSON.stringify(srcLine));
          state.estimate.lines[i] = clone;
          filled++;
        }
        if (filled > 0) {
          saveEstimate();
          renderEstimate();
          showToast(`行全体(${srcLine.item||srcLine.category||'行'})を${filled}行にコピー`);
        }
      };
      document.addEventListener('mousemove', onMove);
      document.addEventListener('mouseup', onUp);
    });
  });

  // チェックボックスの範囲選択: Shift+クリック & マウスドラッグ
  estTbody.querySelectorAll('.row-check').forEach(chk => {
    chk.addEventListener('mousedown', e => {
      const tr = chk.closest('tr');
      const idx = Number(tr.dataset.i);
      // Shift+クリック: mousedownで処理してclickのデフォルト反転をキャンセル
      if (e.shiftKey && lastCheckedIdx != null) {
        e.preventDefault();
        const rows = [...estTbody.querySelectorAll('tr[data-i]')];
        const allIdx = rows.map(r => Number(r.dataset.i));
        const a = allIdx.indexOf(lastCheckedIdx);
        const b = allIdx.indexOf(idx);
        if (a >= 0 && b >= 0) {
          const [lo, hi] = [Math.min(a,b), Math.max(a,b)];
          for (let i = lo; i <= hi; i++) {
            const c = rows[i].querySelector('.row-check');
            if (c) c.checked = true;
          }
        }
        lastCheckedIdx = idx;
        return;
      }
      // 通常クリック: ドラッグで広めるstate(click後の状態)を記録
      dragCheckState = !chk.checked;
      // この間、全行の draggable を無効化して、行入替モードに入らないようにする
      estTbody.querySelectorAll('tr[data-i]').forEach(t => t.draggable = false);
    });
    // 通常クリックは lastCheckedIdx を更新するだけ
    chk.addEventListener('click', e => {
      if (!e.shiftKey) lastCheckedIdx = Number(chk.closest('tr').dataset.i);
    });
    // マウスドラッグで範囲選択(ボタン押しながら別の行に入ったら同じ状態を書き込む)
    chk.addEventListener('mouseenter', e => {
      if (dragCheckState === null) return;
      if (e.buttons !== 1) { dragCheckState = null; return; }
      chk.checked = dragCheckState;
    });
  });
  // オートフィル(行の右下ハンドルを下にドラッグ → その行を下方向にコピー複製)
  estTbody.querySelectorAll('.autofill-handle').forEach(handle => {
    handle.addEventListener('mousedown', e => {
      e.preventDefault(); e.stopPropagation();
      const tr = e.target.closest('tr');
      const srcIdx = Number(tr.dataset.i);
      const srcRect = tr.getBoundingClientRect();
      let hoveredTargetIdx = srcIdx;
      const allRows = [...estTbody.querySelectorAll('tr[data-i]')];
      const onMove = (ev) => {
        const y = ev.clientY;
        let targetTr = null;
        for (const r of allRows) {
          const rect = r.getBoundingClientRect();
          if (rect.top <= y && rect.bottom >= y) { targetTr = r; break; }
        }
        // ハイライト更新
        allRows.forEach(r => r.classList.remove('autofill-target'));
        if (!targetTr) return;
        const targetIdx = Number(targetTr.dataset.i);
        if (targetIdx > srcIdx) {
          hoveredTargetIdx = targetIdx;
          // src+1 〜 target の間の行を枠で囲む
          allRows.forEach(r => {
            const i = Number(r.dataset.i);
            if (i > srcIdx && i <= targetIdx) r.classList.add('autofill-target');
          });
        } else {
          hoveredTargetIdx = srcIdx;
        }
      };
      const onUp = () => {
        document.removeEventListener('mousemove', onMove);
        document.removeEventListener('mouseup', onUp);
        allRows.forEach(r => r.classList.remove('autofill-target'));
        if (hoveredTargetIdx > srcIdx) {
          autofillRange(srcIdx, hoveredTargetIdx);
        }
      };
      document.addEventListener('mousemove', onMove);
      document.addEventListener('mouseup', onUp);
    });
  });

  // ドラッグ&ドロップ(通常行 = 行単位入替 / セクション見出し = カテゴリ丸ごと入替)
  estTbody.querySelectorAll('tr').forEach(tr => {
    tr.addEventListener('dragstart', e => {
      // 入力中・ボタン操作中はドラッグさせない(文字選択・クリック保護)
      const tag = e.target.tagName;
      if (tag === 'INPUT' || tag === 'SELECT' || tag === 'BUTTON' || tag === 'TEXTAREA') {
        e.preventDefault();
        return;
      }
      e.dataTransfer.effectAllowed = 'move';
      if (tr.classList.contains('section-row')) {
        // カテゴリブロック全体を移動
        e.dataTransfer.setData('application/x-category', tr.dataset.sectionCat || '');
      } else if (tr.dataset.i != null) {
        e.dataTransfer.setData('text/plain', tr.dataset.i);
      }
      tr.classList.add('row-dragging');
    });
    tr.addEventListener('dragend', () => {
      tr.classList.remove('row-dragging');
      estTbody.querySelectorAll('tr').forEach(r => r.classList.remove('row-drop-before','row-drop-after'));
    });
    tr.addEventListener('dragover', e => {
      e.preventDefault();
      e.dataTransfer.dropEffect = 'move';
      const rect = tr.getBoundingClientRect();
      const after = (e.clientY - rect.top) > rect.height / 2;
      estTbody.querySelectorAll('tr').forEach(r => r.classList.remove('row-drop-before','row-drop-after'));
      tr.classList.add(after ? 'row-drop-after' : 'row-drop-before');
    });
    tr.addEventListener('dragleave', () => {
      tr.classList.remove('row-drop-before','row-drop-after');
    });
    tr.addEventListener('drop', e => {
      e.preventDefault();
      const catSrc = e.dataTransfer.getData('application/x-category');
      const rect = tr.getBoundingClientRect();
      const after = (e.clientY - rect.top) > rect.height / 2;
      tr.classList.remove('row-drop-before','row-drop-after');
      if (catSrc) {
        // カテゴリブロック移動
        let targetCat = tr.dataset.sectionCat;
        if (!targetCat && tr.dataset.i != null) {
          const l = state.estimate.lines[Number(tr.dataset.i)];
          targetCat = l?.category || '';
        }
        if (!targetCat || catSrc === targetCat) return;
        moveCategoryBlock(catSrc, targetCat, after ? 'after' : 'before');
        return;
      }
      const srcI = Number(e.dataTransfer.getData('text/plain'));
      const dstI = Number(tr.dataset.i);
      if (!Number.isNaN(srcI) && !Number.isNaN(dstI) && srcI !== dstI) moveLineTo(srcI, dstI, after ? 'after' : 'before');
    });
  });

  // order mode 行数表示
  document.getElementById('order-line-count').textContent = (mode==='order') ? `${visibleIdx.length}件` : '';

  renderTotals();
  renderPrintMeta();
}

function handleLineEdit(e) {
  const tr = e.target.closest('tr');
  const idx = Number(tr.dataset.i);
  const f = e.target.dataset.f;
  if (!f) return; // data-f の無い要素(行チェックボックス等)は無視
  const isNum = e.target.dataset.num === '1';
  const raw = e.target.value;
  const v = isNum ? parseNum(raw) : raw;  // 数値フィールドはparseしておく
  const line = state.estimate.lines[idx];
  const mode = state.settings.docMode || 'estimate';

  if (f === 'amount') {
    line.amountOverride = (v == null ? null : Number(v));
  } else if (f === 'orderAmount') {
    line.orderAmountOverride = (v == null ? null : Number(v));
  } else if (f === 'qty') {
    line.qty = Number(v) || 0;
    line.amountOverride = null;
    line.orderAmountOverride = null;
  } else if (f === 'unitPrice') {
    line.unitPrice = Number(v) || 0;
    line.amountOverride = null;
  } else if (f === 'orderPrice') {
    line.orderPrice = Number(v) || 0;
    line.orderAmountOverride = null;
  } else if (f === 'materialPrice') {
    line.materialPrice = Number(v) || 0;
    line.orderAmountOverride = null;
  } else if (f === 'supplier') {
    line.supplier = v;
    // 発注先を選んだら、マスタからその発注先の単価を自動入力(空/0の時のみ)
    if (v && line.itemRef) {
      const m = state.master.find(x => String(x.項目番号) === String(line.itemRef));
      if (m && m[v] != null && (!line.orderPrice || line.orderPrice === 0)) {
        line.orderPrice = Number(m[v]);
      }
    }
  } else if (f === 'burdenType') {
    // 備忘録ラベルのみ。単価・金額には一切影響しない(元請け指定アプリに転記する際の参考)
    line.burdenType = v;
    saveEstimate();
    renderEstimate();
    return;
  } else if (f === 'yanushiAmt') {
    // 家主金額の手入力上書き。空欄なら undefined(=自動計算に戻る)
    if (v == null || raw === '') delete line.yanushiAmt;
    else line.yanushiAmt = Number(v);
    saveEstimate();
    renderTotals();
    return;
  } else if (f === 'tenantAmt') {
    // 入居者金額の手入力上書き。空欄なら undefined(=自動計算に戻る)
    if (v == null || raw === '') delete line.tenantAmt;
    else line.tenantAmt = Number(v);
    saveEstimate();
    renderTotals();
    return;
  } else if (f === 'specsPart' || f === 'specsReason' || f === 'specsMaterial') {
    // 内装工事の構造化仕様: 施工面 / 原因 / 資材 を変更 → specs を再構築
    const cur = parseNaisoSpecs(line.specs);
    if (f === 'specsPart') cur.part = raw;
    else if (f === 'specsReason') cur.reason = raw;
    else cur.material = raw;
    line.specs = buildNaisoSpecs(cur);
    // 施工面を変えたら発注書の hatchuSurface にも同期(空のときだけ)
    if (f === 'specsPart' && !line.hatchuSurface) line.hatchuSurface = raw;
    saveEstimate();
    // select変更時は再描画(selectedの反映)、text変更時は入力維持
    if (f !== 'specsMaterial') renderEstimate();
    return;
  } else if (f === 'category') {
    // カテゴリー変更 → 項目セレクトの絞込が変わる
    line.category = v;
    // 現項目がこのカテゴリーに無ければ、参考としてそのまま残す(マスタ外表示)
    saveEstimate();
    renderEstimate();
    return;
  } else if (f === 'item') {
    line.item = v;
    // 選択値がマスタにあれば、その行の他フィールドを自動入力
    let matches = state.master.filter(m => m.項目 === v);
    if (line.category) {
      const inCategory = matches.filter(m => m.カテゴリー === line.category);
      if (inCategory.length) matches = inCategory;
    }
    const m = matches[0];
    // フローリング工事カテゴリーなら対応テンプレを検索して展開を促す
    if (m && m.カテゴリー === 'フローリング工事') {
      const tmpl = findFlooringTemplate(m.項目, state.settings.priceCol);
      if (tmpl) {
        asyncConfirm(
          `📋 内訳テンプレが見つかりました`,
          `「${m.項目}」は ${tmpl.rows.length}行の内訳明細があります。\n\n合計: ¥${tmpl.total.toLocaleString()}(${tmpl.元請け}単価)\n\n【内訳展開】現在の行を${tmpl.rows.length}行の内訳に置き換え\n【1行のみ】合計1行の形で続行`,
          `内訳展開`, `1行のみ`
        ).then(expand => {
          if (expand) {
            // 現在の行を削除 → その位置にテンプレ展開
            state.estimate.lines.splice(idx, 1);
            expandTemplateAt(tmpl, idx - 1);
            saveEstimate(); renderEstimate();
          } else {
            // 通常の自動入力ロジック
            applyItemFromMaster(line, m);
            saveEstimate(); renderEstimate();
          }
        });
        return;
      }
    }
    if (m) {
      line.itemRef = m.項目番号;
      if (!line.category) line.category = m.カテゴリー || '';
      line.unit = m.単位 || line.unit || '式';
      // 単価マスタの備考に「アラート用メモ」が書かれていればトーストで一言通知
      // (例: CF貼替 → "※ソフト巾木", CF重ね張り → "※下地調整費")
      // 内装仕様パターン("経年変色/床/全面" 等)・産廃名・数値・短すぎ/長すぎ は除外
      const memo = (m.備考 || '').trim();
      const _wasteSet = new Set(['混合廃棄物','廃プラスチック類','廃プラ','がれき類','金属くず','木くず','紙くず']);
      const isSpecsPattern = memo.includes('/');  // 内装仕様 (a/b/c) は除外
      const isShort = memo.length <= 1;
      if (memo && !_wasteSet.has(memo) && isNaN(Number(memo)) && !isSpecsPattern && !isShort) {
        showMemoAlert(m.項目, memo);
      }
      // セーフガード: 数量が100以上の値 or 小数点以下の極小値は明らかにズレ → 1にする
      let qty = Number(m.数量);
      if (!Number.isFinite(qty) || qty <= 0 || qty >= 100 || qty < 0.01) qty = 1;
      line.qty = qty;
      const priceCol = state.settings.priceCol || '山一地所';
      line.unitPrice = Number(m[priceCol]) || 0;
      line.amountOverride = null;
      // 室名: マスタ値が数値ぽいなら採用しない
      let roomVal = m.室名 || '';
      if (roomVal && !isNaN(Number(roomVal))) roomVal = '';
      // 項目が変わったら室名は常にマスタ値で上書き(空でも上書き = 前の項目の室名を引きずらない)
      line.room = roomVal;
      // 仕様・摘要(備考): 数値や産廃品目名が混入していたら採用しない
      let specsVal = m.備考 || '';
      const wasteSet = new Set(['混合廃棄物','廃プラスチック類','廃プラ','がれき類','金属くず','木くず','紙くず']);
      if (wasteSet.has(specsVal) || (specsVal && !isNaN(Number(specsVal)))) specsVal = '';
      // 内装工事はマスタから引かない(構造化フィールド側で管理)
      if (line.category === '内装工事') specsVal = '';
      // 項目が変わったら仕様・摘要も常にマスタ値で上書き(空でも上書き = 前の項目の specs を引きずらない)
      line.specs = specsVal;
      // 発注先・外注単価の更新(項目が変わったら原則更新する)
      const sHint = (m.施工業者 || '').trim();
      const masterZairyou = Number(m['材料費']) || 0;
      const curSup = (line.supplier || '').trim();
      // 材料単価は supplier 状態に関わらずマスタから引く(材料支給+外注 パターンに対応)
      line.materialPrice = masterZairyou;
      if (COL_GROUPS.hatchu.cols.includes(sHint)) {
        // 新項目のマスタに施工業者ヒントがあれば、それに差し替え
        line.supplier = sHint;
        line.orderPrice = Number(m[sHint]) || 0;
      } else if (curSup && COL_GROUPS.hatchu.cols.includes(curSup)) {
        // 既存の発注先のまま、新項目のその業者単価で上書き(無ければ0)
        line.orderPrice = Number(m[curSup]) || 0;
      } else {
        // supplier 空 / ビルドクラスタ / 不明 → 外注費は 0(材料費は上で別途セット済)
        line.orderPrice = 0;
      }
      line.orderAmountOverride = null;
    }
    // 内装工事: 資材デフォルト設定(「クロス貼替」のみ「無地量産クロス」、それ以外は空欄)
    //   → 項目変更時は材料欄を必ずリセット(旧項目の残骸を持ち越さない)
    if (line.category === '内装工事') {
      const parts = parseNaisoSpecs(line.specs);
      const itemName = line.item || '';
      const isKurosHarigae = /^クロス貼替/.test(itemName) && !/量産指定品番以外/.test(itemName);
      // 項目が変わったら資材は必ず入れ直し
      parts.material = isKurosHarigae ? '無地量産クロス' : '';
      line.specs = buildNaisoSpecs(parts);
    }
    saveEstimate();
    renderEstimate();
    return;
  } else {
    line[f] = v;
  }
  saveEstimate();
  renderTotals();

  // 金額セルの表示を更新(ただしそのセル自体に今入力中の場合は触らない)
  const amtCell = tr.querySelector(mode==='order' ? 'input[data-f=orderAmount]' : 'input[data-f=amount]');
  if (amtCell && (f !== 'amount' && f !== 'orderAmount')) {
    // 未フォーカスなら整形、フォーカス中(ユーザー編集中)なら素の数値
    const isAmtFocused = document.activeElement === amtCell;
    amtCell.value = isAmtFocused ? String(lineAmount(line, mode)) : fmtNum(lineAmount(line, mode));
    amtCell.style.background = '';
    amtCell.title = '数量×単価で自動計算中';
  } else if (amtCell) {
    const ov = isOverridden(line, mode);
    amtCell.style.background = ov ? '#fff7e6' : '';
    amtCell.title = ov ? '手打ち(上書き中) — 空にすると 数量×単価 に戻ります' : '数量×単価で自動計算中';
  }
  // supplier変更で orderPrice を自動入力した時、DOMの orderPrice セルも更新
  if (f === 'supplier' && mode === 'estimate') {
    const opCell = tr.querySelector('input[data-f=orderPrice]');
    if (opCell) opCell.value = fmtNum(line.orderPrice || 0);
  }
  // supplier変更時は絞込・発注先リストも変わる + 発注書タブの工事店セルにも同期
  if (f === 'supplier') {
    renderOrderFilterBar();
    syncSupplierBetweenTabs(Number(tr.dataset.i), line.supplier || '', 'estimate');
    // 単価が自動入力された場合、発注書タブの単価セルも同期
    if (line.orderPrice != null) {
      syncOrderPriceBetweenTabs(Number(tr.dataset.i), line.orderPrice || 0, 'estimate');
    }
  }
  // 発注単価 を変更したら 発注書タブの該当セルにも同期
  if (f === 'orderPrice') {
    syncOrderPriceBetweenTabs(Number(tr.dataset.i), line.orderPrice || 0, 'estimate');
  }
  // 数量 / 単価 / 発注小計 変更時、見積タブの 原価小計セル と 粗利セル を即時更新
  if (f === 'qty' || f === 'orderPrice' || f === 'materialPrice' || f === 'orderAmount' || f === 'unitPrice' || f === 'amount') {
    // 原価小計セル(orderAmount → display用 b 要素)を更新
    const tds = Array.from(tr.querySelectorAll('td.no-print.edit-only'));
    // 順序: 発注先 / 材料単価 / 外注単価 / 原価小計 / 粗利 / 備考 / 操作
    const costTd = tds[3];
    if (costTd) {
      costTd.innerHTML = `<b>${fmtNum(lineCost(line))}</b>`;
    }
    // 粗利セル: data-gross-cell 属性で直接指定
    const grossTd = tr.querySelector('td[data-gross-cell="1"]');
    if (grossTd) {
      const ea = lineAmount(line, 'estimate');
      const cost = lineCost(line);
      updateGrossCellDisplay(grossTd, ea - cost, ea, cost);
    }
    // 発注書タブの 発注小計/粗利 にも同期(orderPrice / qty 変更時)
    if (typeof syncOrderPriceBetweenTabs === 'function') {
      syncOrderPriceBetweenTabs(Number(tr.dataset.i), line.orderPrice || 0, 'estimate');
    }
  }
}

// 粗利セルの表示更新(粗利率付き、3段階判定)
function updateGrossCellDisplay(td, gross, estAmt, orderAmt) {
  if (!td) return;
  const rate = (estAmt > 0) ? (gross / estAmt * 100) : null;
  let bg = '#f3f4f6', color = '#6b7280';
  if (rate == null) { bg = '#f3f4f6'; color = '#6b7280'; }
  else if (rate >= 25) { bg = '#dcfce7'; color = '#166534'; }   // 25%以上 緑
  else if (rate >= 10) { bg = '#fef3c7'; color = '#92400e'; }   // 10〜24% 黄
  else { bg = '#fee2e2'; color = '#b91c1c'; }                    // 10%未満 赤
  td.style.background = bg;
  td.style.color = color;
  td.style.fontWeight = '600';
  td.title = `粗利 = ${fmtNum(estAmt)} − ${fmtNum(orderAmt)} = ${fmtNum(gross)}\n粗利率 = ${rate!=null?rate.toFixed(1)+'%':'(計算不可)'}\n判定: 25%以上=緑 / 10〜24%=黄 / 10%未満=赤`;
  td.innerHTML = rate != null
    ? `${fmtNum(gross)}<br><small style="font-weight:normal;">${rate.toFixed(1)}%</small>`
    : fmtNum(gross);
}

// 見積タブの「発注単価」と 発注書タブの「発注単価/発注小計/粗利」を双方向DOM同期
function syncOrderPriceBetweenTabs(lineIdx, value, sourceTab) {
  const disp = fmtNum(value);
  const line = state.estimate.lines[lineIdx];
  // 見積タブ(orderPrice 入力 + 発注小計/粗利セル)
  if (sourceTab !== 'estimate') {
    const estTr = document.querySelector(`#estimate-tbody tr[data-i="${lineIdx}"]`);
    if (estTr) {
      const estInp = estTr.querySelector('input[data-f="orderPrice"]');
      if (estInp && document.activeElement !== estInp) estInp.value = disp;
      const oaInp = estTr.querySelector('input[data-f="orderAmount"]');
      if (oaInp && document.activeElement !== oaInp && line) oaInp.value = fmtNum(lineAmount(line, 'order'));
      const tds = Array.from(estTr.querySelectorAll('td.no-print.edit-only'));
      const grossTd = tds[3];
      if (grossTd && line) {
        const gross = lineAmount(line, 'estimate') - lineAmount(line, 'order');
        grossTd.textContent = fmtNum(gross);
        grossTd.style.color = gross >= 0 ? '#166534' : '#b91c1c';
      }
    }
  }
  // 発注書タブ(orderPrice / orderAmount 入力 + 粗利セル)
  if (sourceTab !== 'hatchu') {
    const hatchuTr = document.querySelector(`#hatchu-tbody tr[data-i="${lineIdx}"]`);
    if (hatchuTr && line) {
      const hatchuInp = hatchuTr.querySelector('input[data-h="orderPrice"]');
      if (hatchuInp && document.activeElement !== hatchuInp) hatchuInp.value = disp;
      const orderAmt = lineAmount(line, 'order');
      const oaInp = hatchuTr.querySelector('input[data-h="orderAmount"]');
      if (oaInp && document.activeElement !== oaInp && (line.orderAmountOverride == null)) oaInp.value = fmtNum(orderAmt);
      // 見積単価セル(no-print/1番目) と 粗利セル(no-print/2番目)
      const noPrintTds = Array.from(hatchuTr.querySelectorAll('td.no-print'));
      const unitPriceTd = noPrintTds[0];
      if (unitPriceTd) unitPriceTd.textContent = fmtNum(line.unitPrice || 0);
      const grossTd = noPrintTds[1];
      if (grossTd) {
        const estAmt = lineAmount(line, 'estimate');
        updateGrossCellDisplay(grossTd, estAmt - orderAmt, estAmt, orderAmt);
      }
    }
  }
}

// 見積タブの「発注先」と 発注書タブの「工事店」を双方向DOM同期(state は line.supplier 共通)
function syncSupplierBetweenTabs(lineIdx, value, sourceTab) {
  // 見積タブ側
  if (sourceTab !== 'estimate') {
    const estTr = document.querySelector(`#estimate-tbody tr[data-i="${lineIdx}"]`);
    if (estTr) {
      const estInp = estTr.querySelector('input[data-f="supplier"]');
      if (estInp && document.activeElement !== estInp) estInp.value = value;
    }
  }
  // 発注書タブ側(supplier は select に変更済)
  if (sourceTab !== 'hatchu') {
    const hatchuTr = document.querySelector(`#hatchu-tbody tr[data-i="${lineIdx}"]`);
    if (hatchuTr) {
      const hatchuSel = hatchuTr.querySelector('select[data-h="supplier"]');
      if (hatchuSel && document.activeElement !== hatchuSel) {
        // 選択肢に存在しなければ option を追加(現在値として)
        const exists = Array.from(hatchuSel.options).some(o => o.value === value);
        if (!exists && value) {
          const opt = document.createElement('option');
          opt.value = value;
          opt.textContent = value;
          opt.selected = true;
          hatchuSel.insertBefore(opt, hatchuSel.firstChild.nextSibling); // (空)の直後
        }
        hatchuSel.value = value;
      }
    }
  }
}

// 数値入力のフォーカス/ブラー: 入力中は素の数値、離れたらカンマ整形
function handleNumFocus(e) {
  if (e.target.dataset.num !== '1') return;
  e.target.value = parseNum(e.target.value) ?? '';
  e.target.select();
}
function handleNumBlur(e) {
  if (e.target.dataset.num !== '1') return;
  const n = parseNum(e.target.value);
  e.target.value = (n == null ? '' : fmtNum(n));
}

// datalist候補を強制展開: 既存値を一時的に空にして全候補を表示、
//   ユーザーが何も操作せず離れたら元の値に戻す(明示的な削除は尊重)
function showDatalistPicker(e) {
  const el = e.target;
  if (el.value) {
    el._origValue = el.value;
    el._userInput = false; // このフォーカスセッションで入力があったか追跡
    el.value = '';
  } else {
    el._userInput = false;
  }
  if (typeof el.showPicker === 'function') {
    try { el.showPicker(); } catch(_) {}
  }
}
function showDatalistPickerOnClick(e) {
  const el = e.target;
  if (document.activeElement === el) {
    if (el.value && el._origValue === undefined) {
      el._origValue = el.value;
      el._userInput = false;
      el.value = '';
    }
    if (typeof el.showPicker === 'function') {
      try { el.showPicker(); } catch(_) {}
    }
  }
}
// blur時: 値が空で元の値が残っていて、かつユーザーが何も入力しなかった時のみ復元
//   → 明示的に削除した場合(backspace等のキー入力あり)は復元せず、state側にも反映
function handleDatalistBlur(e) {
  const el = e.target;
  if (el._origValue !== undefined) {
    const origVal = el._origValue;
    const userInput = !!el._userInput;
    delete el._origValue;
    delete el._userInput;
    if (el.value === '' && !userInput) {
      // 何も操作せず離れた → 元の値に復元
      el.value = origVal;
    } else if (el.value === '' && userInput && origVal !== '') {
      // ユーザーが明示的にクリア → input event を手動 dispatch して state に反映
      el.dispatchEvent(new Event('input', { bubbles: true }));
      el.dispatchEvent(new Event('change', { bubbles: true }));
    }
    // 数値フィールドはフォーマット(カンマ付き表示)
    if (el.dataset && el.dataset.num === '1') {
      const n = parseNum(el.value);
      el.value = (n == null ? '' : fmtNum(n));
    }
  }
}

function renderTotals() {
  const mode = state.settings.docMode || 'estimate';
  const rate = (state.settings.taxRate||10);

  // 見積合計(常に全行、モード非依存)+ 現場管理諸経費
  const mitoriLinesTotal = state.estimate.lines.reduce((s,l) => s + lineAmount(l, 'estimate'), 0);
  const ss = state.settings || {};
  let shogeihi = 0;
  if ((ss.shogeihiPct||0) > 0) shogeihi = Math.round(mitoriLinesTotal * ss.shogeihiPct / 100);
  else if ((ss.shogeihiFixed||0) > 0) shogeihi = ss.shogeihiFixed;
  const mitoriSubtotal = mitoriLinesTotal + shogeihi;  // 税別小計(値引前)
  // 値引(税別から控除)
  const nebiki = Math.max(0, Number(state.estimate.meta?.nebikiAmount || 0));
  const mitoriTotal = Math.max(0, mitoriSubtotal - nebiki); // 税別 値引後
  const mitoriTax = Math.round(mitoriTotal * rate / 100);
  document.getElementById('subtotal-mitori').textContent = mitoriSubtotal.toLocaleString();
  document.getElementById('tax-mitori').textContent = mitoriTax.toLocaleString();
  document.getElementById('total-mitori').textContent = (mitoriTotal+mitoriTax).toLocaleString();
  // 値引行の表示切替
  const nebikiLine = document.getElementById('nebiki-line');
  const aftLine = document.getElementById('aftnebiki-line');
  if (nebikiLine && aftLine) {
    if (nebiki > 0) {
      nebikiLine.style.display = '';
      aftLine.style.display = '';
      document.getElementById('nebiki-amt').textContent = nebiki.toLocaleString();
      document.getElementById('subtotal-after-nebiki').textContent = mitoriTotal.toLocaleString();
    } else {
      nebikiLine.style.display = 'none';
      aftLine.style.display = 'none';
    }
  }
  // 値引コントロールの結果表示
  const nebikiResultEl = document.getElementById('nebiki-result');
  if (nebikiResultEl) {
    if (nebiki > 0) {
      nebikiResultEl.textContent = `→ 税別 ${mitoriTotal.toLocaleString()} 円 / 税込 ${(mitoriTotal+mitoriTax).toLocaleString()} 円`;
    } else {
      nebikiResultEl.textContent = '';
    }
  }
  // 値引入力欄の値を反映(編集中以外)
  const nebikiInp = document.getElementById('nebiki-input');
  if (nebikiInp && document.activeElement !== nebikiInp) {
    nebikiInp.value = nebiki > 0 ? fmtNum(nebiki) : '';
  }

  // 外注合計(発注書モード時は発注先絞込を反映、見積書モード時は全発注先)
  const orderIdxs = (mode === 'order') ? filteredLineIndexes() : state.estimate.lines.map((_,i)=>i);
  const orderTotal = orderIdxs.reduce((s,i) => s + lineAmount(state.estimate.lines[i], 'order'), 0);
  const orderTax = Math.round(orderTotal * rate / 100);
  document.getElementById('subtotal-order').textContent = orderTotal.toLocaleString();
  document.getElementById('tax-order').textContent = orderTax.toLocaleString();
  document.getElementById('total-order').textContent = (orderTotal+orderTax).toLocaleString();

  // 印刷ヘッダー内合計(税込で表示)
  const printTotal = document.getElementById('print-total-inline');
  if (printTotal) {
    const shown = (mode === 'order') ? (orderTotal + orderTax) : (mitoriTotal + mitoriTax);
    printTotal.textContent = shown.toLocaleString();
  }

  // 粗利・粗利率(印刷外、見積モード共通)
  // 粗利 = 値引後 見積小計(税別) − 原価合計(税別)
  // 原価合計 = 材料費合計 + 外注費合計(自社作業料含む)
  const totalCost = state.estimate.lines.reduce((s, l) => {
    if (!l.item || l.reduced) return s;
    return s + lineCost(l);
  }, 0);
  const grossProfit = mitoriTotal - totalCost;
  const grossRate = mitoriTotal > 0 ? (grossProfit / mitoriTotal * 100) : null;
  // 原価内訳: 材料費(列) + 外注費(列、supplier 設定あり)
  // - 材料費 = sum(qty × materialPrice) — 全行
  // - 外注費 = sum(qty × orderPrice)    — supplier 設定あり かつ 'ビルドクラスタ' 以外
  // - 自社   = sum(qty × orderPrice)    — supplier === 'ビルドクラスタ'(自社作業料)
  let gaichuuTotal = 0, zairyouTotal = 0, jishaCostTotal = 0;
  state.estimate.lines.forEach(l => {
    if (!l.item || l.reduced) return;
    const sup = (l.supplier || '').trim();
    const qty = Number(l.qty) || 0;
    zairyouTotal += qty * (Number(l.materialPrice) || 0);
    const labor = qty * (Number(l.orderPrice) || 0);
    if (sup === 'ビルドクラスタ') jishaCostTotal += labor;
    else if (sup) gaichuuTotal += labor;
    // sup空 → 外注費 0(自社作業として扱う) / 材料費に既に加算済
  });
  const setText = (id, val) => { const el = document.getElementById(id); if (el) el.textContent = val; };
  setText('gross-gaichuu-total', gaichuuTotal.toLocaleString());
  setText('gross-zairyou-total', zairyouTotal.toLocaleString());
  setText('gross-jisha-total',  jishaCostTotal.toLocaleString());
  const gpEl = document.getElementById('gross-profit-amt');
  const grEl = document.getElementById('gross-profit-rate');
  if (gpEl) {
    gpEl.textContent = grossProfit.toLocaleString();
    gpEl.style.color = grossProfit >= 0 ? '#166534' : '#b91c1c';
  }
  if (grEl) {
    if (grossRate == null) {
      grEl.textContent = '-';
      grEl.style.color = '#6b7280';
    } else {
      grEl.textContent = `${grossRate.toFixed(1)}%`;
      // 25%以上=緑 / 10〜24%=オレンジ / 10%未満=赤
      if (grossRate >= 25) grEl.style.color = '#166534';
      else if (grossRate >= 10) grEl.style.color = '#92400e';
      else grEl.style.color = '#b91c1c';
    }
  }

  // 外注ブロックのラベル更新(モード/絞込状況を反映)
  const filter = state.estimate.meta?.orderSupplierFilter || '__all__';
  const orderLabel = document.getElementById('totals-order-label');
  if (mode === 'order') {
    orderLabel.textContent = (filter === '__all__')
      ? '【御発注書 / 全発注先】'
      : `【御発注書 / ${filter} 御中】`;
  } else {
    orderLabel.textContent = '【外注費合計(全発注先)】';
  }

  // 印刷時の表示制御: モードに応じて反対側を no-print
  document.getElementById('totals-mitori').classList.toggle('no-print', mode === 'order');
  document.getElementById('totals-order').classList.toggle('no-print', mode === 'estimate');

  // 粗利サマリー(減工事・値引反映後、税別、印刷外)
  // 見積合計 = 確定請求金額(税別) = mitoriSubtotal − 減工事額 − 値引額
  // 外注費合計 = 減工事行を除いた orderPrice 合計(発注書タブの実発注分のみ、materialPrice 含めた lineCost を使用)
  const reducedAmtForGross = state.estimate.lines.filter(l => l.reduced).reduce((s,l) => s + lineAmount(l, 'estimate'), 0);
  const finalMitori = Math.max(0, mitoriSubtotal - reducedAmtForGross - nebiki);
  const allOrderTotal = state.estimate.lines.filter(l => !l.reduced).reduce((s,l) => s + lineCost(l), 0);
  const profit = finalMitori - allOrderTotal;
  const profitRate = finalMitori > 0 ? (profit / finalMitori * 100) : null;
  const profEl = document.getElementById('summary-profit');
  document.getElementById('summary-mitori').textContent = finalMitori.toLocaleString();
  document.getElementById('summary-order').textContent = allOrderTotal.toLocaleString();
  profEl.textContent = profit.toLocaleString();
  profEl.style.color = profit < 0 ? '#dc2626' : '#166534';
  document.getElementById('summary-rate').textContent = profitRate != null ? `${profitRate.toFixed(1)}%` : '-';

  // 💰 確定請求金額(税込) = (見積総額 − 減工事額 − 値引額) + 消費税
  // ※ mitoriTotal は既に値引適用後 (mitoriSubtotal - nebiki) なので、それを基準に税込算出
  // ※ 提出時(税込) = 値引前見積総額 + 税
  const reducedLinesAll = state.estimate.lines.filter(l => l.reduced);
  const reducedAmt = reducedLinesAll.reduce((s,l) => s + lineAmount(l, 'estimate'), 0);
  // 提出時(税込) = mitoriSubtotal(値引前) + その税
  const submittedTax = Math.round(mitoriSubtotal * rate / 100);
  const submittedTotalIncl = mitoriSubtotal + submittedTax;
  // 減工事を引いた最終税抜
  const finalExcl = Math.max(0, mitoriSubtotal - reducedAmt - nebiki);
  const finalTax = Math.round(finalExcl * rate / 100);
  const finalTotalIncl = finalExcl + finalTax;
  // 減工事額の税込概算(表示用)
  const reducedAmtIncl = Math.round(reducedAmt * (1 + rate/100));
  const nebikiIncl = Math.round(nebiki * (1 + rate/100));
  const setIfEl = (id, val) => { const el = document.getElementById(id); if (el) el.textContent = val; };
  setIfEl('fb-submitted-excl', mitoriSubtotal.toLocaleString());
  setIfEl('fb-submitted',      submittedTotalIncl.toLocaleString());
  setIfEl('fb-final-excl',     finalExcl.toLocaleString());
  setIfEl('fb-final',          finalTotalIncl.toLocaleString());
  // 緑ボックス内の 5行 合計テーブル(印刷の totals-mitori と同じ値)
  setIfEl('subtotal-mitori-fb', mitoriSubtotal.toLocaleString());
  setIfEl('tax-mitori-fb', mitoriTax.toLocaleString());
  setIfEl('total-mitori-fb', (mitoriTotal + mitoriTax).toLocaleString());
  const nebikiLineFb = document.getElementById('nebiki-line-fb');
  const aftLineFb = document.getElementById('aftnebiki-line-fb');
  if (nebikiLineFb && aftLineFb) {
    if (nebiki > 0) {
      nebikiLineFb.style.display = '';
      aftLineFb.style.display = '';
      setIfEl('nebiki-amt-fb', nebiki.toLocaleString());
      setIfEl('subtotal-after-nebiki-fb', mitoriTotal.toLocaleString());
    } else {
      nebikiLineFb.style.display = 'none';
      aftLineFb.style.display = 'none';
    }
  }
  // 減工事行表示制御
  const fbReducedLine = document.getElementById('fb-reduced-line');
  if (fbReducedLine) {
    if (reducedAmt > 0) {
      fbReducedLine.style.display = '';
      setIfEl('fb-reduced-excl', '−' + reducedAmt.toLocaleString());
      setIfEl('fb-reduced',      '−' + reducedAmtIncl.toLocaleString());
    } else fbReducedLine.style.display = 'none';
  }
  // 値引行表示制御
  const fbNebikiLine = document.getElementById('fb-nebiki-line');
  if (fbNebikiLine) {
    if (nebiki > 0) {
      fbNebikiLine.style.display = '';
      setIfEl('fb-nebiki-excl', '−' + nebiki.toLocaleString());
      setIfEl('fb-nebiki',      '−' + nebikiIncl.toLocaleString());
    } else fbNebikiLine.style.display = 'none';
  }

  // 減工事サマリーは確定請求金額ボックスに統合済 → 値だけ更新、表示はしない
  const reducedLines = state.estimate.lines.filter(l => l.reduced);
  if (reducedLines.length > 0) {
    const submittedTotal = state.estimate.lines.reduce((s,l)=>s+lineAmount(l,'estimate'),0);
    const reducedAmount = reducedLines.reduce((s,l)=>s+lineAmount(l,'estimate'),0);
    const actualTotal = submittedTotal - reducedAmount;
    const setIf2 = (id, v) => { const el = document.getElementById(id); if (el) el.textContent = v; };
    setIf2('reduce-submitted', submittedTotal.toLocaleString());
    setIf2('reduce-actual', actualTotal.toLocaleString());
    setIf2('reduce-diff', '-' + reducedAmount.toLocaleString());
    setIf2('reduce-count', `(減工事 ${reducedLines.length}行)`);
  }

  // 提出用3見積サマリー
  const lines = state.estimate.lines;
  const ownerTotal  = lines.filter(l => effectiveBurdenType(l) === '家主').reduce((s,l)=>s+lineAmount(l,'estimate'),0);
  const tenantTotal = lines.filter(l => effectiveBurdenType(l) === '入居者').reduce((s,l)=>s+lineAmount(l,'estimate'),0);
  const selfTotal   = lines.filter(l => effectiveBurdenType(l) === '自社のみ').reduce((s,l)=>s+lineAmount(l,'estimate'),0);
  const jishaTotal  = ownerTotal + tenantTotal + selfTotal;
  // 元請けルール適用(家主見積の倍率 + 自動諸経費)
  const rule = getMotoukeRule();
  // 家主見積 base: 各行の yanushiAmt(手入力)優先、無ければ amt × yanushiMarkup
  const yanushiBase = lines
    .filter(l => effectiveBurdenType(l) === '家主')
    .reduce((s,l) => s + effectiveYanushiAmt(l, rule), 0);
  // 入居者見積 base: 各行の tenantAmt(手入力)優先、無ければ amt × 1.2
  const tenantBase  = lines
    .filter(l => effectiveBurdenType(l) === '入居者')
    .reduce((s,l) => s + effectiveTenantAmt(l), 0);
  // 産廃諸経費: 元請けルール未設定なら 5% をデフォルト適用
  const shoKeihiRate = (rule.autoShoKeihiRate && rule.autoShoKeihiRate > 0) ? rule.autoShoKeihiRate : 0.05;
  const shoKeihi    = Math.round(jishaTotal * shoKeihiRate);
  const yanushiTotal = yanushiBase + shoKeihi;
  // 入居者見積(契約種別判定)
  const taikyo = state.estimate.meta.taikyo || {};
  const isCorp = taikyo.contractorType === '法人';
  // 宛名ラベル
  const motoName = state.estimate.meta.motouke || '';
  document.getElementById('triple-motouke-label').textContent =
    `元請け: ${motoName || '(未設定)'} / 家主倍率: ×${(rule.yanushiMarkup||1).toFixed(2)}${rule.autoShoKeihiRate?` +諸経費${Math.round(rule.autoShoKeihiRate*100)}%`:''}`;
  // タイトルに元請け名を反映
  const titleEl = document.getElementById('triple-summary-title');
  if (titleEl) {
    titleEl.textContent = motoName ? `${motoName}見積サマリー` : '自社見積サマリー';
  }
  // 自社
  document.getElementById('memo-owner').textContent = ownerTotal.toLocaleString();
  document.getElementById('memo-tenant').textContent = tenantTotal.toLocaleString();
  document.getElementById('memo-selfonly').textContent = selfTotal.toLocaleString();
  document.getElementById('memo-jisha').textContent = jishaTotal.toLocaleString();

  // 元請け発注額 入力値と一致チェック
  const motoukeInp = document.getElementById('memo-motouke-order');
  const orderCheckEl = document.getElementById('memo-order-check');
  const meta = state.estimate.meta || {};
  if (motoukeInp) {
    // 入力中はvalueを弄らない
    if (document.activeElement !== motoukeInp) {
      motoukeInp.value = (meta.motoukeOrderAmount != null) ? fmtNum(meta.motoukeOrderAmount) : '';
    }
  }
  if (orderCheckEl) {
    // 比較対象は常に「見積金額合計(提出時金額)」。減工事は別概念。
    const compareTarget = jishaTotal;
    if (meta.motoukeOrderAmount == null || meta.motoukeOrderAmount === '') {
      orderCheckEl.innerHTML = `<span style="color:#9ca3af;">元請け発注額を入力すると見積金額合計と一致するか自動チェック</span>`;
    } else {
      const diff = Number(meta.motoukeOrderAmount) - compareTarget;
      if (diff === 0) {
        orderCheckEl.innerHTML = `<span style="color:#065f46; font-weight:600;">✅ 見積金額合計と一致 (${compareTarget.toLocaleString()}円)</span>`;
      } else {
        const sign = diff > 0 ? '+' : '';
        orderCheckEl.innerHTML = `<span style="color:#991b1b; font-weight:600;">⚠ 差額 ${sign}${diff.toLocaleString()}円</span> <span style="color:#6b7280;">(見積金額合計: ${compareTarget.toLocaleString()})</span>`;
      }
    }
  }
  // 家主
  document.getElementById('memo-yanushi-markup').textContent = `×${(rule.yanushiMarkup||1).toFixed(2)}`;
  document.getElementById('memo-yanushi-base').textContent = yanushiBase.toLocaleString();
  const shoLine = document.getElementById('memo-shokeihi-line');
  shoLine.style.display = '';
  document.getElementById('memo-shokeihi-rate').textContent = `${Math.round(shoKeihiRate*100)}%`;
  document.getElementById('memo-shokeihi-baseamt').textContent = jishaTotal.toLocaleString();
  document.getElementById('memo-shokeihi').textContent = shoKeihi.toLocaleString();
  document.getElementById('memo-yanushi').textContent = yanushiTotal.toLocaleString();
  // 入居者
  document.getElementById('memo-nyukyosha').textContent = tenantBase.toLocaleString();
  document.getElementById('memo-nyukyosha-kind').textContent = isCorp ? '(法人契約・PDF必須)' : '(個人契約)';
  const nyuDetail = document.getElementById('memo-nyukyosha-detail');
  if (isCorp) {
    const daiko = taikyo.daikoCorp || '';
    const corp = taikyo.corpName || '';
    const contractNo = taikyo.contractNumber || '';
    nyuDetail.innerHTML = daiko
      ? `宛先: ${escapeHtml(daiko)} 御中<br>契約法人: ${escapeHtml(corp)}${contractNo?' ('+escapeHtml(contractNo)+')':''}`
      : `宛先: ${escapeHtml(corp)} 御中`;
  } else {
    nyuDetail.textContent = taikyo.contractorName ? `宛先: ${taikyo.contractorName} 様` : '入居者負担行のみ';
  }
  // ボタン有効/無効
  const btnNyu = document.getElementById('btn-print-nyukyosha');
  if (btnNyu) {
    const hasTenantLines = tenantTotal > 0;
    btnNyu.disabled = !hasTenantLines;
    btnNyu.title = hasTenantLines
      ? (isCorp ? '法人契約: 代行会社/法人宛の見積書PDFを作成' : '入居者負担行のみのPDFを作成')
      : '入居者負担行がありません';
    btnNyu.style.opacity = hasTenantLines ? '1' : '0.5';
  }

  // 各行の家主金額・入居者金額 input を更新(編集ビュー専用、印刷には出ない)
  // 値ルール: row.yanushiAmt / row.tenantAmt が数値なら手入力値、
  //         未定義ならマスタ(家主単価/入居者単価)列、それも無ければ自社×倍率でplaceholder表示
  const ymk = rule.yanushiMarkup || 1;
  const TENANT_DEFAULT_MK = 1.2;
  const tbody = document.getElementById('estimate-tbody');
  if (tbody) {
    tbody.querySelectorAll('tr[data-i]').forEach(tr => {
      const idx = Number(tr.dataset.i);
      const l = state.estimate.lines[idx];
      if (!l) return;
      const amt = lineAmount(l, 'estimate');
      const bt = l.burdenType || '家主';
      const yInp = tr.querySelector('input[data-f="yanushiAmt"]');
      const tInp = tr.querySelector('input[data-f="tenantAmt"]');
      // マスタ値優先、無ければfallback
      const yFromMaster = _masterAmount(l, '家主単価');
      const tFromMaster = _masterAmount(l, '入居者単価');
      const yAuto = yFromMaster != null ? yFromMaster : Math.round(amt * ymk);
      const tAuto = tFromMaster != null ? tFromMaster : Math.round(amt * TENANT_DEFAULT_MK);
      // 家主金額列: bt==='家主' の時だけアクティブ、それ以外は対象外
      if (yInp) {
        const isY = (bt === '家主');
        const hasOverride = isY && l.yanushiAmt !== undefined && l.yanushiAmt !== null && l.yanushiAmt !== '';
        if (hasOverride) {
          if (document.activeElement !== yInp) yInp.value = fmtNum(l.yanushiAmt);
          yInp.placeholder = '';
          yInp.style.color = '#7c2d12';
          yInp.style.fontWeight = 'bold';
          yInp.disabled = false;
        } else {
          if (document.activeElement !== yInp) yInp.value = '';
          yInp.placeholder = isY ? yAuto.toLocaleString() : '対象外';
          yInp.style.color = isY ? '#7c2d12' : '#aaa';
          yInp.style.fontWeight = 'normal';
          yInp.disabled = !isY; // 対象外はグレーアウト
        }
      }
      // 入居者金額列: bt==='入居者' の時だけアクティブ、それ以外は対象外
      if (tInp) {
        const isT = (bt === '入居者');
        const hasOverride = isT && l.tenantAmt !== undefined && l.tenantAmt !== null && l.tenantAmt !== '';
        if (hasOverride) {
          if (document.activeElement !== tInp) tInp.value = fmtNum(l.tenantAmt);
          tInp.placeholder = '';
          tInp.style.color = '#1e3a8a';
          tInp.style.fontWeight = 'bold';
          tInp.disabled = false;
        } else {
          if (document.activeElement !== tInp) tInp.value = '';
          tInp.placeholder = isT ? tAuto.toLocaleString() : '対象外';
          tInp.style.color = isT ? '#1e3a8a' : '#aaa';
          tInp.style.fontWeight = 'normal';
          tInp.disabled = !isT;
        }
      }
    });
  }
  // 産廃集計表示
  renderSanpaiSummary();
}

// ステータス関連
const ESTIMATE_STATUSES = ['下書き', '提出済', '減工事あり', '完了', 'キャンセル'];
const STATUS_STYLES = {
  '下書き':     { bg:'#e5e7eb', color:'#374151', icon:'📝' },
  '提出済':     { bg:'#dbeafe', color:'#1e40af', icon:'📤' },
  '減工事あり': { bg:'#fef3c7', color:'#92400e', icon:'🟡' },
  '完了':       { bg:'#d1fae5', color:'#065f46', icon:'✅' },
  'キャンセル': { bg:'#fee2e2', color:'#991b1b', icon:'✖' },
};
// 減工事マークが1つでもあれば自動で「減工事あり」に遷移(ただし 完了/キャンセル は尊重)
function autoUpdateEstimateStatus() {
  const meta = state.estimate?.meta;
  if (!meta) return;
  if (meta.status === '完了' || meta.status === 'キャンセル') return;
  const hasReduced = state.estimate.lines.some(l => l.reduced);
  if (hasReduced && meta.status !== '減工事あり') {
    meta.status = '減工事あり';
  } else if (!hasReduced && meta.status === '減工事あり') {
    // 全部解除された → 提出済(または下書き)に戻す
    meta.status = meta.submittedAt ? '提出済' : '下書き';
  }
}
// ステータスバッジを再描画
function renderStatusBadge() {
  const badge = document.getElementById('status-badge');
  if (!badge) return;
  const meta = state.estimate?.meta || {};
  const st = meta.status || '下書き';
  const s = STATUS_STYLES[st] || STATUS_STYLES['下書き'];
  badge.style.background = s.bg;
  badge.style.color = s.color;
  const subInfo = meta.submittedAt ? ` (提出: ${meta.submittedAt})` : '';
  badge.innerHTML = `${s.icon} ${escapeHtml(st)}${subInfo}`;
}
// ステータス変更メニュー
function openStatusMenu() {
  const meta = state.estimate?.meta;
  if (!meta) return;
  const current = meta.status || '下書き';
  const options = ESTIMATE_STATUSES.map(s => `${s === current ? '◉' : '○'} ${s}`);
  const msg = `現在: ${current}\n\n変更先を選んでください:\n${options.map((o,i)=>`${i+1}. ${o}`).join('\n')}`;
  const input = prompt(msg + '\n\n番号を入力 (1-5):', '');
  if (!input) return;
  const idx = Number(input) - 1;
  if (idx < 0 || idx >= ESTIMATE_STATUSES.length) { showToast('無効な番号', true); return; }
  const newStatus = ESTIMATE_STATUSES[idx];
  meta.status = newStatus;
  // 提出済に変える時は提出日を今日でセット(未入力なら)
  if (newStatus === '提出済' && !meta.submittedAt) {
    meta.submittedAt = formatToday();
  }
  // 完了に変える時は完了日
  if (newStatus === '完了' && !meta.completedAt) {
    meta.completedAt = formatToday();
  }
  saveEstimate();
  renderStatusBadge();
  renderTotals();
  renderLedger && renderLedger();
  showToast(`ステータスを「${newStatus}」に変更しました`);
}

// 元請けルール取得(settings.motoukeRules から)
function getMotoukeRule() {
  const moto = state.estimate?.meta?.motouke || '';
  const rules = state.settings?.motoukeRules || {};
  return rules[moto] || { yanushiMarkup: 1.0, autoShoKeihiRate: 0 };
}

// マスタ行の取得(itemRef → master row)
function _getMasterRowForLine(l) {
  if (!l || !l.itemRef) return null;
  return state.master.find(m => String(m.項目番号) === String(l.itemRef)) || null;
}
// マスタの該当列の値を「単価 × 数量」で返す(数値ならOK、無ければnull)
function _masterAmount(l, colName) {
  const m = _getMasterRowForLine(l);
  if (!m) return null;
  const v = m[colName];
  if (v == null || v === '') return null;
  const unitPrice = Number(v);
  if (!Number.isFinite(unitPrice)) return null;
  const qty = Number(l.qty) || 0;
  return Math.round(unitPrice * qty);
}

// 家主金額: 手入力上書き > マスタ「家主単価」列 > 自社×元請けルール倍率(fallback)
// 産廃集計: 見積全行のマスタから産廃品目×数量を集計
// 既知の産廃品目名リスト(マスタの異常値をフィルタ)
const VALID_SANPAI_NAMES = new Set(['混合廃棄物','廃プラスチック類','廃プラ','がれき類','金属くず','木くず','紙くず','ガラスくず','コンクリートがら']);
function calcSanpaiSum(lines) {
  const byName = {}; // name -> {sum, rows}
  const details = []; // 行ごとの内訳 {category, item, room, qty, unit, sanpaiName, sanpaiQty, total}
  (lines || []).forEach((l, idx) => {
    if (l.reduced) return;
    if (!l.itemRef) return;
    const m = state.master.find(x => String(x.項目番号) === String(l.itemRef));
    if (!m) return;
    const name = m['産廃品目'];
    const per = Number(m['産廃数量']);
    if (!name || !VALID_SANPAI_NAMES.has(name)) return;
    if (!Number.isFinite(per) || per <= 0 || per > 10) return;
    const qty = Number(l.qty) || 0;
    if (qty <= 0) return;
    const rowTotal = per * qty;
    if (!byName[name]) byName[name] = { sum: 0, rows: 0 };
    byName[name].sum += rowTotal;
    byName[name].rows += 1;
    details.push({
      lineIdx: idx,
      category: l.category || '',
      item: l.item || '',
      room: l.room || '',
      qty, unit: l.unit || '',
      sanpaiName: name,
      sanpaiQty: per,
      rowTotal,
    });
  });
  const total = Object.values(byName).reduce((s, v) => s + v.sum, 0);
  return { byName, total, details };
}
function renderSanpaiSummary() {
  const el = document.getElementById('sanpai-summary');
  const bdEl = document.getElementById('sanpai-breakdown');
  const totalEl = document.getElementById('sanpai-total');
  const detailEl = document.getElementById('sanpai-detail');
  if (!el || !totalEl) return;
  const { byName, total, details } = calcSanpaiSum(state.estimate?.lines || []);
  if (total <= 0) {
    if (bdEl) bdEl.innerHTML = '<span style="color:#999;">(対象行なし)</span>';
    totalEl.textContent = '0';
    if (detailEl) detailEl.innerHTML = '<div style="padding:10px; color:#999;">対象行なし</div>';
    return;
  }
  const parts = Object.entries(byName).sort((a,b) => b[1].sum - a[1].sum).map(([name, v]) =>
    `<span style="margin-right:12px;">${escapeHtml(name)}: <b>${v.sum.toFixed(4)}</b>㎥ <small style="color:#999;">(${v.rows}行)</small></span>`
  );
  if (bdEl) bdEl.innerHTML = parts.join('');
  totalEl.textContent = total.toFixed(4);
  // 内訳テーブル
  if (detailEl) {
    // 金額大きい順(rowTotal 降順)
    const sorted = details.slice().sort((a, b) => b.rowTotal - a.rowTotal);
    detailEl.innerHTML = `
      <table style="width:100%; border-collapse:collapse; font-size:11.5px;">
        <thead style="background:#fde68a; position:sticky; top:0;">
          <tr>
            <th style="text-align:left; padding:4px 8px;">#</th>
            <th style="text-align:left; padding:4px 8px;">カテゴリー</th>
            <th style="text-align:left; padding:4px 8px;">工事名称</th>
            <th style="text-align:left; padding:4px 8px;">室名</th>
            <th style="text-align:right; padding:4px 8px;">数量</th>
            <th style="text-align:left; padding:4px 8px;">単位</th>
            <th style="text-align:left; padding:4px 8px;">産廃品目</th>
            <th style="text-align:right; padding:4px 8px;">1単位あたり(㎥)</th>
            <th style="text-align:right; padding:4px 8px;">合計(㎥)</th>
          </tr>
        </thead>
        <tbody>
        ${sorted.map((d, i) => `
          <tr style="border-top:1px solid #fde68a;">
            <td style="padding:3px 8px; color:#999;">${i+1}</td>
            <td style="padding:3px 8px;">${escapeHtml(d.category)}</td>
            <td style="padding:3px 8px;">${escapeHtml(d.item)}</td>
            <td style="padding:3px 8px;">${escapeHtml(d.room)}</td>
            <td style="padding:3px 8px; text-align:right;">${d.qty}</td>
            <td style="padding:3px 8px;">${escapeHtml(d.unit)}</td>
            <td style="padding:3px 8px;">${escapeHtml(d.sanpaiName)}</td>
            <td style="padding:3px 8px; text-align:right; color:#666;">${d.sanpaiQty}</td>
            <td style="padding:3px 8px; text-align:right; font-weight:600;">${d.rowTotal.toFixed(4)}</td>
          </tr>
        `).join('')}
        </tbody>
      </table>`;
  }
}

function effectiveYanushiAmt(l, rule) {
  if (l.yanushiAmt !== undefined && l.yanushiAmt !== null && l.yanushiAmt !== '') {
    return Number(l.yanushiAmt) || 0;
  }
  const fromMaster = _masterAmount(l, '家主単価');
  if (fromMaster != null) return fromMaster;
  const r = rule || getMotoukeRule();
  return Math.round(lineAmount(l, 'estimate') * (r.yanushiMarkup || 1));
}
// 負担区分 既定値: HC・エアコン高圧洗浄/クリーニングは入居者、それ以外は家主
function defaultBurdenType(l) {
  const it = l.item || '';
  if (/ハウスクリーニング|エアコン高圧洗浄|エアコンクリーニング/.test(it)) return '入居者';
  return '家主';
}
// 実効負担区分 (line.burdenType > defaultBurdenType)
function effectiveBurdenType(l) {
  if (l.burdenType === '家主' || l.burdenType === '入居者' || l.burdenType === '自社のみ') return l.burdenType;
  return defaultBurdenType(l);
}
// 入居者金額: 手入力上書き > マスタ「入居者単価」列 > 自社×1.2(fallback)
function effectiveTenantAmt(l) {
  if (l.tenantAmt !== undefined && l.tenantAmt !== null && l.tenantAmt !== '') {
    return Number(l.tenantAmt) || 0;
  }
  const fromMaster = _masterAmount(l, '入居者単価');
  if (fromMaster != null) return fromMaster;
  return Math.round(lineAmount(l, 'estimate') * 1.2);
}

function formatJpDate(iso) {
  // 2026-04-19 -> 令和8年4月19日
  const m = /^(\d{4})-(\d{2})-(\d{2})$/.exec(iso || '');
  if (!m) return iso || '';
  const y = Number(m[1]), mo = Number(m[2]), d = Number(m[3]);
  // 令和開始: 2019年5月1日 → 令和元年。y以降は y-2018
  let era = '', eyear = y;
  if (y >= 2019) { era = '令和'; eyear = y - 2018; }
  else if (y >= 1989) { era = '平成'; eyear = y - 1988; }
  else era = String(y);
  return `${era}${eyear}年${mo}月${d}日`;
}
function renderPrintMeta() {
