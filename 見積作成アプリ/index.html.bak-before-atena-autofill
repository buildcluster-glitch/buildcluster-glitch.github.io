function categorySelect(current, rowIndex) {
  const cats = uniqueCategories();
  const knownMinors = new Set(CATEGORY_GROUPS.flatMap(g => g.minors));
  const unknownCats = cats.filter(c => !knownMinors.has(c));
  if (current && !cats.includes(current) && !unknownCats.includes(current)) unknownCats.unshift(current);

  // datalist は optgroup 非対応なので、プレフィックスで分類を示すか、単純にフラットに列挙
  const listId = `cats-${rowIndex == null ? 'x' : rowIndex}`;
  const options = [];
  CATEGORY_GROUPS.forEach(g => {
    g.minors.filter(m => cats.includes(m)).forEach(m => {
      options.push(`<option value="${escapeHtml(m)}">${escapeHtml(g.major)} / ${escapeHtml(m)}</option>`);
    });
  });
  unknownCats.forEach(m => options.push(`<option value="${escapeHtml(m)}">未分類 / ${escapeHtml(m)}</option>`));
  return `<input type="text" data-f="category" list="${listId}" value="${escapeHtml(current||'')}" placeholder="カテゴリー">
    <datalist id="${listId}">${options.join('')}</datalist>`;
}
