  await renderSuidoPdfBackground(templateKey);
  renderSuidoOverlays(templateKey, getSuidoFormData());
  const sheet = document.getElementById('suido-sheet');
  sheet.classList.add('preview-mode');
  const wrap = document.getElementById('suido-canvas-wrap');
  const vh = window.innerHeight - 60;
  const pageHeightPx = 297 * 96 / 25.4;
  const scale = Math.min(1, vh / pageHeightPx);
  wrap.style.transform = `scale(${scale})`;
  wrap.style.marginBottom = `${pageHeightPx * (1 - scale)}px`;
  // オーバーレイを点線で囲む(位置調整しやすく)
