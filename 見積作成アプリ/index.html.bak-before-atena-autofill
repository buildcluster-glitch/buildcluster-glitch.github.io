// 工期("M/D" 形式)の開始・終了を印刷用にまとめる
// 例: "10/9", "10/15" → "10/9 〜15"
// 例: "10/28", "11/3" → "10/28 〜11/3"
// 例: "10/9", "" → "10/9"
// ビルドクラスタ(自社工事)の最早工事開始日 (M/D 形式)
function jishaEarliestStart() {
  const lines = state.estimate?.lines || [];
  let best = null; // { m, d }
  lines.forEach(l => {
    if (!l.item || l.reduced) return;
    if (!isJishaLine(l)) return;
    const p = parseMonthDay(l.hatchuPeriodStart);
    if (!p.m || !p.d) return;
    const key = Number(p.m) * 100 + Number(p.d);
    if (!best || key < best.key) best = { m: p.m, d: p.d, key };
  });
  return best ? `${best.m}/${best.d}` : '';
}

function formatHatchuPeriod(start, end) {
  const sp = parseMonthDay(start);
  const ep = parseMonthDay(end);
  const sStr = (sp.m && sp.d) ? `${sp.m}/${sp.d}` : '';
  const eStr = (ep.m && ep.d) ? `${ep.m}/${ep.d}` : '';
  if (!sStr && !eStr) return '';
  if (sStr && !eStr) return sStr;
  if (!sStr && eStr) return `〜${eStr}`;
  // 同じ月なら終了は日のみ
  if (sp.m === ep.m) return `${sStr} 〜${ep.d}`;
  return `${sStr} 〜${eStr}`;
}

