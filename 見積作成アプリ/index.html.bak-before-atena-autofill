// 内装工事の仕様を「施工面 / 原因 / 資材」に分解してパース
const NAISO_PART_OPTS = ['壁全面','壁東面','壁西面','壁南面','壁北面','壁北面以外','壁東西南北','天井全面','天井一部'];
const NAISO_REASON_OPTS = ['経年変色','クラック','過失(汚損破損)'];
function parseNaisoSpecs(specs) {
  const out = { part: '', reason: '', material: '' };
  if (!specs) return out;
  let remaining = String(specs).trim();
  // 施工面を先頭から探す(長いものから)
  const sortedParts = [...NAISO_PART_OPTS].sort((a,b) => b.length - a.length);
  for (const p of sortedParts) {
    if (remaining.startsWith(p)) {
      out.part = p;
      remaining = remaining.slice(p.length).trim();
      break;
    }
  }
  // 原因
  for (const r of NAISO_REASON_OPTS) {
    if (remaining.startsWith(r)) {
      out.reason = r;
      remaining = remaining.slice(r.length).trim();
      break;
    }
  }
  // 「過失」だけでも過失(汚損破損)として認識
  if (!out.reason && remaining.startsWith('過失')) {
    out.reason = '過失(汚損破損)';
    remaining = remaining.slice(2).trim();
  }
  out.material = remaining;
  return out;
}
function buildNaisoSpecs(parts) {
  return [parts.part, parts.reason, parts.material].filter(Boolean).join(' ').trim();
}

// 内装工事 向け 仕様・摘要セル(施工面・原因・資材 の3構造入力)
