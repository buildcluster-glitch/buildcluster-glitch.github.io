document.getElementById('btn-bukken-import-tsv').addEventListener('click', () => document.getElementById('bukken-file-tsv').click());
document.getElementById('bukken-file-tsv').addEventListener('change', e => {
  const f = e.target.files[0]; if (!f) return;
  const reader = new FileReader();
  reader.onload = () => {
    try {
      const raw = reader.result;
      const lines = raw.split(/\r?\n/);
      const headerIdx = lines.findIndex(l => /^No\.?\t/.test(l));
      if (headerIdx < 0) throw new Error('ヘッダー行(No.タブ始まり)が見つかりません');
      const header = lines[headerIdx].split('\t');
      const hIdx = {};
      header.forEach((h, i) => { if (h.trim()) hIdx[h.trim()] = i; });
      const colVal = (cols, name) => { const i = hIdx[name]; return (i != null && cols[i] != null) ? cols[i].trim() : ''; };
      const items = [];
      lines.slice(headerIdx+1).forEach(ln => {
        if (!ln.trim()) return;
        const cols = ln.split('\t');
        const name = colVal(cols, '物件名');
        if (!name) return;
        items.push({
          no: colVal(cols, 'No.') || colVal(cols, 'No'),
          motouke: (cols[1]||'').trim(),
          name,
          address: colVal(cols, '住所'),
          waterCheck: colVal(cols, '水道検針'),
          notes: colVal(cols, '注意事項'),
          city: colVal(cols, '市'),
          area: colVal(cols, '地名'),
          type: colVal(cols, '区分'),
          parking: colVal(cols, '駐車場'),
          checkDate: colVal(cols, '確認日'),
          denkiApply: colVal(cols, '電気申込'),
          waterApply: colVal(cols, '水道申込'),
          autoLock: colVal(cols, 'オートロック'),
          digiKey: colVal(cols, 'デジキー'),
          loft: colVal(cols, 'ロフト'),
          madori: colVal(cols, '間取り'),
          accent: colVal(cols, 'アクセント'),
          cf: colVal(cols, 'CF'),
          lastWork: colVal(cols, '施工月'),
          memo: colVal(cols, '備考'),
        });
      });
      if (!confirm(`${items.length}件を取り込みます。既存データと置換でOK?(キャンセル=追加マージ)`)) {
        // マージ(物件名で重複チェック)
        items.forEach(it => {
          const idx = state.bukken.findIndex(b => b.name === it.name);
          if (idx >= 0) state.bukken[idx] = { ...state.bukken[idx], ...it };
          else state.bukken.push(it);
