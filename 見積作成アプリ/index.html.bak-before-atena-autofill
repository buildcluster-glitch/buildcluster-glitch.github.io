    else { sealEl.src = ''; sealEl.style.display = 'none'; }
  }
  document.getElementById('print-jisha').textContent = issuer.jishaName || '';
  document.getElementById('print-jisha-addr').textContent = issuer.jishaAddr || '';
  const jTelEl = document.getElementById('print-jisha-tel');
