// キーボードショートカット
document.addEventListener('keydown', e => {
  const tag = (document.activeElement?.tagName || '');
  const isEditing = ['INPUT','TEXTAREA','SELECT'].includes(tag);
  const mod = e.ctrlKey || e.metaKey;

  // Ctrl+Z / Ctrl+Y / Ctrl+Shift+Z は編集中でも常に動く(見積全体のUndo)
  if (mod && e.key.toLowerCase() === 'z' && !e.shiftKey) {
    e.preventDefault();
    if (isEditing) document.activeElement.blur(); // フォーカス外してUndo
    doUndo(); return;
  }
  if (mod && (e.key.toLowerCase() === 'y' || (e.key.toLowerCase() === 'z' && e.shiftKey))) {
    e.preventDefault();
    if (isEditing) document.activeElement.blur();
    doRedo(); return;
  }

  // Copy/Paste/Delete は入力中は無視、チェックが入っている時のみ反応
  if (isEditing) return;
  if (!document.querySelector('#estimate-tbody .row-check:checked')) return;
  if (mod && e.key.toLowerCase() === 'c') {
    e.preventDefault(); copyCheckedRows();
  } else if (mod && e.key.toLowerCase() === 'v') {
    e.preventDefault(); pasteRows();
  } else if (e.key === 'Delete' || e.key === 'Backspace') {
    e.preventDefault(); deleteCheckedRows();
  }
});

function escapeHtml(s) { return String(s ?? '').replace(/[&<>"']/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m])); }

// カスタム確認モーダル(Promise<boolean>を返す) - confirm()代替
function asyncConfirm(title, body, yesLabel, noLabel) {
  return new Promise(resolve => {
    document.getElementById('modal-title').textContent = title || '確認';
    document.getElementById('modal-body').textContent = body || '';
    document.getElementById('modal-btn-yes').textContent = yesLabel || 'はい';
    document.getElementById('modal-btn-no').textContent = noLabel || 'いいえ';
    const overlay = document.getElementById('modal-overlay');
    overlay.style.display = 'flex';
    const yes = document.getElementById('modal-btn-yes');
    const no = document.getElementById('modal-btn-no');
    const close = (v) => {
      overlay.style.display = 'none';
      yes.removeEventListener('click', onYes);
      no.removeEventListener('click', onNo);
      overlay.removeEventListener('click', onBg);
      resolve(v);
    };
    const onYes = () => close(true);
    const onNo = () => close(false);
    const onBg = (e) => { if (e.target === overlay) close(false); };
    yes.addEventListener('click', onYes);
    no.addEventListener('click', onNo);
    overlay.addEventListener('click', onBg);
  });
}

// 数値フォーマット(カンマ区切り)
function fmtNum(n) {
  if (n == null || n === '') return '';
  const num = Number(n);
  if (!Number.isFinite(num)) return '';
  return num.toLocaleString('ja-JP', { maximumFractionDigits: 4 });
}
function parseNum(s) {
  if (s == null) return null;
  const t = String(s).replace(/,/g, '').replace(/\s/g, '').trim();
  if (t === '' || t === '-') return null;
  const n = Number(t);
  return Number.isFinite(n) ? n : null;
}

