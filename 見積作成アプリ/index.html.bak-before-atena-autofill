function applyBukkenToTaikyo() {
  const name = document.getElementById('taikyo-bukken-search').value.trim();
  if (!name) { showToast('物件名を入力してください', true); return; }
  // 完全一致 → 部分一致の順で探す
  let b = state.bukken.find(x => x.name === name);
  if (!b) b = state.bukken.find(x => x.name.includes(name));
  if (!b) { showToast(`物件マスタに「${name}」が見つかりません`, true); return; }
  const est = state.estimate;
  if (!est.meta.taikyo) est.meta.taikyo = emptyTaikyo();
  const t = est.meta.taikyo;
  t.apartmentName = b.name || '';
  t.address = b.address || '';
  // 間取りをデフォルトで物件マスタから引き込む(手入力済みの場合は上書きしない)
  // 優先: madoriDefault > madori の1行目を抽出
  const defaultMadori = b.madoriDefault || (b.madori ? String(b.madori).split(/\r?\n/)[0].trim() : '');
  if (defaultMadori && !t.madori) t.madori = defaultMadori;
  // 間取りをハウスクリーニング行の工事名称に反映
  if (t.madori) syncMadoriToHouseCleaning(t.madori);
  // 営業担当者を反映(物件マスタの tantou/tantouTel)
  if (b.tantou) t.eigyoTantou = b.tantou;
  if (b.tantouTel) t.eigyoTel = b.tantouTel;
  // 立会い・駐車・オートロック等のメモも転記
  const memoPrefix = [];
  if (b.notes) memoPrefix.push(`【注意】${b.notes}`);
  if (b.tantou) memoPrefix.push(`営業担当: ${b.tantou}${b.tantouTel?' ('+b.tantouTel+')':''}`);
  if (b.parking) memoPrefix.push(`駐車場: ${b.parking}`);
  if (b.keyBox) memoPrefix.push(`キーボックス: ${b.keyBox}`);
  if (b.digiKey && b.digiKey !== 'ー') memoPrefix.push(`デジキー: ${b.digiKey}`);
  if (b.autoLock && b.autoLock !== 'ー') memoPrefix.push(`オートロック: ${b.autoLock}`);
  if (b.madoriDefault) memoPrefix.push(`間取り(デフォ): ${b.madoriDefault}`);
  if (b.madori) memoPrefix.push(`間取り(その他): ${b.madori}`);
  if (memoPrefix.length) t.memo = memoPrefix.join('\n');
  // 見積メタへ反映
  est.meta.bukken = b.name || '';
  est.meta.shozaichi = b.address || '';
  // 宛先担当者も自動セット(元請け担当者を見積書宛名の「担当者」に)
  if (b.tantou) est.meta.atenaTantou = `${b.tantou} 様`;
  saveEstimate();
  renderTaikyo();
  syncMetaInputs();
  renderCurrentHeader();
  renderPrintMeta();
  renderEstimate(); // 見積側のHC行に間取りが反映されているので再描画
  showToast(`物件「${b.name}」の情報を取込みました`);
}

