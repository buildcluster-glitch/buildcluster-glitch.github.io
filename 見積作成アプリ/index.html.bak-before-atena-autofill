// build.jsの補正が効かない HC 行パターン: 思綺美装がnull/施工業者が空/はやでん以降に値が入っている
function fixHouseCleaningRow(r) {
  if (r.カテゴリー !== '清掃工事' && r.カテゴリー !== 'ハウスクリーニング') return false;
  const hasShift = (r.思綺美装 == null && (r.はやでん != null || r.ヒラヤマ設備 != null))
    || (r.数量 != null && Number(r.数量) >= 1000)
    || (r.室名 && !isNaN(Number(r.室名)));
  if (!hasShift) return false;
  // 1列右シフト戻し
  r.思綺美装 = r.はやでん;
  r.こころ = r.ヒラヤマ設備;
  r.ハルノデザイン = r.クマガイハウス工業;
  r.ムラカベ = r.材料費 != null && !isNaN(Number(r.材料費)) ? Number(r.材料費) : null;
  r.OMsONE = r.室名 && !isNaN(Number(r.室名)) ? Number(r.室名) : null;
  r.FKKMOTORS = r.数量 != null && !isNaN(Number(r.数量)) && Number(r.数量) >= 100 ? Number(r.数量) : null;
  // シフト元をクリアして、正しい位置へ
  r.はやでん = null;
  r.ヒラヤマ設備 = null;
  r.クマガイハウス工業 = null;
  r.材料費 = null;
  r.室名 = '全室';
  r.数量 = 1;
  // 粗利/備考/産廃品目/産廃数量 は元データが空なのでそのまま
  return true;
}

