// フィールドドラッグ処理
function attachSuidoDragHandlers(templateKey) {
  const wrap = document.getElementById('suido-canvas-wrap');
  const overlays = wrap.querySelectorAll('.suido-overlay');
  overlays.forEach(el => {
    el.addEventListener('mousedown', e => {
      e.preventDefault();
      const key = el.dataset.suidoField;
      const rect = wrap.getBoundingClientRect();
      const startX = e.clientX, startY = e.clientY;
      const startLeft = parseFloat(el.style.left);
      const startTop = parseFloat(el.style.top);
      const onMove = (ev) => {
        const dx = (ev.clientX - startX) / rect.width * 100;
        const dy = (ev.clientY - startY) / rect.height * 100;
        const newLeft = Math.max(0, Math.min(100, startLeft + dx));
        const newTop = Math.max(0, Math.min(100, startTop + dy));
        el.style.left = newLeft + '%';
        el.style.top = newTop + '%';
      };
      const onUp = (ev) => {
        document.removeEventListener('mousemove', onMove);
        document.removeEventListener('mouseup', onUp);
        const newLeft = parseFloat(el.style.left);
        const newTop = parseFloat(el.style.top);
        // 保存
        const all = loadSuidoPositions();
        if (!all[templateKey]) all[templateKey] = {};
        if (!all[templateKey][key]) all[templateKey][key] = {};
        all[templateKey][key].left = Number(newLeft.toFixed(2));
        all[templateKey][key].top = Number(newTop.toFixed(2));
        saveSuidoPositions(all);
      };
      document.addEventListener('mousemove', onMove);
      document.addEventListener('mouseup', onUp);
    });
  });
}

