// 発注書PDF vs 見積 比較機能
// =========================
// PDFからテキスト抽出
async function extractPdfText(file) {
  if (!window.pdfjsLib) throw new Error('pdf.js が読み込まれていません');
  const bytes = new Uint8Array(await file.arrayBuffer());
  const pdf = await pdfjsLib.getDocument({ data: bytes }).promise;
  const pages = [];
  for (let p = 1; p <= pdf.numPages; p++) {
    const page = await pdf.getPage(p);
    const content = await page.getTextContent();
    // 座標ベースに行ごとにまとめる(yが近いtextは同じ行)
    const items = content.items.map(i => ({ str: i.str, x: i.transform[4], y: i.transform[5] }));
    items.sort((a, b) => (b.y - a.y) || (a.x - b.x));
    const lines = [];
    let curY = null, curLine = [];
    for (const it of items) {
      if (curY == null || Math.abs(it.y - curY) > 3) {
        if (curLine.length) lines.push(curLine.map(x => x.str).join(' '));
        curLine = [it];
        curY = it.y;
      } else {
        curLine.push(it);
      }
    }
    if (curLine.length) lines.push(curLine.map(x => x.str).join(' '));
    pages.push(lines.join('\n'));
  }
  return pages.join('\n---\n');
}

// テキストから発注書の明細を抽出(ベストエフォート)
// 各行を見て、「数量・単位・金額らしきもの+項目名」を抽出
function parseOrderItems(text) {
  const lines = text.split(/\r?\n/).map(l => l.trim()).filter(Boolean);
  const items = [];
  // 金額らしき数字パターン(カンマ区切り or 連続数字で 3桁以上)
  const moneyRe = /([0-9]{1,3}(?:,[0-9]{3})+|[0-9]{3,})(?=\s*円?$|\s|¥|￥)/g;
  const qtyUnitRe = /\b([0-9]+(?:\.[0-9]+)?)\s*(式|㎡|m²|m2|個|台|箇所|枚|本|回|日|時間|組|セット|ヵ所|か所|カ所)\b/;
  const skipWords = ['合計','小計','消費税','税抜','税込','総額','御見積','御発注','発注書','見積書','件名','工事名称','発行日','No\\.','番号','様','御中','TEL','FAX','担当','物件','単価','数量','単位','金額'];
  for (const line of lines) {
    // ヘッダ・フッタっぽい行はスキップ
    if (line.length < 3) continue;
    if (skipWords.some(w => line.includes(w)) && !/\d/.test(line.replace(/[^0-9]/g,''))) continue;
    // 金額を抽出
    const moneyMatches = [...line.matchAll(moneyRe)].map(m => parseInt(m[1].replace(/,/g,''),10)).filter(n => n >= 100 && n <= 100000000);
    if (!moneyMatches.length) continue;
    const amount = moneyMatches[moneyMatches.length - 1]; // 行末の金額を合計とみなす
    // 数量・単位
    let qty = 1, unit = '';
    const qm = line.match(qtyUnitRe);
    if (qm) { qty = Number(qm[1]); unit = qm[2]; }
    // 項目名 = 数字や単位を除去した残り
    let name = line;
    [...line.matchAll(moneyRe)].forEach(m => { name = name.replace(m[0], ''); });
    if (qm) name = name.replace(qm[0], '');
    name = name.replace(/[¥￥,円]/g,'').replace(/\s+/g,' ').trim();
    // 項目名が空 or 短すぎるならスキップ
    if (!name || name.length < 2) continue;
    items.push({ name, qty, unit, amount, rawLine: line });
  }
  return items;
}

// 文字列類似度(0-1)シンプル版: 共通部分文字列ベース
function stringSimilarity(a, b) {
  if (!a || !b) return 0;
  const na = a.replace(/\s/g,'').toLowerCase();
  const nb = b.replace(/\s/g,'').toLowerCase();
  if (na === nb) return 1;
  if (na.includes(nb) || nb.includes(na)) return 0.85;
  // bigram Jaccard
  const bigrams = s => {
    const set = new Set();
    for (let i = 0; i < s.length - 1; i++) set.add(s.slice(i, i+2));
    return set;
  };
  const A = bigrams(na), B = bigrams(nb);
  if (!A.size || !B.size) return 0;
  let inter = 0;
  A.forEach(x => { if (B.has(x)) inter++; });
  return inter / (A.size + B.size - inter);
}

// 見積行 vs 発注書項目 をマッチング
function matchEstimateToOrder(estLines, orderItems) {
  const results = [];
  const usedOrderIdx = new Set();
  estLines.forEach((l, i) => {
    if (!l.item && !l.unitPrice) return; // 空行スキップ
    const amt = lineAmount(l, 'estimate');
    let best = null;
    orderItems.forEach((o, j) => {
      if (usedOrderIdx.has(j)) return;
      const nameSim = stringSimilarity(l.item || '', o.name);
      const amtMatch = (o.amount === amt) ? 1 : (Math.abs(o.amount - amt) / Math.max(amt, 1) < 0.05 ? 0.7 : 0);
      // スコア = 名前0.6 + 金額0.4
      const score = nameSim * 0.6 + amtMatch * 0.4;
      if (!best || score > best.score) best = { idx: j, order: o, score, nameSim, amtMatch };
    });
    let verdict;
    if (!best || best.score < 0.3) verdict = 'missing'; // 発注書に無い
    else if (best.score >= 0.75 && best.amtMatch === 1) verdict = 'match';
    else if (best.score >= 0.5 && best.amtMatch < 1) verdict = 'price_diff';
    else verdict = 'partial';
    if (best && verdict !== 'missing') usedOrderIdx.add(best.idx);
    results.push({ lineIdx: i, line: l, match: best, verdict });
  });
  // 発注書にだけある項目
  const unmatched = orderItems.filter((_, j) => !usedOrderIdx.has(j));
  return { results, unmatched };
}

// 結果モーダルを表示
function showComparisonResult(results, unmatched) {
  const ov = document.createElement('div');
  ov.style.cssText = 'position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:10001; display:flex; align-items:center; justify-content:center;';
  const box = document.createElement('div');
  box.style.cssText = 'background:#fff; padding:20px; border-radius:8px; max-width:90vw; max-height:90vh; overflow:auto; width:900px;';
  // 集計
  const counts = { match:0, price_diff:0, missing:0, partial:0 };
  results.forEach(r => counts[r.verdict]++);
  const badge = (v) => {
    const map = {
      match:     { t:'✅ 一致', c:'#065f46', bg:'#d1fae5' },
      price_diff:{ t:'⚠ 金額差', c:'#92400e', bg:'#fef3c7' },
      missing:   { t:'❌ 発注書に無し', c:'#991b1b', bg:'#fee2e2' },
      partial:   { t:'❓ 不明', c:'#3730a3', bg:'#e0e7ff' },
    };
    const m = map[v] || map.partial;
    return `<span style="display:inline-block; padding:2px 8px; border-radius:10px; font-size:11px; font-weight:600; background:${m.bg}; color:${m.c};">${m.t}</span>`;
  };
  const rowsHtml = results.map(r => {
    const amt = lineAmount(r.line, 'estimate');
    const oAmt = r.match?.order?.amount;
    const oName = r.match?.order?.name || '-';
    return `<tr data-line-idx="${r.lineIdx}">
      <td style="padding:4px; border-bottom:1px solid #eee;">${escapeHtml(r.line.item||'(無題)')}<br><small style="color:#6b7280;">${escapeHtml(r.line.category||'')}</small></td>
      <td style="padding:4px; border-bottom:1px solid #eee; text-align:right;">${amt.toLocaleString()}</td>
      <td style="padding:4px; border-bottom:1px solid #eee;">${escapeHtml(oName)}${r.match?`<br><small style="color:#6b7280;">類似度 ${Math.round(r.match.nameSim*100)}%</small>`:''}</td>
      <td style="padding:4px; border-bottom:1px solid #eee; text-align:right;">${oAmt != null ? oAmt.toLocaleString() : '-'}</td>
      <td style="padding:4px; border-bottom:1px solid #eee;">${badge(r.verdict)}</td>
      <td style="padding:4px; border-bottom:1px solid #eee;">
        ${r.verdict === 'missing' ? `<button class="btn-mark-reduce" data-line-idx="${r.lineIdx}" style="font-size:11px; background:#fef3c7; border:1px solid #f59e0b;">➖ 減工事にする</button>` : ''}
      </td>
    </tr>`;
  }).join('');
  const unmatchedHtml = unmatched.length
    ? `<h4 style="margin-top:16px;">📌 発注書にだけある項目 (${unmatched.length}件)</h4>
       <div style="font-size:12px; color:#6b7280; margin-bottom:4px;">※ 見積に含まれていない = 元請け側で追加された項目かもしれません</div>
       <ul style="font-size:12px;">${unmatched.map(u => `<li>${escapeHtml(u.name)} — ${u.amount.toLocaleString()}円${u.qty>1?` (${u.qty}${u.unit})`:''}</li>`).join('')}</ul>`
    : '';
  box.innerHTML = `
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px;">
      <h3 style="margin:0;">📄 発注書 vs 見積 比較結果</h3>
      <button type="button" id="cmp-close" style="font-size:14px;">×</button>
    </div>
    <div style="display:flex; gap:16px; margin-bottom:12px; font-size:13px;">
      <span>✅ 一致: <b>${counts.match}</b>件</span>
      <span>⚠ 金額差: <b>${counts.price_diff}</b>件</span>
      <span>❌ 発注書に無し: <b style="color:#991b1b;">${counts.missing}</b>件</span>
      <span>❓ 不明: <b>${counts.partial}</b>件</span>
      ${counts.missing > 0 ? `<button type="button" id="cmp-mark-all" style="margin-left:auto; background:#fef3c7; border:1px solid #f59e0b;">❌の${counts.missing}件を一括で減工事にする</button>` : ''}
    </div>
    <table style="width:100%; border-collapse:collapse; font-size:12px;">
      <thead><tr style="background:#f3f4f6;"><th style="text-align:left; padding:6px;">見積項目</th><th style="text-align:right; padding:6px;">金額</th><th style="text-align:left; padding:6px;">発注書対応</th><th style="text-align:right; padding:6px;">金額</th><th style="padding:6px;">判定</th><th style="padding:6px;">操作</th></tr></thead>
      <tbody>${rowsHtml}</tbody>
    </table>
    ${unmatchedHtml}`;
  ov.appendChild(box);
  document.body.appendChild(ov);

  // 閉じる
  const close = () => { document.body.removeChild(ov); };
  box.querySelector('#cmp-close').onclick = close;
  ov.addEventListener('click', e => { if (e.target === ov) close(); });
  // 個別 減工事にする
  box.querySelectorAll('.btn-mark-reduce').forEach(btn => {
    btn.addEventListener('click', e => {
      const idx = Number(e.target.dataset.lineIdx);
      const line = state.estimate.lines[idx];
      if (line) {
        line.reduced = true;
        autoUpdateEstimateStatus();
        saveEstimate();
        renderEstimate();
        btn.textContent = '✅ マーク済';
        btn.disabled = true;
        btn.style.opacity = '0.5';
      }
    });
  });
  // 一括 減工事
  const btnAll = box.querySelector('#cmp-mark-all');
  if (btnAll) {
    btnAll.addEventListener('click', () => {
      let count = 0;
      results.filter(r => r.verdict === 'missing').forEach(r => {
        const line = state.estimate.lines[r.lineIdx];
        if (line && !line.reduced) { line.reduced = true; count++; }
      });
      autoUpdateEstimateStatus();
      saveEstimate();
      renderEstimate();
      showToast(`${count}行を減工事にマークしました`);
      close();
    });
  }
}

// 値引き入力 (税別から控除)
const _nebikiInp = document.getElementById('nebiki-input');
if (_nebikiInp) {
  const commitNebiki = () => {
    if (!state.estimate?.meta) return;
    const raw = (_nebikiInp.value || '').replace(/,/g, '').trim();
    const v = raw === '' ? 0 : (Number(raw) || 0);
    state.estimate.meta.nebikiAmount = v > 0 ? v : null;
    saveEstimate();
    renderTotals();
  };
  _nebikiInp.addEventListener('change', commitNebiki);
  _nebikiInp.addEventListener('blur', commitNebiki);
}
// 目標税込額から逆算 (値引き = 現税別小計 − 目標税込/(1+rate))
const _btnNebikiCalc = document.getElementById('btn-nebiki-calc');
if (_btnNebikiCalc) {
  _btnNebikiCalc.addEventListener('click', () => {
    if (!state.estimate?.meta) return;
    const targetInp = document.getElementById('nebiki-target-incl');
    const raw = (targetInp?.value || '').replace(/,/g, '').trim();
    if (!raw) { showToast('目標税込合計を入力してください', true); targetInp?.focus(); return; }
    const targetIncl = Number(raw) || 0;
    const rate = (state.settings.taxRate || 10);
    // 税抜額 X を求めて X + round(X*rate/100) === targetIncl になるようにする
    // (Math.round(X/(1+r)) では税込再計算で1円ずれる場合がある → ±2範囲を試走)
    let targetExcl = Math.round(targetIncl / (1 + rate / 100));
    let bestExcl = targetExcl;
    let bestDiff = Infinity;
    for (let x = targetExcl - 2; x <= targetExcl + 2; x++) {
      if (x < 0) continue;
      const tax = Math.round(x * rate / 100);
      const diff = Math.abs((x + tax) - targetIncl);
      if (diff < bestDiff) { bestDiff = diff; bestExcl = x; if (diff === 0) break; }
    }
    targetExcl = bestExcl;
    // 現在の税別小計(値引前)を算出
    const subtotal = state.estimate.lines.reduce((s,l) => s + lineAmount(l, 'estimate'), 0);
    const ss = state.settings || {};
    let shogeihi = 0;
    if ((ss.shogeihiPct||0) > 0) shogeihi = Math.round(subtotal * ss.shogeihiPct / 100);
    else if ((ss.shogeihiFixed||0) > 0) shogeihi = ss.shogeihiFixed;
    const cur = subtotal + shogeihi;
    const nebiki = Math.max(0, cur - targetExcl);
    state.estimate.meta.nebikiAmount = nebiki > 0 ? nebiki : null;
    saveEstimate();
    renderTotals();
    const actualIncl = targetExcl + Math.round(targetExcl * rate / 100);
    const exactNote = (actualIncl === targetIncl) ? '' : ` (実際: 税込 ¥${actualIncl.toLocaleString()})`;
    showToast(`値引き ¥${nebiki.toLocaleString()} (税別) → 税込 ¥${targetIncl.toLocaleString()}${exactNote}`);
  });
}
// 値引クリア
const _btnNebikiClear = document.getElementById('btn-nebiki-clear');
if (_btnNebikiClear) {
  _btnNebikiClear.addEventListener('click', () => {
    if (!state.estimate?.meta) return;
    state.estimate.meta.nebikiAmount = null;
    const t = document.getElementById('nebiki-target-incl');
    if (t) t.value = '';
    saveEstimate();
    renderTotals();
    showToast('値引をクリアしました');
