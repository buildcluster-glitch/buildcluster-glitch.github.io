};

// 組込 + カスタム上書き + テンプレ見積由来 を統合したパターン取得
function getMergedPatterns() {
  const custom = state.settings?.customPatterns || {};
  const merged = { ...ESTIMATE_DEFAULT_PATTERNS };
  // 1. customPatterns(従来形式)
  Object.entries(custom).forEach(([k, v]) => { merged[k] = v; });
  // 2. テンプレ見積(state.estimates の isTemplate=true)
  Object.values(state.estimates || {}).forEach(est => {
    if (!est?.meta?.isTemplate) return;
    const name = est.meta.templateName || est.meta.bukken || `テンプレ-${(est.id||'').slice(0,6)}`;
    const filledRows = (est.lines || []).filter(l => l.category || l.item);
    merged[name] = {
      label: `${name} (${filledRows.length}行)`,
      rows: filledRows.map(l => {
        const o = {};
        if (l.category) o.category = l.category;
        if (l.item) o.item = l.item;
        if (l.unit) o.unit = l.unit;
        if (l.qty != null && l.qty !== 0 && l.qty !== '') o.qty = Number(l.qty) || 0;
        if (l.burdenType && l.burdenType !== '家主') o.burdenType = l.burdenType;
        return o;
      })
    };
  });
  return merged;
}

// テンプレ一覧の描画(タブ「📋 見積テンプレ」)
function renderTemplateList() {
  const tbody = document.getElementById('template-tbody');
  if (!tbody) return;
  const templates = Object.values(state.estimates || {}).filter(e => e?.meta?.isTemplate);
  if (!templates.length) {
    tbody.innerHTML = `<tr><td colspan="5" style="padding:20px; text-align:center; color:var(--muted);">テンプレートがまだありません。<br>「＋ 新規テンプレ作成」 で作成、または見積タブで「💾 現在をテンプレに保存」でも追加できます。</td></tr>`;
    return;
  }
  templates.sort((a, b) => (b.updatedAt || '').localeCompare(a.updatedAt || ''));
  tbody.innerHTML = templates.map(est => {
    const name = est.meta?.templateName || est.meta?.bukken || `(無名テンプレ ${est.id.slice(0,6)})`;
    const filled = (est.lines || []).filter(l => l.item).length;
    const cats = [...new Set((est.lines || []).filter(l => l.category).map(l => l.category))].slice(0, 3).join(' / ');
    const dt = est.updatedAt ? est.updatedAt.slice(0, 16).replace('T', ' ') : '';
    return `<tr data-tpl-id="${est.id}" style="cursor:pointer; border-bottom:1px solid var(--line);">
      <td style="padding:6px 8px;"><b>${escapeHtml(name)}</b></td>
      <td style="padding:6px 8px; text-align:right;">${filled} 行</td>
      <td style="padding:6px 8px; font-size:11px; color:#6b7280;">${escapeHtml(cats)}</td>
      <td style="padding:6px 8px; font-size:11px; color:#6b7280;">${escapeHtml(dt)}</td>
      <td style="padding:6px 8px; text-align:center; white-space:nowrap;">
        <button class="primary btn-tpl-edit" data-tpl-id="${est.id}" title="このテンプレを編集">✏ 編集</button>
        <button class="btn-tpl-dup" data-tpl-id="${est.id}" title="複製">📄</button>
        <button class="danger btn-tpl-del" data-tpl-id="${est.id}" title="削除">×</button>
      </td>
    </tr>`;
  }).join('');
  // 編集ボタン
  tbody.querySelectorAll('.btn-tpl-edit').forEach(btn => btn.addEventListener('click', e => {
    e.stopPropagation();
    openTemplate(btn.dataset.tplId);
  }));
  // 行クリック = 編集
  tbody.querySelectorAll('tr[data-tpl-id]').forEach(tr => tr.addEventListener('click', e => {
    if (e.target.closest('button')) return;
    openTemplate(tr.dataset.tplId);
  }));
  // 複製
  tbody.querySelectorAll('.btn-tpl-dup').forEach(btn => btn.addEventListener('click', e => {
    e.stopPropagation();
    const src = state.estimates[btn.dataset.tplId];
    if (!src) return;
    const newName = (prompt(`「${src.meta.templateName||src.meta.bukken||''}」を複製。新しい名前:`, (src.meta.templateName||'') + '_copy') || '').trim();
    if (!newName) return;
    const dup = JSON.parse(JSON.stringify(src));
    dup.id = newEstimateId();
    dup.createdAt = new Date().toISOString();
    dup.updatedAt = new Date().toISOString();
    dup.meta.templateName = newName;
    dup.meta.bukken = '';
    state.estimates[dup.id] = dup;
    saveEstimates();
    renderTemplateList();
    showToast(`テンプレ「${newName}」を複製しました`);
  }));
  // 削除
  tbody.querySelectorAll('.btn-tpl-del').forEach(btn => btn.addEventListener('click', e => {
    e.stopPropagation();
    const tpl = state.estimates[btn.dataset.tplId];
    if (!tpl) return;
    const name = tpl.meta.templateName || tpl.meta.bukken || '(無名)';
    if (!confirm(`テンプレ「${name}」を削除しますか?`)) return;
    delete state.estimates[btn.dataset.tplId];
    saveEstimates();
    renderTemplateList();
    initNewEstPatternSelect();
    showToast(`テンプレ「${name}」を削除しました`);
  }));
}

// 新規テンプレ作成
function createNewTemplate() {
  const name = (prompt('テンプレ名を入力(例: 退去A標準):', '') || '').trim();
  if (!name) return;
  // 既存名と重複チェック
  const dup = Object.values(state.estimates||{}).find(e => e?.meta?.isTemplate && (e.meta.templateName === name));
  if (dup) {
    if (!confirm(`「${name}」は既に存在します。代わりに開きますか?`)) return;
    openTemplate(dup.id);
    return;
  }
  const tpl = emptyEstimate();
  tpl.meta.isTemplate = true;
  tpl.meta.templateName = name;
  tpl.meta.bukken = '';
  state.estimates[tpl.id] = tpl;
  state.estimate = tpl;
  setCurrentId(tpl.id);
  saveEstimates();
  syncMetaInputs();
  renderEstimate();
  renderCurrentHeader();
  initNewEstPatternSelect();
  switchTab('estimate');
  showToast(`新規テンプレ「${name}」を作成 → 編集を開始`);
}

function openTemplate(id) {
  const tpl = state.estimates[id];
  if (!tpl) return;
  state.estimate = tpl;
  setCurrentId(id);
  // Undo履歴リセット
  if (typeof undoStack !== 'undefined') {
    undoStack.length = 0; redoStack.length = 0;
    undoLastSnapshot = snapshotEstimate();
    if (typeof updateUndoButtons === 'function') updateUndoButtons();
  }
  syncMetaInputs();
  renderEstimate();
  renderCurrentHeader();
  switchTab('estimate');
  showToast(`テンプレ「${tpl.meta.templateName || ''}」を編集中`);
}

function emptyEstimate(patternName) {
  const merged = getMergedPatterns();
  const patternKey = patternName || state.settings?.defaultPattern || '標準';
  const pattern = merged[patternKey] || merged['標準'] || ESTIMATE_DEFAULT_PATTERNS['標準'];
  // 組込パターン(標準/シンプル/空白)は 30行に padding。カスタムテンプレはそのまま使用
  const isBuiltin = !!ESTIMATE_DEFAULT_PATTERNS[patternKey];
  const TOTAL_ROWS = 30;
  let baseRows = pattern.rows.map(spec => ({ ...emptyLine(), ...spec }));
  // マスタから自動取込(item指定があれば単価・室名等を自動セット)
  baseRows.forEach(row => {
    if (row.item) {
      const m = (state.master || []).find(x => x.項目 === row.item);
      if (m) {
        row.itemRef = m.項目番号;
        if (!row.unit) row.unit = m.単位 || '式';
        if (!row.qty) row.qty = 1;
        const priceCol = state.settings?.priceCol || '山一地所';
        if (!row.unitPrice) row.unitPrice = Number(m[priceCol]) || 0;
        if (!row.materialPrice) row.materialPrice = Number(m['材料費']) || 0;
      }
    }
  });
  if (isBuiltin) {
    // 組込パターンは 30行 確保(超過は切り捨て、不足は空行で埋める)
    baseRows = baseRows.slice(0, TOTAL_ROWS);
    while (baseRows.length < TOTAL_ROWS) baseRows.push(emptyLine());
  }
  // カスタムテンプレ由来は pattern.rows そのまま(padding なし)
  return {
    id: newEstimateId(),
    createdAt: new Date().toISOString(),
    updatedAt: new Date().toISOString(),
    meta: { bukken:'', roomNo:'', shozaichi:'', date: formatToday(), atena:'', atenaTantou:'', folderName:'', driveUrl:'', remarks:'', orderSupplierFilter:'__all__', taikyo: emptyTaikyo(), status:'下書き', submittedAt:'', completedAt:'', motoukeOrderAmount:null, nebikiAmount:null, isTemplate:false, templateName:'', hatchuOrder: emptyHatchuOrder(), oshirase: emptyOshirase(), koutei: emptyKoutei() },
    lines: baseRows,
  };
}

// 間取りをハウスクリーニング行の工事名称に反映(マスタから単価も自動)
function syncMadoriToHouseCleaning(madori) {
  if (!state.estimate || !madori) return false;
  const lines = state.estimate.lines;
  // 旧 'ハウスクリーニング' / 新 '清掃工事' どちらでも検出
  let line = lines.find(l => l.category === '清掃工事' || l.category === 'ハウスクリーニング');
  // 無ければ先頭の空行を使う、それも無ければunshift
  if (!line) {
    const emptyIdx = lines.findIndex(l => !l.item && !l.category);
    line = emptyLine();
    line.category = '清掃工事';
    line.unit = '式';
    line.qty = 1;
    line.burdenType = '入居者';
    if (emptyIdx >= 0) lines[emptyIdx] = line;
    else lines.unshift(line);
  }
  // 新しい命名: "ハウスクリーニング 1K"
  const expectedItem = 'ハウスクリーニング ' + madori;
  if (line.item === expectedItem) return false; // 既に一致
  line.category = '清掃工事';
  line.item = expectedItem;
  // マスタから該当行を引いて単価などを自動入力
  const m = state.master.find(x => x.カテゴリー === '清掃工事' && x.項目 === expectedItem);
  if (m) {
    line.unit = m.単位 || '式';
    const col = state.settings.priceCol;
    if (col && m[col] != null) line.unitPrice = Number(m[col]) || 0;
    const oCol = state.settings.priceColOrder;
    if (oCol && m[oCol] != null) line.orderPrice = Number(m[oCol]) || 0;
    line.itemRef = m.項目番号;
  }
  line.amountOverride = null;
  line.orderAmountOverride = null;
  return true;
}

