    profit_desc:  (a,b)=>{ const sa=estimateSummary(a), sb=estimateSummary(b); return (sb.mitoriTotal-sb.orderTotal) - (sa.mitoriTotal-sa.orderTotal); },
    rate_desc:    (a,b)=>{ const sa=estimateSummary(a), sb=estimateSummary(b); const ra=sa.mitoriTotal?(sa.mitoriTotal-sa.orderTotal)/sa.mitoriTotal:0; const rb=sb.mitoriTotal?(sb.mitoriTotal-sb.orderTotal)/sb.mitoriTotal:0; return rb-ra; },
  }[sort] || ((a,b)=>0);
  rows.sort(cmp);
