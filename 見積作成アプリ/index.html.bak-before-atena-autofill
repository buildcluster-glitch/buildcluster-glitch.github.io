// Undo/Redo: 現在編集中見積のスナップショット履歴
const undoStack = [];
const redoStack = [];
const UNDO_LIMIT = 50;
let undoDebounceTimer = null;
let undoLastSnapshot = null;

function snapshotEstimate() {
  if (!state.estimate) return null;
  return JSON.stringify({ meta: state.estimate.meta, lines: state.estimate.lines });
}
// 直前状態を記録(入力を連続してる間は debounce でまとめる)
function pushUndo(immediate = false) {
  const snap = snapshotEstimate();
  if (!snap || snap === undoLastSnapshot) return;
  const doPush = () => {
    const cur = snapshotEstimate();
    if (!cur || cur === undoLastSnapshot) return;
    if (undoLastSnapshot != null) undoStack.push(undoLastSnapshot);
    if (undoStack.length > UNDO_LIMIT) undoStack.shift();
    undoLastSnapshot = cur;
    redoStack.length = 0; // 新規編集が入ったらredoは消す
    updateUndoButtons();
  };
  if (immediate) {
    if (undoDebounceTimer) { clearTimeout(undoDebounceTimer); undoDebounceTimer = null; }
    doPush();
  } else {
    if (undoDebounceTimer) clearTimeout(undoDebounceTimer);
    undoDebounceTimer = setTimeout(() => { undoDebounceTimer = null; doPush(); }, 600);
  }
}
function applySnapshot(snap) {
  if (!snap || !state.estimate) return;
  try {
    const obj = JSON.parse(snap);
    state.estimate.meta = obj.meta;
    state.estimate.lines = obj.lines;
    migrateOldEstimateLines(state.estimate.lines);
    state.estimate.updatedAt = new Date().toISOString();
    state.estimates[state.estimate.id] = state.estimate;
    saveEstimates();
    syncMetaInputs();
    renderEstimate();
    renderCurrentHeader();
    renderPrintMeta();
    // 業者発注書タブも再描画(タブ表示中なら即反映)
    if (typeof renderHatchu === 'function') renderHatchu();
    // 現場情報タブも再描画
    if (typeof renderTaikyo === 'function') renderTaikyo();
  } catch(e) { console.error('snapshot restore failed', e); }
}
function doUndo() {
  if (undoDebounceTimer) { clearTimeout(undoDebounceTimer); undoDebounceTimer = null; }
  // 保留中の変更があれば先に確定
  const cur = snapshotEstimate();
  if (cur && cur !== undoLastSnapshot) {
    if (undoLastSnapshot != null) undoStack.push(undoLastSnapshot);
    undoLastSnapshot = cur;
  }
  if (!undoStack.length) return;
  const prev = undoStack.pop();
  if (undoLastSnapshot) redoStack.push(undoLastSnapshot);
  undoLastSnapshot = prev;
  applySnapshot(prev);
  updateUndoButtons();
}
function doRedo() {
  if (!redoStack.length) return;
  const next = redoStack.pop();
  if (undoLastSnapshot) undoStack.push(undoLastSnapshot);
  undoLastSnapshot = next;
  applySnapshot(next);
  updateUndoButtons();
}
function updateUndoButtons() {
  const u = document.getElementById('btn-undo');
  const r = document.getElementById('btn-redo');
  if (u) u.disabled = undoStack.length === 0;
  if (r) r.disabled = redoStack.length === 0;
}

