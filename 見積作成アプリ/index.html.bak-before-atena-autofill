function attachColumnResizeHandlers() {
  const ths = document.querySelectorAll('#estimate-thead th.col-resize');
  ths.forEach(th => {
    const handle = th.querySelector('.col-resize-handle');
    if (!handle) return;
    handle.addEventListener('mousedown', e => {
      e.preventDefault();
      e.stopPropagation();
      const key = th.dataset.colkey;
      const startX = e.clientX;
      const startW = th.getBoundingClientRect().width;
      th.classList.add('col-resizing');
      const onMove = (ev) => {
        const newW = Math.max(40, Math.round(startW + (ev.clientX - startX)));
        th.style.width = newW + 'px';
      };
      const onUp = (ev) => {
        document.removeEventListener('mousemove', onMove);
        document.removeEventListener('mouseup', onUp);
        th.classList.remove('col-resizing');
        const newW = Math.max(40, Math.round(startW + (ev.clientX - startX)));
        if (!state.settings.colWidths) state.settings.colWidths = {};
        state.settings.colWidths[key] = newW;
        saveSettings();
      };
      document.addEventListener('mousemove', onMove);
      document.addEventListener('mouseup', onUp);
    });
    // ダブルクリックでデフォルト復帰
    handle.addEventListener('dblclick', e => {
      e.preventDefault();
      e.stopPropagation();
      const key = th.dataset.colkey;
      if (state.settings.colWidths && state.settings.colWidths[key]) {
        delete state.settings.colWidths[key];
        saveSettings();
        renderEstimateHeader();
        attachColumnResizeHandlers();
        showToast(`「${th.textContent.replace(/\s+$/,'')}」列幅をリセット`);
      }
    });
  });
}

