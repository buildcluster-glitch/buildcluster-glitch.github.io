  const cats = uniqueCategories();
  const knownMinors = new Set(CATEGORY_GROUPS.flatMap(g => g.minors));
  const unknownCats = cats.filter(c => !knownMinors.has(c));
  const groupedHtml = CATEGORY_GROUPS.map(g => {
    const minors = g.minors.filter(m => cats.includes(m));
    if (!minors.length) return '';
    return `<optgroup label="${escapeHtml(g.major)}">${minors.map(c => `<option value="${escapeHtml(c)}">${escapeHtml(c)}</option>`).join('')}</optgroup>`;
  }).join('');
  const unknownHtml = unknownCats.length
    ? `<optgroup label="未分類">${unknownCats.map(c => `<option value="${escapeHtml(c)}">${escapeHtml(c)}</option>`).join('')}</optgroup>`
    : '';
  ['filter-category','master-filter-cat'].forEach(id => {
    const sel = document.getElementById(id);
    const cur = sel.value;
    sel.innerHTML = '<option value="">(全カテゴリー)</option>' + groupedHtml + unknownHtml;
    sel.value = cur;
  });
}

