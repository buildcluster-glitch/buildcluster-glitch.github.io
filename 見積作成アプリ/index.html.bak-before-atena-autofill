// 新規見積パターン編集
// =========================
let _patternEditCurrent = null;  // 編集中のパターン名
let _patternEditDraft = null;    // { label, rows: [...] }

function renderPatternEditor() {
  const sel = document.getElementById('pattern-edit-select');
  if (!sel) return;
  const merged = getMergedPatterns();
  const keys = Object.keys(merged);
  if (!_patternEditCurrent || !keys.includes(_patternEditCurrent)) {
    _patternEditCurrent = state.settings?.defaultPattern || keys[0] || '標準';
  }
  // セレクトの中身: 名前 + (組込/カスタム) ラベル
  const customSet = new Set(Object.keys(state.settings?.customPatterns || {}));
  const builtinSet = new Set(Object.keys(ESTIMATE_DEFAULT_PATTERNS));
  sel.innerHTML = keys.map(k => {
    const tags = [];
    if (builtinSet.has(k) && customSet.has(k)) tags.push('組込+上書き');
    else if (builtinSet.has(k)) tags.push('組込');
    else tags.push('カスタム');
    return `<option value="${escapeHtml(k)}" ${k===_patternEditCurrent?'selected':''}>${escapeHtml(k)} (${tags.join('/')})</option>`;
  }).join('');
  // ドラフトを現在のパターンから初期化
  loadPatternToDraft(_patternEditCurrent);
  paintPatternEditTable();
}

function loadPatternToDraft(name) {
  const merged = getMergedPatterns();
  const p = merged[name] || { label: '', rows: [] };
  _patternEditDraft = {
    name,
    label: p.label || '',
    rows: (p.rows || []).map(r => ({
      category: r.category || '',
      item: r.item || '',
      unit: r.unit || '',
      qty: r.qty != null ? r.qty : '',
      burdenType: r.burdenType || ''
    }))
  };
  document.getElementById('pattern-edit-name').value = name;
  document.getElementById('pattern-edit-label').value = _patternEditDraft.label;
}

function paintPatternEditTable() {
  const tbody = document.getElementById('pattern-edit-tbody');
  if (!tbody || !_patternEditDraft) return;
  // 全カテゴリ候補
  const cats = [...new Set([...CATEGORY_GROUPS.flatMap(g => g.minors), ...(state.master||[]).map(m => m.カテゴリー).filter(Boolean)])];
  const burdenOpts = ['', '家主', '入居者', '自社のみ'];
  tbody.innerHTML = _patternEditDraft.rows.map((r, i) => `
    <tr data-i="${i}">
      <td style="text-align:center; color:#6b7280;">${i+1}</td>
      <td>
        <select data-pe="category" style="width:100%;">
          <option value="">(空)</option>
          ${cats.map(c => `<option value="${escapeHtml(c)}" ${c===r.category?'selected':''}>${escapeHtml(c)}</option>`).join('')}
        </select>
      </td>
