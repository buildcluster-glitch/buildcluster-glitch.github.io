    return `<tr data-i="${i}" draggable="true"${l.reduced?' class="reduced-row"':''}>
      <td class="no-print"><input type="checkbox" class="row-check"></td>
      <td class="num drag-handle no-print">${n+1}</td>
      <td class="no-print cat-cell" style="position:relative;">${categorySelect(l.category, i)}${l.category?'<span class="cat-fill-handle" title="下にドラッグして行全体を連続コピー"></span>':''}</td>
      <td class="item-cell" style="position:relative;">${insAbove}${insBelow}${itemSelect(l.item, l.category, i)}${l.item?'<span class="item-fill-handle" title="下にドラッグしてこの工事名称を連続コピー"></span>':''}</td>
      <td>${datalistInput('room', l.room, `rooms-${i}`, uniqueRooms(), '室名')}</td>
      <td class="specs-cell" style="position:relative;">${l.category === '内装工事' ? specsCellForNaiso(l.specs, `specs-${i}`, uniqueSpecs()) : datalistInput('specs', l.specs, `specs-${i}`, uniqueSpecs(), '仕様・摘要')}${l.category === '内装工事' ? '' : `<button type="button" class="btn-clear-specs no-print" data-row-i="${i}" title="この欄をクリア" tabindex="-1">×</button>`}</td>
      <td class="qty-col"><input type="text" inputmode="decimal" data-f="qty" data-num="1" list="dl-qty" value="${fmtNum(l.qty)}" style="text-align:center;"></td>
      <td>${unitSelect(l.unit, i)}</td>
      <td class="num"><input type="text" inputmode="decimal" data-f="${priceField}" data-num="1" value="${fmtNum(priceVal)}"></td>
      <td class="num print-edge"><input type="text" inputmode="decimal" data-f="${amountField}" data-num="1" value="${fmtNum(amt)}" title="${amtTitle}" style="${amtStyle}"></td>
      <td class="no-print edit-only">${supSel}</td>
      <td class="num no-print edit-only" style="background:#fef3c7;"><input type="text" inputmode="decimal" data-f="materialPrice" data-num="1" value="${fmtNum(l.materialPrice||0)}" style="background:transparent;" title="材料単価(支給材料)"></td>
