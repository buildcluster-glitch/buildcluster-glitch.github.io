<!doctype html>
<html lang="ja">
<head>
<meta charset="utf-8">
<title>見積作成アプリ - ビルドクラスタ</title>
<style>
  :root {
    --bg:#f5f5f7; --panel:#fff; --line:#e1e1e6; --accent:#2563eb; --accent-dk:#1d4ed8;
    --text:#111; --muted:#666; --warn:#d97706; --ok:#16a34a; --danger:#dc2626;
  }
  * { box-sizing:border-box; }
  body { margin:0; font-family: "Hiragino Kaku Gothic ProN","Yu Gothic","Meiryo",sans-serif; background:var(--bg); color:var(--text); }
  header { background:#111; color:#fff; padding:10px 16px; display:flex; align-items:center; gap:16px; flex-wrap:wrap; }
  header h1 { font-size:16px; margin:0; }
  header .meta { font-size:12px; color:#bbb; }
  .tabs { display:flex; gap:2px; background:#222; padding:4px 8px; }
  .tab { padding:8px 14px; background:#333; color:#ddd; cursor:pointer; border-radius:6px 6px 0 0; font-size:13px; }
  .tab.active { background:var(--bg); color:var(--text); }
  main { padding:12px; }
  .panel { background:var(--panel); border:1px solid var(--line); border-radius:8px; padding:12px; margin-bottom:12px; }
  .row { display:flex; gap:8px; align-items:center; flex-wrap:wrap; }
  label { font-size:12px; color:var(--muted); }
  input[type=text], input[type=number], select, textarea {
    font:inherit; padding:6px 8px; border:1px solid var(--line); border-radius:4px; background:#fff;
  }
  input[type=text]:focus, input[type=number]:focus, select:focus { outline:2px solid var(--accent); outline-offset:-1px; }
  button { font:inherit; padding:6px 12px; border:1px solid var(--line); background:#fff; border-radius:4px; cursor:pointer; }
  button.primary { background:var(--accent); color:#fff; border-color:var(--accent); }
  button.primary:hover { background:var(--accent-dk); }
  button.danger { color:var(--danger); }
  button:hover { background:#f0f0f3; }
  button.primary:hover { background:var(--accent-dk); color:#fff; }
  table { width:100%; border-collapse:collapse; font-size:12px; }
  th, td { border-bottom:1px solid var(--line); padding:4px 6px; text-align:left; vertical-align:top; }
  th { background:#fafafa; position:sticky; top:0; z-index:1; font-weight:600; font-size:11px; color:#444; }
  td.num, th.num { text-align:right; font-variant-numeric: tabular-nums; }
  tr:hover td { background:#f8f8fc; }
  .cat-tag { display:inline-block; padding:1px 6px; border-radius:3px; background:#eef; font-size:10px; color:#336; margin-right:4px; }
  .viewer-wrap { max-height: calc(100vh - 240px); overflow:auto; }
  .pill { display:inline-block; font-size:11px; padding:1px 8px; border-radius:10px; background:#eee; }
  #estimate-table td input, #estimate-table td select { width:100%; border:1px solid transparent; padding:2px 4px; font-size:12px; }
  #estimate-table td input:focus, #estimate-table td select:focus { border-color:var(--accent); }
  /* 負担区分セレクトはブラウザ標準スタイルを抑えて見た目を揃える */
  .burden-sel {
    appearance:none; -webkit-appearance:none; -moz-appearance:none;
    background:#fff;
    color:#333;
    border:1px solid #ccc !important;
    border-radius:3px;
    padding:2px 18px 2px 4px !important;
    font-size:12px;
    text-decoration:none !important;
    /* 右側に▼を自前で描く */
    background-image: linear-gradient(45deg, transparent 50%, #666 50%), linear-gradient(135deg, #666 50%, transparent 50%);
    background-position: calc(100% - 10px) 50%, calc(100% - 6px) 50%;
    background-size: 4px 4px, 4px 4px;
    background-repeat: no-repeat;
  }
  .burden-sel option { text-decoration:none !important; }
  #estimate-tbody tr.row-dragging,
  #hatchu-tbody tr.row-dragging { opacity:0.35; }
  #estimate-tbody tr.row-drop-before,
  #hatchu-tbody tr.row-drop-before { box-shadow: inset 0 3px 0 var(--accent); }
  #estimate-tbody tr.row-drop-after,
  #hatchu-tbody tr.row-drop-after  { box-shadow: inset 0 -3px 0 var(--accent); }
  #hatchu-tbody tr[data-i] td:first-child { cursor:grab; user-select:none; }
  #hatchu-tbody tr[data-i] td:first-child:active { cursor:grabbing; }
  #hatchu-tbody tr[data-i] td:first-child::before { content:"⋮⋮ "; color:#bbb; font-weight:bold; }
  #estimate-tbody td.drag-handle { cursor:grab; user-select:none; color:var(--muted); }
  #estimate-tbody td.drag-handle:active { cursor:grabbing; }
  #estimate-tbody td.drag-handle::before { content:"⋮⋮ "; font-weight:bold; color:#bbb; }
  /* オートフィル: 行の右下に青い小さな四角(Excel風) */
  /* datalist付きinputの視認性: 右側に▼を表示 */
  input[list] {
    background-image: linear-gradient(45deg, transparent 50%, #888 50%),
                      linear-gradient(135deg, #888 50%, transparent 50%);
    background-position: calc(100% - 9px) 50%, calc(100% - 5px) 50%;
    background-size: 4px 4px, 4px 4px;
    background-repeat: no-repeat;
    padding-right: 14px !important;
  }
  input[list]:focus { background-image: linear-gradient(45deg, transparent 50%, var(--accent) 50%), linear-gradient(135deg, var(--accent) 50%, transparent 50%); }
  #estimate-tbody tr { position:relative; }
  #estimate-tbody tr .autofill-handle {
    position:absolute; right:-3px; bottom:-3px; width:8px; height:8px;
    background:var(--accent); border:1px solid #fff; cursor:crosshair; z-index:5;
    display:none;
  }
  #estimate-tbody tr:hover .autofill-handle { display:block; }
  /* 数量列: ヘッダ・セル中央寄せ */
  #estimate-table th.qty-col, #estimate-table td.qty-col { text-align:center; }
  /* 列幅リサイズハンドル */
  #estimate-table th.col-resize { position:relative; }
  #estimate-table th.col-resize .col-resize-handle {
    position:absolute; right:-3px; top:0; bottom:0; width:6px;
    cursor:col-resize; user-select:none; z-index:20;
  }
  #estimate-table th.col-resize .col-resize-handle:hover { background:var(--accent); opacity:0.5; }
  #estimate-table th.col-resize.col-resizing { background:#dbeafe; }
  /* sticky thead を行内ハンドル類より前面に */
  #estimate-table thead th { z-index:15; }

  /* 項目カスケードメニュー(2段式: 小分類 → 項目) */
  #item-cascade-menu {
    position:fixed; z-index:10000; display:none;
    background:#fff; border:1px solid #1e40af; box-shadow:0 6px 24px rgba(0,0,0,0.2);
    border-radius:4px; overflow:hidden;
    font-size:12px;
  }
  #item-cascade-menu .cascade-wrap { display:flex; }
  #item-cascade-menu .cascade-col-sub {
    background:#f3f4f6; border-right:1px solid #cbd5e1;
    min-width:140px; overflow-y:auto;
  }
  #item-cascade-menu .cascade-col-items {
    min-width:320px; max-width:480px; overflow-y:auto;
  }
  #item-cascade-menu .cascade-wrap { max-height: calc(100vh - 40px); }
  #item-cascade-menu .cascade-col-sub,
  #item-cascade-menu .cascade-col-items { max-height: calc(100vh - 40px); }
  #item-cascade-menu .cascade-sub-item {
    padding:6px 10px; cursor:pointer; border-bottom:1px solid #e5e7eb;
    display:flex; justify-content:space-between; align-items:center; gap:6px;
  }
  #item-cascade-menu .cascade-sub-item:hover,
  #item-cascade-menu .cascade-sub-item.active { background:#dbeafe; color:#1e3a8a; font-weight:600; }
  #item-cascade-menu .cascade-sub-item .count { font-size:10px; color:#6b7280; }
  #item-cascade-menu .cascade-item {
    padding:5px 10px; cursor:pointer; border-bottom:1px solid #f1f5f9;
    white-space:nowrap; overflow:hidden; text-overflow:ellipsis;
  }
  #item-cascade-menu .cascade-item:hover { background:#fef9c3; }
  #item-cascade-menu .cascade-empty { padding:12px; color:#9ca3af; text-align:center; }
  /* カテゴリセル右下のExcel風オートフィルハンドル */
  #estimate-tbody td.cat-cell .cat-fill-handle {
    position:absolute; right:1px; bottom:1px; width:8px; height:8px;
    background:#1d4ed8; border:1px solid #fff; cursor:crosshair; z-index:5;
    display:none;
    box-shadow:0 0 0 1px #1d4ed8;
  }
  #estimate-tbody tr:hover td.cat-cell .cat-fill-handle { display:block; }
  #estimate-tbody tr.cat-fill-target td.cat-cell { outline:2px dashed #1d4ed8; outline-offset:-2px; background:#eff6ff !important; }
  /* 工事名称セル右下のオートフィルハンドル */
  #estimate-tbody td.item-cell .item-fill-handle {
    position:absolute; right:1px; bottom:1px; width:8px; height:8px;
    background:#166534; border:1px solid #fff; cursor:crosshair; z-index:5;
    display:none;
    box-shadow:0 0 0 1px #166534;
  }
  #estimate-tbody tr:hover td.item-cell .item-fill-handle { display:block; }
  #estimate-tbody tr.item-fill-target td.item-cell { outline:2px dashed #166534; outline-offset:-2px; background:#f0fdf4 !important; }
  /* フィル対象のプレビュー枠(ドラッグ中) */
  #estimate-tbody tr.autofill-target { outline:2px dashed var(--accent); outline-offset:-2px; }
  /* 発注先セル: 種別バッジ(材料費/自社/外注) */
  .sup-badge {
    display:inline-block; font-size:9px; padding:1px 4px;
    border-radius:3px; white-space:nowrap; line-height:1.4;
    border:1px solid transparent;
  }
  .sup-badge-mat   { background:#fef3c7; color:#92400e; border-color:#fcd34d; }
  .sup-badge-jisha { background:#dbeafe; color:#1e40af; border-color:#93c5fd; }
  .sup-badge-out   { background:#fed7aa; color:#7c2d12; border-color:#fdba74; }
  /* 仕様・摘要セルのクリア×ボタン: 値があるときだけ表示 */
  #estimate-tbody td.specs-cell .btn-clear-specs {
    position:absolute; right:2px; top:50%; transform:translateY(-50%);
    width:16px; height:16px; line-height:14px; text-align:center;
    border:1px solid #ccc; background:#fff; color:#888; font-size:10px;
    border-radius:50%; cursor:pointer; padding:0; z-index:6;
    visibility:hidden; opacity:0;
  }
  #estimate-tbody td.specs-cell:hover .btn-clear-specs,
  #estimate-tbody td.specs-cell:focus-within .btn-clear-specs {
    visibility:visible; opacity:1;
  }
  #estimate-tbody td.specs-cell .btn-clear-specs:hover {
    color:#fff; background:#dc2626; border-color:#dc2626;
  }
  /* 入力欄の右側に余裕を持たせて×ボタンと被らないように */
  #estimate-tbody td.specs-cell input[data-f="specs"] { padding-right:20px !important; }
  /* 行挿入 + ボタン: 各データ行の 工事名称セル の上端に浮かせる */
  #estimate-tbody td.item-cell .row-insert-above,
  #estimate-tbody td.item-cell .row-insert-below {
    position:absolute; left:50%; transform:translateX(-50%);
    font-size:11px; line-height:1; padding:2px 9px;
    background:#fff; border:1px solid var(--accent); color:var(--accent);
    border-radius:10px; cursor:pointer; z-index:8;
    display:none; font-weight:700;
    box-shadow:0 1px 4px rgba(0,0,0,0.18);
    white-space:nowrap;
  }
  #estimate-tbody td.item-cell .row-insert-above { top:-9px; }
  #estimate-tbody td.item-cell .row-insert-below { bottom:-9px; }
  #estimate-tbody tr:hover td.item-cell .row-insert-above,
  #estimate-tbody tr:hover td.item-cell .row-insert-below,
  #estimate-tbody td.item-cell .row-insert-above:hover,
  #estimate-tbody td.item-cell .row-insert-below:hover { display:inline-block; }
  #estimate-tbody td.item-cell .row-insert-above:hover,
  #estimate-tbody td.item-cell .row-insert-below:hover { background:var(--accent); color:#fff; }
  /* カテゴリーセクション見出し行 */
  /* 減工事行: グレースケール化で一目で識別(見積・発注書 両方) */
  #estimate-tbody tr.reduced-row,
  #hatchu-tbody tr.reduced-row {
    filter: grayscale(1);
    opacity: 0.55;
  }
  #estimate-tbody tr.reduced-row td,
  #hatchu-tbody tr.reduced-row td {
    background: #e5e7eb !important;
    color: #6b7280;
    text-decoration: line-through;
    text-decoration-color: #9ca3af;
    text-decoration-thickness: 1.5px;
  }
  #estimate-tbody tr.reduced-row td input,
  #estimate-tbody tr.reduced-row td select,
  #hatchu-tbody tr.reduced-row td input,
  #hatchu-tbody tr.reduced-row td select {
    background: #f3f4f6 !important;
    color: #6b7280 !important;
  }
  /* 減工事マークボタンは目立たせる(グレースケール除外) */
  #estimate-tbody tr.reduced-row .btn-reduce,
  #hatchu-tbody tr.reduced-row .btn-h-reduce {
    filter: grayscale(0) !important;
    opacity: 1 !important;
    background: #fcd34d !important;
    border-color: #d97706 !important;
  }
  /* マウスホバーで少し見やすく */
  #estimate-tbody tr.reduced-row:hover,
  #hatchu-tbody tr.reduced-row:hover { opacity: 0.85; }
  /* 印刷モード: 実施版(減工事行を非表示) */
  body.hide-reduced-rows #estimate-tbody tr.reduced-row { display:none !important; }
  /* 印刷モード: 提出時版(減工事行を通常表示、打ち消しはナシ) */
  body.show-reduced-marks #estimate-tbody tr.reduced-row td {
    background:transparent !important;
    text-decoration:none !important;
    color:inherit !important;
  }
  #estimate-tbody tr.section-row td { background:#dbeafe !important; font-weight:bold; padding:4px 8px; border-top:2px solid #1e40af; border-bottom:1px solid #1e40af; }
  #estimate-tbody tr.section-row td { color:#1e3a8a; }
  #estimate-tbody tr.subtotal-row td { background:#f3f4f6 !important; font-weight:bold; text-align:right; font-size:11px; color:#555; }
  #estimate-tbody tr.shogeihi-row td { background:#fef3c7 !important; font-style:italic; }
  /* 印刷境界: 金額セルに太い右罫線、以降の編集専用列は薄い黄色背景 */
  #estimate-table th.print-edge, #estimate-table td.print-edge { border-right: 3px solid #111 !important; }
  #estimate-table th.edit-only, #estimate-table td.edit-only { background:#fffbea; }
  #estimate-table th.edit-only { color:#92400e; font-size:10px; }
  .edit-only-banner { background:#fef3c7; color:#92400e; font-size:11px; padding:3px 8px; border-radius:3px; display:inline-block; }
  .totals { display:flex; justify-content:flex-end; gap:20px; padding:8px 0; font-size:14px; }
  .totals b { font-size:16px; }
  .hide { display:none !important; }
  .toolbar { display:flex; gap:6px; flex-wrap:wrap; }
  .grow { flex:1; }
  .danger-zone { border-color:#fcc; background:#fff7f7; }
  /* 現場情報A4印刷モード(1枚収まり優先) */
  @media print {
    body.print-taikyo-mode header,
    body.print-taikyo-mode .tabs,
    body.print-taikyo-mode #tab-estimate,
    body.print-taikyo-mode #tab-ledger,
    body.print-taikyo-mode #tab-bukken,
    body.print-taikyo-mode #tab-master,
    body.print-taikyo-mode #tab-settings,
    body.print-taikyo-mode .no-print-taikyo,
    body.print-taikyo-mode #modal-overlay { display:none !important; }
    body.print-taikyo-mode #tab-taikyo { display:block !important; }
    body.print-taikyo-mode #tab-taikyo.hide { display:block !important; }
    body.print-taikyo-mode { background:#fff; }
    body.print-taikyo-mode main { padding:0; }
    body.print-taikyo-mode .panel { border:none !important; padding:0 !important; margin:0 !important; box-shadow:none !important; }
    body.print-taikyo-mode fieldset {
      border:1px solid #000 !important;
      padding:2mm 3mm !important;
      margin:0 0 2mm 0 !important;
      page-break-inside:avoid;
    }
    body.print-taikyo-mode legend { font-weight:bold; font-size:10pt; padding:0 4px; }
    body.print-taikyo-mode input, body.print-taikyo-mode select, body.print-taikyo-mode textarea {
      border:none !important; border-bottom:1px solid #888 !important; border-radius:0 !important;
      background:transparent !important; font-size:9pt !important;
      padding:0 2px !important; line-height:1.2 !important; height:auto !important; min-height:0 !important;
    }
    body.print-taikyo-mode label { font-size:8.5pt !important; color:#000 !important; white-space:nowrap; line-height:1.2 !important; }
    body.print-taikyo-mode textarea { border:1px solid #888 !important; min-height:12mm !important; }
    /* グリッド隙間を詰める */
    body.print-taikyo-mode fieldset > div[style*="display:grid"] {
      gap:1mm 6px !important;
    }
    /* 物件セクション: 2カラム化(label/input/label/input) */
    body.print-taikyo-mode #tab-taikyo fieldset:nth-of-type(1) > div {
      grid-template-columns: auto 1fr auto 1fr !important;
    }
    /* 契約・退去セクション: 2カラム化 */
    body.print-taikyo-mode #tab-taikyo fieldset:nth-of-type(2) > div {
      grid-template-columns: auto 1fr auto 1fr !important;
    }
    /* [data-show-when] 分岐ブロックは全幅維持 */
    body.print-taikyo-mode [data-show-when] { padding:2mm !important; grid-column: 1/-1 !important; }
    body.print-taikyo-mode [data-show-when] > div { gap:1mm 6px !important; }
    /* 点線区切りをスペース的に */
    body.print-taikyo-mode fieldset > div > div[style*="border-top"] { margin:1mm 0 !important; }
    /* 印刷時タイトル */
    body.print-taikyo-mode #taikyo-print-title { display:block !important; text-align:center; font-size:14pt; font-weight:bold; letter-spacing:4px; margin:0 0 2mm 0; }
    body.print-taikyo-mode #taikyo-print-title::after { content:" 退 去 立 会 情 報"; }
    /* 印刷時見出し = 物件名  */
    body.print-taikyo-mode #taikyo-print-title::before { content:attr(data-sub) " — "; letter-spacing:0; font-size:12pt; }
    @page { size:A4 portrait; margin:8mm; }
    html, body { height:auto !important; }
    /* 全体を少し縮小してA4 1枚に収める(Chrome/Edge用) */
    body.print-taikyo-mode #tab-taikyo { zoom: 0.88; }
    body.print-taikyo-mode section#tab-taikyo { page-break-inside:avoid; }
  }
  #taikyo-print-title { display:none; }

  /* 工程表(A4横) */
  .koutei-doc {
    font-family: 'Yu Gothic','MS PGothic','游ゴシック',sans-serif;
    color:#000;
    font-size: 9.5pt;
    padding: 6mm 8mm;
  }
  .koutei-doc h1 {
    text-align:center;
    font-size:15pt;
    font-weight:bold;
    margin: 2mm 0 4mm;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .koutei-doc .kt-info-table {
    width:100%;
    border-collapse:collapse;
    margin-bottom: 3mm;
    font-size: 9pt;
  }
  .koutei-doc .kt-info-table td {
    border: 1px solid #000;
    padding: 1.5mm 3mm;
    vertical-align: middle;
  }
  .koutei-doc .kt-info-table td.lbl {
    background:#f3f4f6;
    -webkit-print-color-adjust:exact;
    font-weight:600;
    width: 22mm;
  }
  /* コンパクト情報テーブル(ガント強調用) */
  .koutei-doc .kt-info-compact {
    font-size: 8.5pt;
  }
  .koutei-doc .kt-info-compact td {
    padding: 0.8mm 2mm;
  }
  .koutei-doc .kt-info-compact td.lbl {
    width: auto;
    white-space: nowrap;
    font-size: 8pt;
  }
  .koutei-gantt {
    width:100%;
    border-collapse:collapse;
    font-size: 8.5pt;
    table-layout: fixed;
  }
  .koutei-gantt th, .koutei-gantt td {
    border: 1px solid #000;
    padding: 0;
    height: 5mm;
    text-align: center;
    vertical-align: middle;
  }
  .koutei-gantt thead th {
    background:#fafafa;
    -webkit-print-color-adjust:exact;
    font-weight: 600;
  }
  .koutei-gantt .kt-rowlabel {
    background:#fff;
    padding: 0 2mm;
    text-align: left;
    white-space: nowrap;
    width: 28mm;
  }
  .koutei-gantt .kt-date-cell.sunday,
  .koutei-gantt .kt-work-cell.sunday {
    background:#9ca3af;
    -webkit-print-color-adjust:exact;
  }
  .koutei-gantt .kt-work-cell.work {
    background:#60a5fa;
    -webkit-print-color-adjust:exact;
  }
  .koutei-gantt .kt-diagonal {
    width:28mm; height:10mm;
    background: linear-gradient(to top right, transparent 49%, #000 49%, #000 51%, transparent 51%);
    position:relative;
  }
  .koutei-gantt .kt-diagonal .a { position:absolute; right:2mm; top:0.5mm; font-size:8pt; }
  .koutei-gantt .kt-diagonal .b { position:absolute; left:2mm; bottom:0.5mm; font-size:8pt; }
  .koutei-doc .kt-notes {
    margin-top: 3mm;
    font-size: 8.5pt;
    line-height: 1.6;
    border: 1px solid #000;
    border-top: none;
    padding: 1mm 3mm;
  }
  #koutei-print-area { display:none; }
  @media print {
    body.print-koutei-mode header,
    body.print-koutei-mode .tabs,
    body.print-koutei-mode #modal-overlay,
    body.print-koutei-mode #app-toast,
    body.print-koutei-mode #tab-estimate,
    body.print-koutei-mode #tab-hatchu,
    body.print-koutei-mode #tab-taikyo,
    body.print-koutei-mode #tab-bukken,
