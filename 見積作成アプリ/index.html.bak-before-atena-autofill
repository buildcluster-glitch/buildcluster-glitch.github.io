// madoriフィールドからデフォルト間取を推測(単純な間取り表記なら madoriDefault にコピー)
// 例: "1LDK" → madoriDefault="1LDK", madori=""
// 例: "1～10F 1号室:1R\n..." → そのまま(複数行だから madoriDefault は空)
function migrateBukkenMadori(list) {
  if (!Array.isArray(list)) return 0;
  const MADORI_SIMPLE = /^\s*([0-9]+[KkLDRSlr]{1,4}|[0-9]+R|ワンルーム)\s*$/i;
  let count = 0;
  list.forEach(b => {
    if (b.madoriDefault) return;
    if (!b.madori) return;
    const firstLine = String(b.madori).split(/\r?\n/)[0].trim();
    if (MADORI_SIMPLE.test(firstLine)) {
      b.madoriDefault = firstLine;
      // madori が同じ単一行だけなら madori クリア、複数行なら残す
      const lines = String(b.madori).split(/\r?\n/).map(s=>s.trim()).filter(Boolean);
      if (lines.length === 1) b.madori = '';
      count++;
    }
  });
  return count;
}

function loadBukken() {
  const stored = localStorage.getItem(STORAGE_KEYS.bukken);
  const defaults = Array.isArray(window.BUKKEN_LIST) ? JSON.parse(JSON.stringify(window.BUKKEN_LIST)) : [];
  if (!stored) { migrateBukkenMadori(defaults); return defaults; }
  try {
    const saved = JSON.parse(stored);
    // 保存件数がデフォルト未満で、デフォルトの方が明らかに多い場合は自動マージ
    let result;
    if (Array.isArray(saved) && defaults.length > saved.length + 10) {
      const savedByName = new Map(saved.map(b => [b.name, b]));
      const merged = defaults.map(d => savedByName.has(d.name) ? { ...d, ...savedByName.get(d.name) } : d);
      saved.forEach(s => { if (!merged.some(m => m.name === s.name)) merged.push(s); });
      console.log(`物件マスタ自動マージ: saved ${saved.length}件 + defaults ${defaults.length}件 → ${merged.length}件`);
      result = merged;
    } else {
      result = saved;
    }
    // madoriDefault マイグレーション(単純な間取り表記は自動で分離)
    const migrated = migrateBukkenMadori(result);
    if (migrated > 0) {
      localStorage.setItem(STORAGE_KEYS.bukken, JSON.stringify(result));
      console.log(`madoriDefault マイグレーション: ${migrated}件`);
    }
    return result;
  } catch(e) { migrateBukkenMadori(defaults); return defaults; }
}
