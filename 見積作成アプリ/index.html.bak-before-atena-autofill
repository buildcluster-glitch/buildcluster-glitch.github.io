function addCustomEntry(kind) {
  const inputId = kind === 'moto' ? 'new-moto-input' : (kind === 'hatchu' ? 'new-hatchu-input' : 'new-cat-input');
  const inp = document.getElementById(inputId);
  const name = (inp?.value || '').trim();
  if (!name) { showToast('名前を入力してください', true); return; }
  const key = kind === 'moto' ? 'customMotouke' : (kind === 'hatchu' ? 'customHatchu' : 'customCategories');
  let existing = [];
  if (kind === 'moto') existing = DEFAULT_MOTO_COLS;
  else if (kind === 'hatchu') existing = DEFAULT_HATCHU_COLS;
  else existing = [...new Set(state.master.map(r => r.カテゴリー).filter(Boolean))];
  if (existing.includes(name)) { showToast(`「${name}」は既に存在しています`, true); return; }
  if (!state.settings[key]) state.settings[key] = [];
  if (state.settings[key].includes(name)) { showToast(`「${name}」は既に追加されています`, true); return; }
  state.settings[key].push(name);
  saveSettings();
  if (kind !== 'cat') applyCustomCompanies();
  // 単価コピー: 元請けは「ワールドレジデンシャル」、外注先は「思綺美装」をテンプレートに各マスタ行へコピー
  let copiedRows = 0;
  if (kind === 'moto' || kind === 'hatchu') {
    const refCol = kind === 'moto' ? 'ワールドレジデンシャル' : '思綺美装';
    (state.master || []).forEach(r => {
      const v = r[refCol];
      if (v != null && v !== '') {
        r[name] = v;
        copiedRows++;
      } else {
        // 参照列が空の行は新列も明示的に null(キー存在を保証)
        r[name] = null;
      }
    });
    saveMaster();
  }
  inp.value = '';
  renderCustomCompanyLists();
  renderPriceColOptions();
  if (typeof renderCategoryOptions === 'function') renderCategoryOptions();
  if (typeof renderMaster === 'function') renderMaster();
  if (kind === 'moto' || kind === 'hatchu') {
    const refLabel = kind === 'moto' ? 'ワールドレジデンシャル' : '思綺美装';
    showToast(`「${name}」を追加しました(${refLabel}の単価を ${copiedRows}行 にコピー)`);
  } else {
    showToast(`「${name}」を追加しました`);
  }
}
