// マスタ値のズレを除外するセーフガード
function sanitizeQty(v) {
  const n = Number(v);
  if (!Number.isFinite(n) || n <= 0 || n >= 100 || n < 0.01) return 1;
  return n;
}
function sanitizeRoom(v) {
  if (!v) return '';
  if (!isNaN(Number(v))) return ''; // 数値文字列はズレたデータ
  return v;
}
function sanitizeSpecs(v) {
  if (!v) return '';
  const wasteSet = new Set(['混合廃棄物','廃プラスチック類','廃プラ','がれき類','金属くず','木くず','紙くず']);
  if (wasteSet.has(v)) return '';
  if (!isNaN(Number(v))) return '';
  return v;
}

