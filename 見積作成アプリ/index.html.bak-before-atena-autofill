  '2027-07-19': '海の日', '2027-08-11': '山の日', '2027-09-20': '敬老の日', '2027-09-23': '秋分の日',
  '2027-10-11': 'スポーツの日', '2027-11-03': '文化の日', '2027-11-23': '勤労感謝の日',
};
function isJpHoliday(dateObj) {
  const y = dateObj.getFullYear();
  const m = String(dateObj.getMonth()+1).padStart(2,'0');
  const d = String(dateObj.getDate()).padStart(2,'0');
  return JP_HOLIDAYS[`${y}-${m}-${d}`] || null;
}

// 今日〜+60日 の日付プルダウン選択肢生成(曜日・祝日色分け対応)
function buildDateOptionsNext2Months(currentValue) {
  const DOW = ['日','月','火','水','木','金','土'];
  const today = new Date();
  today.setHours(0,0,0,0);
  const arr = [];
  for (let i = 0; i <= 60; i++) {
    const d = new Date(today);
    d.setDate(today.getDate() + i);
    const m = d.getMonth() + 1;
    const dd = d.getDate();
    const dow = d.getDay();
    const val = `${m}/${dd}`;
    const holiday = isJpHoliday(d);
    let color = '';
    if (dow === 0 || holiday) color = '#dc2626';      // 日曜・祝日: 赤
    else if (dow === 6) color = '#2563eb';            // 土曜: 青
    const label = `${m}/${dd}(${DOW[dow]})${holiday ? ' '+holiday : ''}`;
    arr.push({ value: val, text: label, color });
  }
  // 現在値が M/D 形式以外(旧ISOデータ等)→ 正規化して範囲内なら選択、なければ範囲外表示
  const normalized = toMonthDay(currentValue);
  if (normalized && !arr.some(o => o.value === normalized)) {
    arr.unshift({ value: normalized, text: `${normalized} (範囲外)`, color: '#6b7280' });
  }
  return arr;
}

// 日付プルダウンのHTML生成(単一select、曜日色付き)
function monthDaySelectHtml(fieldKey, value) {
  const opts = buildDateOptionsNext2Months(value);
  const selectedVal = toMonthDay(value);
  const options = '<option value="">-</option>' +
    opts.map(o => {
      const styleAttr = o.color ? ` style="color:${o.color};"` : '';
      const sel = o.value === selectedVal ? ' selected' : '';
      return `<option value="${escapeHtml(o.value)}"${sel}${styleAttr}>${escapeHtml(o.text)}</option>`;
    }).join('');
  return `<select data-h="${fieldKey}" style="width:130px; font-size:11px;">${options}</select>`;
}

// 自社工事判定: supplier が空 or "ビルドクラスタ"
function isJishaLine(line) {
  const s = (line.supplier || '').trim();
  return !s || s === 'ビルドクラスタ';
}

function renderHatchuRows() {
  const tbody = document.getElementById('hatchu-tbody');
  if (!tbody) return;
  const lines = state.estimate?.lines || [];
  // 表示用: item 空行はスキップ + 減工事行はセクション末尾にまとめる(表示順は安定保持)
  const allVisible = lines.map((l, origIdx) => ({ l, origIdx })).filter(x => x.l.item);
  // 外注 vs 自社 に分割 → 各セクション内で 通常→減工事 の順に並べる
  const sortReducedLast = arr => arr.slice().sort((a, b) => {
    const ar = a.l.reduced ? 1 : 0;
    const br = b.l.reduced ? 1 : 0;
    return ar - br; // 通常(0)が先、減工事(1)が後
  });
  const gaichuuVisible = sortReducedLast(allVisible.filter(x => !isJishaLine(x.l)));
  const jishaVisible = sortReducedLast(allVisible.filter(x => isJishaLine(x.l)));
  document.getElementById('hatchu-row-count').textContent = `外注 ${gaichuuVisible.length}件 / 自社 ${jishaVisible.length}件(見積と連動)`;
  // 業者候補
  const workshopOpts = [...new Set(lines.map(l => l.supplier).filter(Boolean).concat(COL_GROUPS.hatchu.cols))];
  const wsListId = 'dl-hatchu-workshops';
  let wsDatalist = document.getElementById(wsListId);
  if (!wsDatalist) {
    wsDatalist = document.createElement('datalist');
    wsDatalist.id = wsListId;
    document.body.appendChild(wsDatalist);
  }
  wsDatalist.innerHTML = workshopOpts.map(w => `<option value="${escapeHtml(w)}">`).join('');

  const renderSection = (items, sectionLabel, sectionColor, bgColor) => {
    if (items.length === 0) {
      return `<tr class="hatchu-section-row"><td colspan="14" style="background:${bgColor}; color:${sectionColor}; font-weight:bold; padding:6px 10px; border-top:2px solid ${sectionColor};">${escapeHtml(sectionLabel)} <span style="font-size:11px; font-weight:normal; color:#6b7280;">(該当なし)</span></td></tr>`;
    }
    const header = `<tr class="hatchu-section-row"><td colspan="14" style="background:${bgColor}; color:${sectionColor}; font-weight:bold; padding:6px 10px; border-top:2px solid ${sectionColor};">${escapeHtml(sectionLabel)} <span style="font-size:11px; font-weight:normal; color:#6b7280;">(${items.length}件)</span></td></tr>`;
    const rowsHtml = items.map(({ l, origIdx }, i) => {
    const reducedClass = l.reduced ? ' class="reduced-row"' : '';
    const estAmt   = lineAmount(l, 'estimate');
    const orderAmt = lineAmount(l, 'order');
    const grossProfit = estAmt - orderAmt;
    // 粗利率(estAmt=0 や マイナス時は判定なし)
    const grossRate = estAmt > 0 ? (grossProfit / estAmt * 100) : null;
    // 25%以上=緑OK / 10〜24%=黄注意 / 10%未満=赤NG
    let grossBg = '#f3f4f6', grossColor = '#6b7280';
    if (grossRate == null) { grossBg = '#f3f4f6'; grossColor = '#6b7280'; }
    else if (grossRate >= 25) { grossBg = '#dcfce7'; grossColor = '#166534'; }
    else if (grossRate >= 10) { grossBg = '#fef3c7'; grossColor = '#92400e'; }
    else { grossBg = '#fee2e2'; grossColor = '#b91c1c'; }
    const grossDisp = grossRate != null
      ? `${fmtNum(grossProfit)}<br><small style="font-weight:normal;">${grossRate.toFixed(1)}%</small>`
      : fmtNum(grossProfit);
    // 自社工事行は supplier 欄の表示を "ビルドクラスタ" に(placeholder)
    const supplierValue = l.supplier || '';
    const supplierPlaceholder = isJishaLine(l) ? 'ビルドクラスタ(自社)' : '業者名';
    // 工事店プルダウン: 既存候補(workshopOpts) + 現在値(リストに無ければ追加) + (その他...)
    const opts = [...workshopOpts];
    if (supplierValue && !opts.includes(supplierValue)) opts.unshift(supplierValue);
    const supplierSelect = `<select data-h="supplier" data-h-type="select" style="width:100%;" title="工事店を選択(その他を選ぶと自由入力)">
      <option value="" ${!supplierValue ? 'selected' : ''}>${escapeHtml(supplierPlaceholder)}</option>
      ${opts.map(o => `<option value="${escapeHtml(o)}" ${o === supplierValue ? 'selected' : ''}>${escapeHtml(o)}</option>`).join('')}
      <option value="__other__">＋ その他(自由入力)…</option>
    </select>`;
    return `<tr data-i="${origIdx}" draggable="true"${reducedClass}>
      <td class="num">${i+1}</td>
      <td>${supplierSelect}</td>
      <td style="white-space:nowrap;">
        ${monthDaySelectHtml('hatchuPeriodStart', l.hatchuPeriodStart)}
        <span style="font-size:11px; color:#6b7280;">〜</span>
        ${monthDaySelectHtml('hatchuPeriodEnd', l.hatchuPeriodEnd)}
      </td>
      <td><input type="text" data-h="room" value="${escapeHtml(l.room||'')}" style="width:100%;"></td>
      <td><input type="text" data-h="item" value="${escapeHtml(l.item||'')}" style="width:100%;"></td>
      <td>${isJishaLine(l) ? '<span style="color:#9ca3af; font-size:11px;">—</span>' : `<input type="text" data-h="hatchuSurface" value="${escapeHtml(l.hatchuSurface||'')}" style="width:100%;" placeholder="壁全面">`}</td>
      <td><input type="text" data-h="specs" value="${escapeHtml(l.specs||'')}" style="width:100%;" placeholder="量産クロス 等"></td>
      <td class="num"><input type="text" data-h="qty" value="${escapeHtml(String(l.qty||''))}" style="width:100%;" inputmode="decimal"></td>
      <td><input type="text" data-h="unit" value="${escapeHtml(l.unit||'')}" style="width:100%;"></td>
      <td class="num"><input type="text" data-h="orderPrice" value="${fmtNum(l.orderPrice||0)}" style="width:100%; text-align:right;" inputmode="decimal" title="発注単価(見積タブと連動)"></td>
      <td class="num"><input type="text" data-h="orderAmount" value="${fmtNum(orderAmt)}" style="width:100%; text-align:right;" inputmode="decimal" title="発注小計(=数量×発注単価)。手入力で上書き、空にすると自動再計算"></td>
      <td class="num no-print" style="background:#f0f9ff; color:#1e3a8a;" title="参考(印刷外): 見積単価">${fmtNum(l.unitPrice||0)}</td>
      <td class="num no-print" style="background:${grossBg}; color:${grossColor}; font-weight:600;" title="粗利 = ${fmtNum(estAmt)} − ${fmtNum(orderAmt)} = ${fmtNum(grossProfit)}\n粗利率 = ${grossRate!=null?grossRate.toFixed(1)+'%':'(計算不可)'}\n判定: 25%以上=緑 / 10〜24%=黄 / 10%未満=赤">${grossDisp}</td>
      <td style="white-space:nowrap;">
        <button class="btn-h-reduce" title="${l.reduced?'解除':'減工事マーク'}" style="background:${l.reduced?'#fcd34d':'transparent'};">${l.reduced?'➕':'➖'}</button>
        <button class="danger btn-h-del" title="削除(見積からも削除)">×</button>
      </td>
    </tr>`;
    }).join('');
    return header + rowsHtml;
  };

  const gaichuuHtml = renderSection(gaichuuVisible, '🔧 工事店担当(業者別)', '#7c2d12', '#fed7aa');
  const jishaHtml = renderSection(jishaVisible, '🏠 自社工事(ビルドクラスタ)', '#1e40af', '#dbeafe');
  tbody.innerHTML = gaichuuHtml + jishaHtml;

  // イベントバインド: どのフィールドを編集しても state.estimate.lines を直接更新 → 見積タブと連動
  // 値が長くて見切れる可能性のあるテキスト系フィールドは title 属性をリアルタイム更新 → ホバーで全文表示
  tbody.querySelectorAll('input[data-h], select[data-h]').forEach(el => {
    const k = el.dataset.h;
    if (['qty','orderPrice','orderAmount','hatchuPeriodStart','hatchuPeriodEnd'].includes(k)) return;
    const updateTitle = () => {
      if (el.tagName === 'SELECT') {
        const opt = el.options[el.selectedIndex];
        el.title = opt ? (opt.text || el.value) : (el.value || '');
      } else {
        el.title = el.value || '';
      }
    };
    updateTitle();
    el.addEventListener('input', updateTitle);
    el.addEventListener('change', updateTitle);
  });
  tbody.querySelectorAll('input[data-h]').forEach(inp => {
    inp.addEventListener('input', e => {
      const tr = e.target.closest('tr');
      const idx = Number(tr.dataset.i);
      const k = inp.dataset.h;
      let v = inp.value;
      if (k === 'qty' || k === 'orderPrice' || k === 'orderAmount') v = parseNum(v) || 0;
      const line = state.estimate.lines[idx];
      if (!line) return;
      // hatchuRemark に手入力値が入った瞬間に override として保存(後方互換)
      if (k === 'hatchuRemark') {
        const amt = lineAmount(line, 'estimate');
        const autoRemark = amt > 0 ? `¥${amt.toLocaleString()}` : '';
        line.hatchuRemark = (v === autoRemark) ? '' : v;
      } else if (k === 'orderPrice') {
        line.orderPrice = v;
        line.orderAmountOverride = null; // 単価変更で override 解除 → 数量×単価
      } else if (k === 'orderAmount') {
        // 発注小計 上書き: 空にすると自動計算に戻る
        const raw = (inp.value || '').replace(/,/g,'').trim();
        line.orderAmountOverride = raw === '' ? null : (Number(raw) || 0);
      } else {
        line[k] = v;
      }
      saveEstimate();
      // 業者・数量・金額に影響する変更はリアルタイムサマリー更新
      if (k === 'supplier' || k === 'qty' || k === 'hatchuRemark' || k === 'orderPrice' || k === 'orderAmount') {
        renderHatchuBreakdown();
      }
      // 工事店(supplier)を変更したら 見積タブの「発注先」入力にもDOM同期
      if (k === 'supplier' && typeof syncSupplierBetweenTabs === 'function') {
        syncSupplierBetweenTabs(idx, line.supplier || '', 'hatchu');
      }
      // 発注単価/数量/小計 を変更したら 見積タブの該当セルと粗利表示にもDOM同期
      if ((k === 'orderPrice' || k === 'qty' || k === 'orderAmount') && typeof syncOrderPriceBetweenTabs === 'function') {
        syncOrderPriceBetweenTabs(idx, line.orderPrice || 0, 'hatchu');
      }
      // 自タブの 発注小計 / 粗利 セル即時再計算(input がフォーカス中のものは触らない)
      if (k === 'qty' || k === 'orderPrice' || k === 'orderAmount') {
        const tr2 = e.target.closest('tr');
        const orderAmt2 = lineAmount(line, 'order');
        const estAmt2 = lineAmount(line, 'estimate');
        const gross = estAmt2 - orderAmt2;
        const orderAmtInp = tr2.querySelector('input[data-h="orderAmount"]');
        if (orderAmtInp && document.activeElement !== orderAmtInp && (line.orderAmountOverride == null)) {
          orderAmtInp.value = fmtNum(orderAmt2);
        }
        const grossCell = tr2.querySelectorAll('td.no-print')[1]; // 粗利セル(2番目のno-print)
        if (grossCell) {
          updateGrossCellDisplay(grossCell, gross, estAmt2, orderAmt2);
        }
      }
    });
  });
  // 日付プルダウン(工期)は select 要素だが data-h 属性なので既存の input[data-h] ループで拾えない
  // select[data-h] にも change イベントを紐付け(M/D 形式に正規化)
  tbody.querySelectorAll('select[data-h]').forEach(sel => {
    sel.addEventListener('change', e => {
      const tr = e.target.closest('tr');
      const idx = Number(tr.dataset.i);
      const k = sel.dataset.h;
      const line = state.estimate.lines[idx];
      if (!line) return;
      // 工期フィールドは M/D に正規化して保存
      if (k === 'hatchuPeriodStart' || k === 'hatchuPeriodEnd') {
        const newVal = toMonthDay(sel.value);
        line[k] = newVal;
        // 同じグループの他の行にも一括反映
        // - 業者あり → 同 supplier の他行
        // - 自社(supplier空 or ビルドクラスタ) → 全自社行(セクション内一括)
        const isJisha = isJishaLine(line);
        let groupLabel = '';
        let count = 0;
        state.estimate.lines.forEach(l => {
          if (l === line) return;
          const sameGroup = isJisha ? isJishaLine(l) : (line.supplier && l.supplier === line.supplier);
          if (sameGroup && l[k] !== newVal) {
            l[k] = newVal;
            count++;
          }
        });
        groupLabel = isJisha ? 'ビルドクラスタ(自社)' : (line.supplier || '');
        if (groupLabel) {
          saveEstimate();
          renderHatchuRows();
          if (count > 0) {
            const label = k === 'hatchuPeriodStart' ? '開始日' : '終了日';
            showToast(`「${groupLabel}」の${count}行にも${label}を反映`);
          }
          return;
        }
      } else if (k === 'supplier') {
        // 工事店プルダウン: 「__other__」選択 → 自由入力
        let v = sel.value;
        if (v === '__other__') {
          const typed = (prompt('工事店名を入力(設定タブで追加すれば次回からプルダウンに出ます)', line.supplier || '') || '').trim();
          if (typed) {
            v = typed;
          } else {
            // キャンセル → 元の値に戻す
            sel.value = line.supplier || '';
            return;
          }
        }
        line.supplier = v;
        // マスタから単価自動入力(空/0の時のみ)
        if (v && line.itemRef) {
          const m = state.master.find(x => String(x.項目番号) === String(line.itemRef));
          if (m && m[v] != null && (!line.orderPrice || line.orderPrice === 0)) {
            line.orderPrice = Number(m[v]);
          }
        }
        saveEstimate();
        renderHatchuBreakdown();
        if (typeof syncSupplierBetweenTabs === 'function') {
          syncSupplierBetweenTabs(idx, line.supplier || '', 'hatchu');
        }
        // workshop プルダウンの選択肢更新のため再描画
        renderHatchuRows();
        return;
      } else {
        line[k] = sel.value;
      }
      saveEstimate();
    });
  });
  tbody.querySelectorAll('.btn-h-del').forEach(btn => btn.addEventListener('click', e => {
    const idx = Number(e.target.closest('tr').dataset.i);
    state.estimate.lines.splice(idx, 1);
    saveEstimate();
    renderHatchu();
    if (typeof renderEstimate === 'function') renderEstimate();
  }));
  tbody.querySelectorAll('.btn-h-reduce').forEach(btn => btn.addEventListener('click', e => {
    const idx = Number(e.target.closest('tr').dataset.i);
    const line = state.estimate.lines[idx];
    if (!line) return;
    line.reduced = !line.reduced;
    if (typeof autoUpdateEstimateStatus === 'function') autoUpdateEstimateStatus();
    saveEstimate();
    renderHatchuRows();
    if (typeof renderEstimate === 'function') renderEstimate();
  }));

  // 行ドラッグ&ドロップ並び替え(発注書)
  tbody.querySelectorAll('tr[data-i]').forEach(tr => {
    tr.addEventListener('dragstart', e => {
      // 入力中の input/select からのドラッグはキャンセル(テキスト選択優先)
      if (['INPUT','SELECT','TEXTAREA','BUTTON'].includes((e.target?.tagName)||'')) {
        e.preventDefault(); return;
      }
      e.dataTransfer.effectAllowed = 'move';
      e.dataTransfer.setData('text/plain', tr.dataset.i);
      tr.classList.add('row-dragging');
    });
    tr.addEventListener('dragend', () => {
      tr.classList.remove('row-dragging');
      tbody.querySelectorAll('tr').forEach(r => r.classList.remove('row-drop-before','row-drop-after'));
    });
    tr.addEventListener('dragover', e => {
      e.preventDefault();
      e.dataTransfer.dropEffect = 'move';
      const rect = tr.getBoundingClientRect();
      const after = (e.clientY - rect.top) > rect.height / 2;
      tbody.querySelectorAll('tr').forEach(r => r.classList.remove('row-drop-before','row-drop-after'));
      tr.classList.add(after ? 'row-drop-after' : 'row-drop-before');
    });
    tr.addEventListener('dragleave', () => {
      tr.classList.remove('row-drop-before','row-drop-after');
    });
    tr.addEventListener('drop', e => {
      e.preventDefault();
      const rect = tr.getBoundingClientRect();
      const after = (e.clientY - rect.top) > rect.height / 2;
      tr.classList.remove('row-drop-before','row-drop-after');
      const srcI = Number(e.dataTransfer.getData('text/plain'));
      const dstI = Number(tr.dataset.i);
      if (Number.isNaN(srcI) || Number.isNaN(dstI) || srcI === dstI) return;
      // moveLineTo は state を変更し見積タブを再描画 → 発注書タブも明示的に再描画
      moveLineTo(srcI, dstI, after ? 'after' : 'before');
      renderHatchu();
    });
  });
}

// 業者別発注金額まとめ(リアルタイム表示)
function renderHatchuBreakdown() {
  const el = document.getElementById('hatchu-breakdown-summary');
  if (!el) return;
  const lines = state.estimate?.lines || [];
  const activeLines = lines.filter(l => l.item && !l.reduced);
  if (!activeLines.length) {
    el.innerHTML = '<div style="color:#6b7280;">(まだ明細がありません)</div>';
    return;
  }
  // 業者別集計(発注小計ベース)
  const supplierTotals = {};
  let jishaTotal = 0;
  let gaichuuTotal = 0;
  activeLines.forEach(l => {
    const amt = lineAmount(l, 'order');
    if (isJishaLine(l)) {
      jishaTotal += amt;
    } else {
      const sup = l.supplier;
      supplierTotals[sup] = (supplierTotals[sup] || 0) + amt;
      gaichuuTotal += amt;
    }
  });
  const grandTotal = gaichuuTotal; // 自社工事は発注対象外なので総合計に含めない
  const breakdown = Object.entries(supplierTotals).sort((a, b) => b[1] - a[1]);
  // 減工事合計(外注分のみ・発注小計ベース)
  const reducedTotal = lines.filter(l => l.item && l.reduced && !isJishaLine(l)).reduce((s, l) => s + lineAmount(l, 'order'), 0);
  const rowsHtml = breakdown.map(([sup, amt]) => {
    const pct = grandTotal > 0 ? (amt / grandTotal * 100).toFixed(1) : '0.0';
    const rowCount = activeLines.filter(l => !isJishaLine(l) && l.supplier === sup).length;
    return `<tr>
      <td style="padding:3px 8px;">${escapeHtml(sup)}</td>
      <td style="padding:3px 8px; text-align:right; color:#6b7280; font-size:11px;">${rowCount}行</td>
      <td style="padding:3px 8px; text-align:right; font-weight:600;">¥${amt.toLocaleString()}</td>
      <td style="padding:3px 8px; text-align:right; color:#6b7280;">${pct}%</td>
    </tr>`;
  }).join('');
  const reducedRow = reducedTotal > 0 ? `<tr style="background:#fef3c7; color:#78350f; font-style:italic;">
    <td style="padding:3px 8px;">🟡 減工事(総合計には含まず)</td>
    <td style="padding:3px 8px; text-align:right; font-size:11px;">${lines.filter(l => l.reduced && !isJishaLine(l)).length}行</td>
    <td style="padding:3px 8px; text-align:right;">-¥${reducedTotal.toLocaleString()}</td>
    <td style="padding:3px 8px;"></td>
  </tr>` : '';
  el.innerHTML = `<table style="width:100%; border-collapse:collapse; max-width:560px;">
    <thead><tr style="background:#e0e7ff;">
      <th style="padding:3px 8px; text-align:left; font-size:11px;">業者</th>
      <th style="padding:3px 8px; text-align:right; font-size:11px;">行数</th>
      <th style="padding:3px 8px; text-align:right; font-size:11px;">発注金額</th>
      <th style="padding:3px 8px; text-align:right; font-size:11px;">構成比</th>
    </tr></thead>
    <tbody>
      ${rowsHtml}
      <tr style="background:#1e3a8a; color:#fff; font-weight:bold;">
        <td style="padding:4px 8px;">工事店 発注 総合計</td>
