// "M/D" 形式の文字列を分解(ISO YYYY-MM-DD も受け入れ)
function parseMonthDay(s) {
  if (!s) return { m:'', d:'' };
  const str = String(s).trim();
  // YYYY-MM-DD 形式も M/D として扱う(旧データ互換)
  const iso = /^\d{4}-(\d{2})-(\d{2})$/.exec(str);
  if (iso) return { m: String(Number(iso[1])), d: String(Number(iso[2])) };
  const m = /^(\d{1,2})\/(\d{1,2})$/.exec(str);
  if (!m) return { m:'', d:'' };
  return { m: m[1], d: m[2] };
}
// 任意フォーマット → "M/D" に正規化
function toMonthDay(s) {
  const { m, d } = parseMonthDay(s);
  return (m && d) ? `${m}/${d}` : '';
}

