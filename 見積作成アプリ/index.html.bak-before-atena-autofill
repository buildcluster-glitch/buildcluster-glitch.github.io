// 既存の見積にテンプレを適用(末尾追加 / 全置換)
function getPatternRowsForApply(patternKey) {
  const merged = getMergedPatterns();
  const p = merged[patternKey] || merged['標準'];
  if (!p) return [];
  return p.rows.map(spec => {
    const row = { ...emptyLine(), ...spec };
    // マスタ自動取込
    if (row.item) {
      const m = (state.master || []).find(x => x.項目 === row.item);
      if (m) {
        row.itemRef = m.項目番号;
        if (!row.unit) row.unit = m.単位 || '式';
        if (!row.qty) row.qty = 1;
        const priceCol = state.settings?.priceCol || '山一地所';
