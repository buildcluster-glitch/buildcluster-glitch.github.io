// モードに応じた金額を返す
function lineAmount(l, mode) {
  mode = mode || state.settings.docMode || 'estimate';
  if (mode === 'order') {
    // 'order' = 外注費(発注書PDFで業者に見せる金額)。材料費は含めない。
    if (l.orderAmountOverride != null && l.orderAmountOverride !== '') return Number(l.orderAmountOverride) || 0;
    return (Number(l.qty)||0) * (Number(l.orderPrice)||0);
  }
  if (l.amountOverride != null && l.amountOverride !== '') return Number(l.amountOverride) || 0;
  return (Number(l.qty)||0) * (Number(l.unitPrice)||0);
}

// 行の原価小計 = 材料費 + 外注費(=lineAmount order)
// 粗利計算・原価集計用(発注書PDFでは使わない)
function lineCost(l) {
  const qty = Number(l.qty) || 0;
  const mat = qty * (Number(l.materialPrice) || 0);
  const labor = lineAmount(l, 'order');
  return mat + labor;
}

function isOverridden(l, mode) {
  mode = mode || state.settings.docMode || 'estimate';
  const ov = mode === 'order' ? l.orderAmountOverride : l.amountOverride;
  return ov != null && ov !== '';
}

// 現在モードで明細として扱う行(発注書モードは絞込考慮)
function filteredLineIndexes() {
  const mode = state.settings.docMode || 'estimate';
  if (mode !== 'order') return state.estimate.lines.map((_, i) => i);
  const filter = state.estimate.meta.orderSupplierFilter || '__all__';
  return state.estimate.lines.map((l, i) => ({ l, i }))
    .filter(({l}) => filter === '__all__' ? true : (l.supplier || '') === filter)
    .map(({i}) => i);
}

// 行移動: 表示中の隣接行と入替(絞込中でも表示順のまま動く)
function moveLine(i, direction) {
  const visible = filteredLineIndexes();
  const pos = visible.indexOf(i);
  if (pos < 0) return;
  const targetPos = pos + direction;
  if (targetPos < 0 || targetPos >= visible.length) return;
  const j = visible[targetPos];
  const arr = state.estimate.lines;
  [arr[i], arr[j]] = [arr[j], arr[i]];
  saveEstimate();
  renderEstimate();
}

// オートフィル: srcIの内容を、srcI+1 〜 endI の範囲の行に複製
// 範囲内に既存行(明細入り)があれば「上書き確認」。空行なら上書き。範囲を超えたら新規行を追加。
function autofillRange(srcI, endI) {
  const src = state.estimate.lines[srcI];
  if (!src) return;
  const count = endI - srcI;
  // 対象行の状態を確認
  const targets = [];
  for (let i = srcI + 1; i <= endI; i++) {
    if (i < state.estimate.lines.length) targets.push({ idx:i, line: state.estimate.lines[i] });
    else targets.push({ idx:i, line: null });
  }
  const nonEmpty = targets.filter(t => t.line && t.line.item);
  if (nonEmpty.length && !confirm(`${count}行にコピーします。うち${nonEmpty.length}行は既に内容があります。上書きしますか?`)) return;

  targets.forEach(t => {
    const clone = JSON.parse(JSON.stringify(src));
    if (t.idx < state.estimate.lines.length) state.estimate.lines[t.idx] = clone;
    else state.estimate.lines.push(clone);
  });
  saveEstimate(); renderEstimate();
}

// ドラッグ&ドロップ: srcIを dstIの直前/直後 に移動
function moveLineTo(srcI, dstI, position) {
  if (srcI === dstI) return;
  const arr = state.estimate.lines;
  const [item] = arr.splice(srcI, 1);
  let insertAt = (srcI < dstI) ? dstI - 1 : dstI;
  if (position === 'after') insertAt += 1;
  if (insertAt < 0) insertAt = 0;
  if (insertAt > arr.length) insertAt = arr.length;
  arr.splice(insertAt, 0, item);
  // 自動統合はしない(ユーザーの配置意図を尊重) → まとめたい時は専用ボタン
  saveEstimate();
  renderEstimate();
}

// カテゴリが飛び地になっていたら一つのブロックに統合する(stable sort)
// 例: [A, B, A, C, A] → [A, A, A, B, C]
// 各カテゴリは初出位置を基準に並べ、同じカテゴリ内の行順は維持
function consolidateCategoryBlocks() {
  const lines = state.estimate.lines;
  if (lines.length < 3) return false;
  // 空カテゴリ(未入力)は飛び地統合の対象外にする → 末尾にまとめるのは避け、現在位置維持
  // 各カテゴリの初出 index を記録
  const firstIdxByCat = new Map();
  lines.forEach((l, i) => {
    const cat = l.category || '';
    if (!firstIdxByCat.has(cat)) firstIdxByCat.set(cat, i);
  });
  // 飛び地判定: あるカテゴリが一度途切れて再出現したらtrue
  let needsMerge = false;
  let seenCats = new Set();
  let prevCat = null;
  for (const l of lines) {
    const cat = l.category || '';
    if (cat !== prevCat) {
      if (seenCats.has(cat)) { needsMerge = true; break; }
      seenCats.add(cat);
      prevCat = cat;
    }
  }
  if (!needsMerge) return false;
  // 初出 index によるstable sort
  const sorted = lines.slice().sort((a, b) => {
    const aCat = a.category || '';
    const bCat = b.category || '';
    return firstIdxByCat.get(aCat) - firstIdxByCat.get(bCat);
  });
  state.estimate.lines = sorted;
  return true;
}

// カテゴリブロック丸ごとを移動(srcCatに属する全行を、targetCatのブロックの直前/直後へ)
function moveCategoryBlock(srcCat, targetCat, position /* 'before' | 'after' */) {
  const lines = state.estimate.lines;
  const srcLines = [];
  const rest = [];
  lines.forEach(l => {
    if ((l.category||'') === srcCat) srcLines.push(l);
    else rest.push(l);
  });
  if (srcLines.length === 0) return;
  // rest の中で targetCat が出現するレンジを探す
  let firstIdx = -1, lastIdx = -1;
  for (let i = 0; i < rest.length; i++) {
    if ((rest[i].category||'') === targetCat) {
      if (firstIdx < 0) firstIdx = i;
      lastIdx = i;
    }
  }
  let insertAt;
  if (firstIdx < 0) {
    insertAt = rest.length; // 見つからないなら末尾
  } else if (position === 'after') {
    insertAt = lastIdx + 1;
  } else {
    insertAt = firstIdx;
  }
  rest.splice(insertAt, 0, ...srcLines);
  state.estimate.lines = rest;
  saveEstimate();
  renderEstimate();
  showToast(`【${srcCat}】を【${targetCat}】の${position==='after'?'後':'前'}に移動`);
}

// 発注先ドロップダウンの選択肢(マスタ列のsubcontractor名 + 現在明細で使われている名前)
function supplierOptions() {
  const fromCols = COL_GROUPS.hatchu.cols;
  const fromLines = [...new Set(state.estimate.lines.map(l => l.supplier).filter(Boolean))];
  return [...new Set([...fromCols, ...fromLines, 'ビルドクラスタ'])];
