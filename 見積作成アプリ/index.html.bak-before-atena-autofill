const NUMERIC_COLS = new Set([...PRICE_COLS, '数量','粗利','産廃数量']);
const MASTER_COLUMNS = ['項目番号','大分類','カテゴリー','項目','単位', ...PRICE_COLS, '室名','数量','粗利','備考','産廃品目','産廃数量'];
const MASTER_TEXT_COLS = ['項目番号','大分類','カテゴリー','項目','単位','室名','備考','産廃品目','施工業者'];
let masterEditIdx = null;

function masterViewCols() {
  const mode = document.getElementById('master-view-mode').value;
  if (mode === 'motouke')  return ['項目番号','カテゴリー','項目','単位', ...COL_GROUPS.moto.cols, ...COL_GROUPS.sanko.cols];
  if (mode === 'hatchu')   return ['項目番号','カテゴリー','項目','単位','施工業者', ...COL_GROUPS.hatchu.cols, ...COL_GROUPS.material.cols];
  if (mode === 'full')     return MASTER_COLUMNS;
  // concise: 項目番号/カテゴリー/項目/単位/数量/現行選択の元請け+発注先+材料費
  const moto = state.settings.priceCol || '山一地所';
  const hatchu = state.settings.priceColOrder || '思綺美装';
  // 重複排除(moto/hatchuが同じ列名のとき)
  const priceCols = [];
  if (moto) priceCols.push(moto);
  if (hatchu && hatchu !== moto) priceCols.push(hatchu);
  return ['項目番号','カテゴリー','項目','単位','数量', ...priceCols, '材料費','備考'];
}

function renderMaster() {
  const cols = masterViewCols();
  // ヘッダ: グループ色分け
  const thCells = cols.map(c => {
    const isNum = NUMERIC_COLS.has(c);
    let bg = '';
    if (COL_GROUPS.moto.cols.includes(c)) bg = 'background:#dbeafe;';
    else if (COL_GROUPS.hatchu.cols.includes(c)) bg = 'background:#fed7aa;';
    else if (COL_GROUPS.sanko.cols.includes(c)) bg = 'background:#e5e7eb;';
    else if (COL_GROUPS.material.cols.includes(c)) bg = 'background:#fef3c7;';
    return `<th class="${isNum?'num':''}" style="${bg}">${escapeHtml(c)}</th>`;
  });
  masterThead.innerHTML = `<tr>${thCells.join('')}<th class="no-print" style="width:60px;"></th></tr>`;

  const q = masterSearch.value.trim().toLowerCase();
  const cat = masterFilterCat.value;
  const rows = state.master.filter(r => {
    if (cat && r.カテゴリー !== cat) return false;
    if (!q) return true;
    const hay = `${r.カテゴリー||''} ${r.項目||''} ${r.大分類||''} ${r.備考||''}`.toLowerCase();
    return hay.includes(q);
  });
  masterCount.textContent = `${rows.length}件`;
  masterTbody.innerHTML = rows.map(r => {
    const realIdx = state.master.indexOf(r);
    const selected = masterEditIdx === realIdx;
    const tds = cols.map(c => {
      const isNum = NUMERIC_COLS.has(c);
      const v = r[c];
      let bg = '';
      if (COL_GROUPS.moto.cols.includes(c)) bg = 'background:#eff6ff;';
      else if (COL_GROUPS.hatchu.cols.includes(c)) bg = 'background:#fff7ed;';
      else if (COL_GROUPS.sanko.cols.includes(c)) bg = 'background:#f9fafb;';
      else if (COL_GROUPS.material.cols.includes(c)) bg = 'background:#fffbeb;';
      const disp = v == null || v === '' ? '' : (isNum ? Number(v).toLocaleString() : v);
      return `<td class="${isNum?'num':''}" style="${bg}">${escapeHtml(disp)}</td>`;
    }).join('');
    return `<tr data-idx="${realIdx}" ${selected?'style="background:#fef9c3;"':''}><td class="no-print" style="padding:0;">${tds.length?'':''}</td>`
      .replace('<td class="no-print" style="padding:0;"></td>','') // 空セルtoken除去
      + tds
      + `<td class="no-print"><button class="btn-edit-master" title="編集">✎</button></td></tr>`;
  }).join('');
  // 行クリックで編集パネルを開く
  masterTbody.querySelectorAll('tr').forEach(tr => {
    tr.addEventListener('click', e => {
      if (e.target.closest('button')) return;
      openEditPane(Number(tr.dataset.idx));
    });
  });
  masterTbody.querySelectorAll('.btn-edit-master').forEach(btn => {
    btn.addEventListener('click', e => {
      e.stopPropagation();
      openEditPane(Number(e.target.closest('tr').dataset.idx));
    });
  });
}

// 編集パネル
function openEditPane(idx) {
  masterEditIdx = idx;
  const r = state.master[idx];
  document.getElementById('master-edit-title').textContent = `編集: ${r.項目 || '(無題)'}`;
  const body = document.getElementById('master-edit-body');
  const numInp = (col) => `<input type="text" inputmode="decimal" data-edit="${col}" value="${r[col] != null && r[col] !== '' ? Number(r[col]).toLocaleString() : ''}" style="width:100%;">`;
  const txtInp = (col, w) => `<input type="text" data-edit="${col}" value="${escapeHtml(r[col] ?? '')}" style="width:${w||'100%'};">`;
  const section = (title, cols, bg, note, opts) => {
    opts = opts || {};
    const bulkBtn = opts.bulk
      ? `<button type="button" data-bulk-fill="${escapeHtml(opts.bulk)}" title="一番上(${escapeHtml(cols[0]||'')})の金額を、空欄の全列に一括コピー" style="margin-left:8px; font-size:11px; padding:2px 6px; background:#fff; border:1px solid var(--line); border-radius:4px; cursor:pointer;">↓ 一番上の金額を全列に反映</button>`
      : '';
    return `
    <div style="margin-bottom:12px; padding:8px; background:${bg}; border-radius:6px;" ${opts.bulk ? `data-section="${escapeHtml(opts.bulk)}"` : ''}>
      <div style="font-weight:600; font-size:12px; margin-bottom:6px; display:flex; align-items:center; flex-wrap:wrap;">
        <span>${title}</span>
        ${note?`<span style="font-weight:normal; color:var(--muted); margin-left:8px;">${note}</span>`:''}
        ${bulkBtn}
      </div>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:4px 8px;">
        ${cols.map(c => `<label style="font-size:11px; color:#555;">${escapeHtml(c)}</label><div>${numInp(c)}</div>`).join('')}
      </div>
    </div>`;
  };
  body.innerHTML = `
    <div style="margin-bottom:12px;">
      <div style="display:grid; grid-template-columns: auto 1fr auto 1fr; gap:4px 8px; align-items:center; font-size:12px;">
        <label>項目番号</label>${txtInp('項目番号')}
        <label>単位</label>${txtInp('単位')}
        <label>カテゴリー</label>
        <div><select data-edit="カテゴリー" style="width:100%;">${categoryOptionsFor(r.カテゴリー)}</select></div>
        <label>大分類</label>
        <div><select data-edit="大分類" style="width:100%;"><option value="原復" ${r.大分類==='原復'?'selected':''}>原復</option><option value="修繕" ${r.大分類==='修繕'?'selected':''}>修繕</option><option value="Dクレ" ${r.大分類==='Dクレ'?'selected':''}>Dクレ</option><option value="" ${!r.大分類?'selected':''}>(なし)</option></select></div>
        <label>項目名</label><div style="grid-column: span 3;">${txtInp('項目')}</div>
        <label>室名</label>${txtInp('室名')}
        <label>数量</label>${numInp('数量')}
        <label>施工業者(ヒント)</label><div style="grid-column: span 3;">${txtInp('施工業者')}</div>
        <label>備考</label><div style="grid-column: span 3;"><textarea data-edit="備考" style="width:100%; min-height:40px;">${escapeHtml(r.備考 ?? '')}</textarea></div>
      </div>
    </div>
    ${section('🔵 元請け単価', COL_GROUPS.moto.cols, '#eff6ff', '(見積書用)', { bulk:'moto' })}
    ${section('🧑 入居者・家主単価', COL_GROUPS.sanko.cols, '#fef3c7')}
    ${section('🟠 発注先/外注費', COL_GROUPS.hatchu.cols, '#fff7ed', '(発注書用)', { bulk:'hatchu' })}
    ${section('🟡 仕入', COL_GROUPS.material.cols, '#fffbeb')}
    <div style="margin-bottom:12px; padding:8px; background:#f3f4f6; border-radius:6px;">
      <div style="font-weight:600; font-size:12px; margin-bottom:6px;">産廃</div>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:4px 8px;">
        <label style="font-size:11px;">品目</label><div>${txtInp('産廃品目')}</div>
        <label style="font-size:11px;">数量(㎥/t)</label><div>${numInp('産廃数量')}</div>
      </div>
    </div>`;
  // 一括反映ボタン: 「↓ 一番上の金額を全列に反映」
  body.querySelectorAll('button[data-bulk-fill]').forEach(btn => {
    btn.addEventListener('click', () => {
      const sec = btn.closest('[data-section]');
      if (!sec) return;
      const inputs = sec.querySelectorAll('input[data-edit]');
      if (!inputs.length) return;
      const head = inputs[0];
      const v = head.value;
      if (!v) { alert('一番上の入力欄に金額を入れてから押してください'); head.focus(); return; }
      // 確認: 既に値が入っている列があれば上書き確認
      const filled = Array.from(inputs).slice(1).filter(i => i.value && i.value !== v);
      if (filled.length > 0) {
        if (!confirm(`他${filled.length}列に既に異なる金額が入っています。\n上書きして「${v}」に揃えますか?`)) return;
      }
      Array.from(inputs).slice(1).forEach(i => { i.value = v; });
    });
  });
  document.getElementById('master-edit-pane').style.display = 'block';
  renderMaster();
}

function categoryOptionsFor(current) {
  const known = CATEGORY_GROUPS.flatMap(g => g.minors);
  const fromMaster = uniqueCategories();
  const extras = fromMaster.filter(c => !known.includes(c));
  if (current && !known.includes(current) && !extras.includes(current)) extras.unshift(current);
  return `<option value="" ${!current?'selected':''}>(未選択)</option>`
    + CATEGORY_GROUPS.map(g => `<optgroup label="${escapeHtml(g.major)}">${g.minors.map(m => `<option value="${escapeHtml(m)}" ${m===current?'selected':''}>${escapeHtml(m)}</option>`).join('')}</optgroup>`).join('')
    + (extras.length ? `<optgroup label="未分類">${extras.map(m => `<option value="${escapeHtml(m)}" ${m===current?'selected':''}>${escapeHtml(m)}</option>`).join('')}</optgroup>` : '');
}

function closeEditPane() {
  masterEditIdx = null;
  document.getElementById('master-edit-pane').style.display = 'none';
  renderMaster();
}

document.getElementById('btn-close-edit').addEventListener('click', closeEditPane);
document.getElementById('btn-save-master-row').addEventListener('click', () => {
  if (masterEditIdx == null) return;
  const r = state.master[masterEditIdx];
  const body = document.getElementById('master-edit-body');
  body.querySelectorAll('[data-edit]').forEach(inp => {
    const col = inp.dataset.edit;
    const raw = inp.value;
    if (NUMERIC_COLS.has(col)) {
      const n = parseNum(raw);
      r[col] = (raw === '' ? null : n);
    } else {
      r[col] = raw;
    }
  });
  saveMaster();
  renderCategoryOptions();
  renderMaster();
  alert(`保存しました: ${r.項目 || r.項目番号}`);
});
document.getElementById('btn-del-master-row').addEventListener('click', () => {
  if (masterEditIdx == null) return;
  const r = state.master[masterEditIdx];
  if (!confirm(`削除しますか?\n${r.項目 || r.項目番号}`)) return;
  state.master.splice(masterEditIdx, 1);
  closeEditPane();
  saveMaster(); renderCategoryOptions(); renderMaster();
});

document.getElementById('master-view-mode').addEventListener('change', renderMaster);

masterSearch.addEventListener('input', renderMaster);
masterFilterCat.addEventListener('change', renderMaster);

document.getElementById('btn-add-row').addEventListener('click', () => {
  // 次の項目番号を自動採番: 最大値+1
  const nums = state.master.map(r => Number(r.項目番号)).filter(Number.isFinite);
  const next = nums.length ? Math.max(...nums) + 1 : 1000;
  const newRow = { 項目番号: String(next), 大分類: '原復' };
  MASTER_COLUMNS.forEach(c => { if (!(c in newRow)) newRow[c] = null; });
  newRow.施工業者 = '';
  state.master.unshift(newRow);
  saveMaster(); renderMaster();
  openEditPane(0); // 編集パネルを開く
});

document.getElementById('btn-export-json').addEventListener('click', () => {
  const blob = new Blob([JSON.stringify(state.master, null, 2)], {type:'application/json'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = `tanka_master_${formatToday()}.json`;
  a.click();
});

document.getElementById('btn-import-json').addEventListener('click', () => document.getElementById('file-input').click());
document.getElementById('file-input').addEventListener('change', e => {
  const f = e.target.files[0]; if (!f) return;
  const reader = new FileReader();
  reader.onload = () => {
    try {
      const data = JSON.parse(reader.result);
      if (!Array.isArray(data)) throw new Error('配列ではありません');
      if (!confirm(`${data.length}件で置き換えますか?`)) return;
      state.master = data;
      saveMaster(); renderCategoryOptions(); renderMaster();
    } catch(err) { alert('読み込み失敗: ' + err.message); }
  };
  reader.readAsText(f);
});

/* =========================
   設定タブ
   ========================= */
function renderCustomCompanyLists() {
  const motoCustom = (state.settings.customMotouke || []).filter(Boolean);
  const hatchuCustom = (state.settings.customHatchu || []).filter(Boolean);
  const catCustom = (state.settings.customCategories || []).filter(Boolean);
  const motoEl = document.getElementById('custom-moto-list');
  const hatchuEl = document.getElementById('custom-hatchu-list');
  const catEl = document.getElementById('custom-cat-list');
  // kind: 'moto'|'hatchu'|'cat'
  const renderList = (el, items, kind) => {
    if (!el) return;
    let defaults = [];
    if (kind === 'moto') defaults = DEFAULT_MOTO_COLS;
    else if (kind === 'hatchu') defaults = DEFAULT_HATCHU_COLS;
    else if (kind === 'cat') defaults = [...new Set(state.master.map(r => r.カテゴリー).filter(Boolean))]; // マスタの既存カテゴリ
    const badgeBg = kind === 'cat' ? '#dcfce7' : (kind === 'moto' ? '#dbeafe' : '#fed7aa');
    const badgeBorder = kind === 'cat' ? '#86efac' : (kind === 'moto' ? '#93c5fd' : '#fdba74');
    const defaultLabel = kind === 'cat' ? '(マスタ済)' : '(既定)';
    const rows = [
      ...defaults.map(c => `<div style="padding:3px 8px; background:#f3f4f6; border-radius:3px; font-size:12px; display:inline-flex; align-items:center; margin:2px; color:#6b7280;">${escapeHtml(c)} <small style="margin-left:6px;">${defaultLabel}</small></div>`),
      ...items.map(c => `<div style="padding:3px 8px; background:${badgeBg}; border:1px solid ${badgeBorder}; border-radius:3px; font-size:12px; display:inline-flex; align-items:center; margin:2px;"><b>${escapeHtml(c)}</b> <button type="button" class="btn-del-custom" data-kind="${kind}" data-name="${escapeHtml(c)}" title="削除(2段階確認)" style="margin-left:6px; padding:0 5px; font-size:11px; color:#9ca3af; background:transparent; border:1px solid #d1d5db; border-radius:3px;">🔒×</button></div>`)
    ];
    el.innerHTML = rows.join('');
  };
  renderList(motoEl, motoCustom, 'moto');
  renderList(hatchuEl, hatchuCustom, 'hatchu');
  renderList(catEl, catCustom, 'cat');
  // 削除ボタン: 2段階確認(ロック解除 → 確認ダイアログ → 入力一致で削除)
  document.querySelectorAll('#custom-moto-list .btn-del-custom, #custom-hatchu-list .btn-del-custom, #custom-cat-list .btn-del-custom').forEach(btn => {
    let unlocked = false;
    let unlockTimer = null;
    btn.addEventListener('click', () => {
      const kind = btn.dataset.kind;
      const name = btn.dataset.name;
      const kindLabel = kind === 'moto' ? '元請け' : (kind === 'hatchu' ? '外注先' : 'カテゴリー');
      // 1段階目: ロック解除(ボタン色変化、5秒以内に再度クリックで2段階目へ)
      if (!unlocked) {
        unlocked = true;
        btn.textContent = '🔓削除';
        btn.style.color = '#dc2626';
        btn.style.borderColor = '#dc2626';
        btn.style.background = '#fee2e2';
        btn.title = '5秒以内にもう一度クリックで削除確認へ';
        unlockTimer = setTimeout(() => {
          unlocked = false;
          btn.textContent = '🔒×';
          btn.style.color = '#9ca3af';
          btn.style.borderColor = '#d1d5db';
          btn.style.background = 'transparent';
          btn.title = '削除(2段階確認)';
        }, 5000);
        return;
      }
      // 2段階目: 名前一致タイプ確認
      clearTimeout(unlockTimer);
      // 利用状況チェック: マスタの単価列(moto/hatchu)に登録があるか / 既存見積で参照されているか
      let usage = [];
      if (kind === 'moto') {
        const usedInMaster = (state.master || []).filter(r => r[name] != null && r[name] !== '').length;
        if (usedInMaster > 0) usage.push(`単価マスタの単価列に ${usedInMaster}行 登録あり`);
        const usedInEst = Object.values(state.estimates || {}).filter(e => e?.meta?.motouke === name).length;
        if (usedInEst > 0) usage.push(`既存見積で元請けに ${usedInEst}件 設定済`);
      } else if (kind === 'hatchu') {
        const usedInMaster = (state.master || []).filter(r => r[name] != null && r[name] !== '').length;
        if (usedInMaster > 0) usage.push(`単価マスタの単価列に ${usedInMaster}行 登録あり`);
        const usedInEst = Object.values(state.estimates || {}).reduce((sum, e) =>
          sum + ((e?.lines || []).filter(l => l.supplier === name).length), 0);
        if (usedInEst > 0) usage.push(`既存見積の発注先に ${usedInEst}行 設定済`);
      } else if (kind === 'cat') {
        const usedInMaster = (state.master || []).filter(r => r['カテゴリー'] === name).length;
        if (usedInMaster > 0) usage.push(`単価マスタに ${usedInMaster}行 該当`);
        const usedInEst = Object.values(state.estimates || {}).reduce((sum, e) =>
          sum + ((e?.lines || []).filter(l => l.category === name).length), 0);
        if (usedInEst > 0) usage.push(`既存見積に ${usedInEst}行 該当`);
      }
      const usageMsg = usage.length
        ? `\n\n⚠ 現在の利用状況:\n  ・${usage.join('\n  ・')}\n\n削除しても既存データの値は残りますが、新規入力での候補から消えます。`
        : '';
      const typed = prompt(
        `${kindLabel} 「${name}」 を削除します。\n\n` +
        `本当に削除する場合は、上の名前を正確に入力してください:${usageMsg}`,
        ''
      );
      // ボタンを元に戻す
      unlocked = false;
      btn.textContent = '🔒×';
      btn.style.color = '#9ca3af';
      btn.style.borderColor = '#d1d5db';
      btn.style.background = 'transparent';
      btn.title = '削除(2段階確認)';
      if (typed == null) return; // キャンセル
      if (typed.trim() !== name) {
        showToast('名前が一致しないため削除をキャンセルしました', true);
        return;
      }
      const key = kind === 'moto' ? 'customMotouke' : (kind === 'hatchu' ? 'customHatchu' : 'customCategories');
      state.settings[key] = (state.settings[key] || []).filter(c => c !== name);
      saveSettings();
      if (kind !== 'cat') applyCustomCompanies();
      renderCustomCompanyLists();
      renderPriceColOptions();
      if (typeof renderCategoryOptions === 'function') renderCategoryOptions();
      showToast(`「${name}」を削除しました`);
    });
  });
}

