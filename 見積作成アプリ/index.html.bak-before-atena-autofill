// 既存見積の meta.atena を 旧表記「(株)/(有)」→「株式会社/有限会社」に置換
function migrateOldEstimateAtena(meta) {
  if (!meta) return;
  if (meta.atena) {
    if (/^\(株\)山一地所/.test(meta.atena)) meta.atena = meta.atena.replace(/^\(株\)/, '株式会社');
    else if (/^\(有\)みどり不動産/.test(meta.atena)) meta.atena = meta.atena.replace(/^\(有\)/, '有限会社');
    else if (/^\(株\)ジェイ・エス・ビー・ネットワーク/.test(meta.atena)) meta.atena = meta.atena.replace(/^\(株\)/, '株式会社');
  }
}

function migrateOldEstimateLines(lines) {
  (lines || []).forEach(l => {
    if (l.supplier == null) l.supplier = '';
    if (l.orderPrice == null) l.orderPrice = 0;
    if (!('orderAmountOverride' in l)) l.orderAmountOverride = null;
    if (l.materialPrice == null) l.materialPrice = 0;  // 材料単価(新フィールド)
    // HC/エアコン高圧洗浄系は 入居者 デフォルト → 旧 '家主' migration を補正
    if (/ハウスクリーニング|エアコン高圧洗浄|エアコンクリーニング/.test(l.item || '')) {
      if (l.burdenType !== '入居者' && l.burdenType !== '自社のみ') {
        l.burdenType = '入居者';
      }
    }
    // note を specs(仕様摘要)に引き継ぐ(後方互換)
    if (l.room == null) l.room = '';
    if (l.specs == null) l.specs = l.note || '';
    // カテゴリー名移行: ハウスクリーニング → 清掃工事 / item にプレフィックス
    if (l.category === 'ハウスクリーニング') {
      l.category = '清掃工事';
      if (l.item && !l.item.startsWith('ハウスクリーニング')) {
        l.item = 'ハウスクリーニング ' + l.item;
      }
    } else if (l.category === '清掃') {
      // 旧"清掃"カテゴリも 清掃工事 に統合
      l.category = '清掃工事';
    } else if (l.category === 'エアコン洗浄') {
      // 旧"エアコン洗浄"カテゴリも 清掃工事 に統合
      l.category = '清掃工事';
    }
  });
}

function loadEstimates() {
  const s = localStorage.getItem(STORAGE_KEYS.estimates);
  if (s) {
    try {
      const obj = JSON.parse(s);
      // 各見積の行をマイグレーション
      Object.values(obj).forEach(est => {
        migrateOldEstimateLines(est.lines);
        migrateOldEstimateAtena(est.meta);
        if (est.meta && !est.meta.taikyo) est.meta.taikyo = emptyTaikyo();
        // ステータス関連のデフォルト補完
        if (est.meta && !est.meta.status) est.meta.status = '下書き';
        if (est.meta && est.meta.submittedAt === undefined) est.meta.submittedAt = '';
        if (est.meta && est.meta.completedAt === undefined) est.meta.completedAt = '';
        if (est.meta && est.meta.motoukeOrderAmount === undefined) est.meta.motoukeOrderAmount = null;
        if (est.meta && !est.meta.hatchuOrder) est.meta.hatchuOrder = emptyHatchuOrder();
        if (est.meta && !est.meta.oshirase) est.meta.oshirase = emptyOshirase();
        if (est.meta && !est.meta.koutei) est.meta.koutei = emptyKoutei();
        // 各行の reduced フィールド補完
        (est.lines || []).forEach(l => {
          if (l.reduced === undefined) l.reduced = false;
          if (l.reducedReason === undefined) l.reducedReason = '';
        });
      });
      return obj;
    } catch(e) {}
  }
  // 旧単一見積があれば台帳の1件目に移行
  const old = localStorage.getItem(STORAGE_KEYS.estimate);
  if (old) {
    try {
      const parsed = JSON.parse(old);
      migrateOldEstimateLines(parsed.lines);
      const mig = {
        id: newEstimateId(),
        createdAt: new Date().toISOString(),
        updatedAt: new Date().toISOString(),
        meta: parsed.meta || { bukken:'', date:formatToday(), atena:'', orderSupplierFilter:'__all__' },
        lines: parsed.lines || [],
      };
      if (mig.meta.orderSupplierFilter == null) mig.meta.orderSupplierFilter = '__all__';
      return { [mig.id]: mig };
    } catch(e) {}
  }
  return {};
}

