function inferSubcat(categoryName, itemName) {
  const rules = SUBCAT_RULES[categoryName];
  if (!rules) return { order:99, name:'' };
  const item = itemName || '';
  for (const [order, name, re] of rules) {
    if (re.test(item)) return { order, name };
  }
  return { order: 99, name: 'その他' };
}

