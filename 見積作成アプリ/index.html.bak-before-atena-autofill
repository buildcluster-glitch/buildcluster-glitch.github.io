}

// 比較ボタンのハンドラ
const _btnComparePdf = document.getElementById('btn-compare-pdf');
if (_btnComparePdf) {
  _btnComparePdf.addEventListener('click', async () => {
    const fileInp = document.getElementById('motouke-order-pdf');
    const file = fileInp?.files?.[0];
    if (!file) { showToast('発注書PDFを選択してください', true); return; }
    showToast('PDFを解析中…');
    try {
      const text = await extractPdfText(file);
      const orderItems = parseOrderItems(text);
      if (!orderItems.length) {
        showToast('発注書から明細を抽出できませんでした。PDF構造を確認してください', true);
        console.log('[compare] PDF text:\n', text);
        return;
      }
      console.log('[compare] 抽出された発注書明細:', orderItems);
      const { results, unmatched } = matchEstimateToOrder(state.estimate.lines, orderItems);
      showComparisonResult(results, unmatched);
    } catch (e) {
      console.error(e);
      showToast('PDF解析エラー: ' + (e.message||e), true);
    }
  });
}

// 元請け発注額 入力 → state保存 + 一致チェック更新
